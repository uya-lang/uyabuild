    return mem as &SourceFile;
}

fn append_source_file(ctx: &Phase1Context, file: &SourceFile) void {
    if ctx.files_head == null {
        ctx.files_head = file;
        ctx.files_tail = file;
    } else {
        ctx.files_tail.next = file;
        ctx.files_tail = file;
    }
    ctx.file_count = ctx.file_count + 1;
}

