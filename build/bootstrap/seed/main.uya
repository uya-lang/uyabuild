fn phase2_ctx_init(ctx: &Phase2Context,
                   phase1: &Phase1Context,
                   state_layout: &StateLayout,
                   manifest: &RunManifest,
                   requested_count: i32,
                   matched_count: i32) void {
    ctx.phase1 = phase1;
    ctx.state_layout = state_layout;
    ctx.manifest = manifest;
    ctx.snapshot_head = null;
    ctx.action_head = null;
    ctx.action_tail = null;
    ctx.visit_head = null;
    ctx.requested_count = requested_count;
    ctx.matched_count = matched_count;
    ctx.snapshot_count = 0;
    ctx.action_count = 0;
    ctx.cache_hit_count = 0;
    ctx.seeded_count = 0;
    ctx.pending_count = 0;
    ctx.root_digest = null;
}

fn append_buffer_bytes(buffer: &byte, used: &usize, cap: usize, src: &byte, src_len: usize) i32 {
    if buffer == null || used == null || src == null {
        return -1;
    }
    if used[0] + src_len + 1usize > cap {
        return -1;
    }
    if src_len > 0 {
        memcpy(&buffer[used[0]] as &byte, src, src_len);
    }
    used[0] = used[0] + src_len;
    buffer[used[0]] = 0 as byte;
    return 0;
}

fn append_buffer_text(buffer: &byte, used: &usize, cap: usize, text: &byte) i32 {
    if text == null {
        return append_buffer_bytes(buffer, used, cap, "" as &byte, 0usize);
    }
    return append_buffer_bytes(buffer, used, cap, text, strlen(text));
}

fn append_buffer_byte(buffer: &byte, used: &usize, cap: usize, value: byte) i32 {
    if buffer == null || used == null {
        return -1;
    }
    if used[0] + 2usize > cap {
        return -1;
    }
    buffer[used[0]] = value;
    used[0] = used[0] + 1usize;
    buffer[used[0]] = 0 as byte;
    return 0;
}

fn digest_hex_char(nibble: byte) byte {
    if nibble < 10 as byte {
        return (48 + nibble as i32) as byte;
    }
    return (87 + nibble as i32) as byte;
}

fn bytes_to_hex_text(ctx: &Phase1Context, bytes: &byte, len: usize) &byte {
    if ctx == null || bytes == null {
        return null;
    }
    const out: &byte = arena_alloc_zero(&ctx.arena, len * 2usize + 1usize);
    if out == null {
        return null;
    }
    var i: usize = 0usize;
    while i < len {
        out[i * 2usize] = digest_hex_char((bytes[i] >> 4) & (15 as byte));
        out[i * 2usize + 1usize] = digest_hex_char(bytes[i] & (15 as byte));
        i = i + 1usize;
    }
    const tail_ptr: &byte = out + (len * 2usize);
    tail_ptr[0] = 0 as byte;
    return out;
}

fn blake2s_hex_bytes(ctx: &Phase1Context, data: &byte, data_len: usize) &byte {
    if ctx == null || data == null {
        return null;
    }
    var digest: [byte: DIGEST_BYTES] = [];
    const data_slice: &[byte] = data[0: data_len];
    blake2s_digest(data_slice, digest[0: DIGEST_BYTES]);
    return bytes_to_hex_text(ctx, &digest[0] as &byte, DIGEST_BYTES);
}

fn blake2s_hex_text(ctx: &Phase1Context, text: &byte) &byte {
    if text == null {
        return null;
    }
    return blake2s_hex_bytes(ctx, text, strlen(text));
}

fn find_source_file(ctx: &Phase1Context, abs_path: &byte) &SourceFile {
    var file: &SourceFile = ctx.files_head;
    while file != null {
        if string_equals(file.abs_path, abs_path) != 0 {
            return file;
        }
        file = file.next;
    }
    return null;
}

fn source_display_path(ctx: &Phase1Context, file: &SourceFile) &byte {
    _ = ctx;
    if file == null {
        return "" as &byte;
    }
    return file.rel_path;
}

fn read_file_into_arena(ctx: &Phase1Context, path: &byte, size_out: &usize) &byte {
    var st: Stat = zero_stat();
    if stat(path as &const byte, &st) != 0 {
        return null;
    }
    if st.st_size < 0 {
        return null;
    }

    const file_size_result: !usize = st.st_size as! usize;
    const file_size: usize = file_size_result catch {
        return null;
    };
    var content: &byte = arena_alloc_zero(&ctx.arena, file_size + 1);
    if content == null {
        return null;
    }

    const file: &FILE = fopen(path as *byte, "r" as *byte);
    if file == null {
        return null;
    }
    const bytes_read: usize = fread(content as *void, 1, file_size, file);
    _ = fclose(file);

    const end_ptr: &byte = content + bytes_read;
    end_ptr[0] = 0 as byte;
    size_out[0] = bytes_read;
    return content;
}

fn new_source_file(ctx: &Phase1Context) &SourceFile {
    const mem: &byte = arena_alloc_zero(&ctx.arena, @size_of(SourceFile));
