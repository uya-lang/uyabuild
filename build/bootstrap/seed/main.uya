fn zero_stat() Stat {
    return Stat {
        st_dev: 0,
        st_ino: 0,
        st_nlink: 0,
        st_mode: 0,
        st_uid: 0,
        st_gid: 0,
        _pad0: 0,
        st_rdev: 0,
        st_size: 0,
        st_blksize: 0,
        st_blocks: 0,
        st_atime: 0,
        st_atime_nsec: 0,
        st_mtime: 0,
        st_mtime_nsec: 0,
        st_ctime: 0,
        st_ctime_nsec: 0,
        _unused0: 0,
        _unused1: 0,
        _unused2: 0,
    };
}

fn string_equals(left: &byte, right: &byte) i32 {
    if left == null || right == null {
        return 0;
    }
    if strcmp(left as *byte, right as *byte) == 0 {
        return 1;
    }
    return 0;
}

fn copy_string(out: &byte, out_cap: usize, text: &byte) i32 {
    if out == null || out_cap == 0 || text == null {
        return -1;
    }
    const written: i32 = snprintf(out as *byte, out_cap, "%s" as *byte, text as *byte);
    if written < 0 || written >= out_cap as i32 {
        return -1;
    }
    return 0;
}

fn path_is_absolute(path: &byte) i32 {
    if path == null || path[0] == 0 as byte {
        return 0;
    }
    if path[0] == 47 as byte || path[0] == 92 as byte {
        return 1;
    }
    const len: usize = strlen(path);
    if len < 3 {
        return 0;
    }
    const c0: i32 = path[0] as i32;
    if ((c0 >= 65 && c0 <= 90) || (c0 >= 97 && c0 <= 122)) &&
        path[1] == 58 as byte &&
        (path[2] == 47 as byte || path[2] == 92 as byte) {
        return 1;
    }
    return 0;
}

fn join_path(left: &byte, right: &byte, out: &byte, out_cap: usize) i32 {
    if left == null || right == null || out == null || out_cap == 0 {
        return -1;
    }
    if left[0] == 0 as byte {
        return copy_string(out, out_cap, right);
    }
    if right[0] == 0 as byte {
        return copy_string(out, out_cap, left);
    }

    const left_len: usize = strlen(left);
    var needs_separator: i32 = 1;
    if left_len > 0 && left[left_len - 1] == 47 as byte {
        needs_separator = 0;
    }

    var written: i32 = 0;
    if needs_separator != 0 {
        written = snprintf(out as *byte, out_cap, "%s/%s" as *byte, left as *byte, right as *byte);
    } else {
        written = snprintf(out as *byte, out_cap, "%s%s" as *byte, left as *byte, right as *byte);
    }

    if written < 0 || written >= out_cap as i32 {
        return -1;
    }
    return 0;
}

fn abspath_from_base(base: &byte, path: &byte, out: &byte, out_cap: usize) i32 {
    if base == null || path == null {
        return -1;
    }
    if path_is_absolute(path) != 0 {
        return copy_string(out, out_cap, path);
    }
    return join_path(base, path, out, out_cap);
}

fn path_is_dir(path: &byte) i32 {
    if path == null {
        return 0;
    }
    var st: Stat = zero_stat();
    if stat(path as &const byte, &st) != 0 {
        return 0;
    }
    if ((st.st_mode as u32) & S_IFMT) == S_IFDIR {
        return 1;
    }
    return 0;
}

fn path_is_file(path: &byte) i32 {
    if path == null {
        return 0;
    }
    var st: Stat = zero_stat();
    if stat(path as &const byte, &st) != 0 {
        return 0;
    }
    if ((st.st_mode as u32) & S_IFMT) == S_IFREG {
        return 1;
    }
    return 0;
}

fn ensure_dir_recursive(path: &byte) i32 {
    if path == null || path[0] == 0 as byte {
        return -1;
    }
    if path_is_dir(path) != 0 {
        return 0;
    }

    var buf: [byte: PATH_MAX] = [];
    if copy_string(&buf[0] as &byte, PATH_MAX, path) != 0 {
        return -1;
    }

    const len: usize = strlen(&buf[0] as &byte);
    var i: usize = 1;
    while i < len {
        if buf[i] == 47 as byte {
            buf[i] = 0 as byte;
            if buf[0] != 0 as byte {
                _ = mkdir(&buf[0] as &const byte, 493);
            }
            buf[i] = 47 as byte;
        }
        i = i + 1;
    }

    _ = mkdir(&buf[0] as &const byte, 493);
    if path_is_dir(path) == 0 {
        return -1;
    }
    return 0;
}

fn trim_to_parent(path: &byte) i32 {
    if path == null {
        return -1;
    }

    const len_usize: usize = strlen(path);
    if len_usize > 2147483647usize {
        return -1;
    }
    const len_result: !i32 = len_usize as! i32;
    var len: i32 = len_result catch {
        return -1;
    };
    if len <= 0 {
        return -1;
    }
    if len == 1 && path[0] == 47 as byte {
        return 1;
    }

    var idx: i32 = len - 1;
    while idx > 0 && path[idx as usize] == 47 as byte {
        path[idx as usize] = 0 as byte;
        idx = idx - 1;
    }
    while idx > 0 && path[idx as usize] != 47 as byte {
        idx = idx - 1;
    }
    if idx <= 0 {
        path[1] = 0 as byte;
    } else {
        path[idx as usize] = 0 as byte;
    }
    return 0;
}

fn find_workspace_root(start_dir: &byte, out: &byte, out_cap: usize) i32 {
    var current: [byte: PATH_MAX] = [];
    var uya_build_path: [byte: PATH_MAX] = [];
    var uya_toml_path: [byte: PATH_MAX] = [];

    if copy_string(&current[0] as &byte, PATH_MAX, start_dir) != 0 {
        return -1;
    }

    while true {
        if join_path(&current[0] as &byte, "uya.build" as &byte, &uya_build_path[0] as &byte, PATH_MAX) == 0 &&
            path_is_file(&uya_build_path[0] as &byte) != 0 {
            return copy_string(out, out_cap, &current[0] as &byte);
        }

        if join_path(&current[0] as &byte, "uya.toml" as &byte, &uya_toml_path[0] as &byte, PATH_MAX) == 0 &&
            path_is_file(&uya_toml_path[0] as &byte) != 0 {
            return copy_string(out, out_cap, &current[0] as &byte);
        }

        if string_equals(&current[0] as &byte, "/" as &byte) != 0 {
            break;
        }
        if trim_to_parent(&current[0] as &byte) != 0 {
            break;
        }
    }

    return -1;
}

fn workspace_has_entrypoint(root: &byte, entrypoint: &byte, entrypoint_cap: usize) i32 {
    var uya_build_path: [byte: PATH_MAX] = [];
    var uya_toml_path: [byte: PATH_MAX] = [];

    if join_path(root, "uya.build" as &byte, &uya_build_path[0] as &byte, PATH_MAX) != 0 {
        return -1;
    }
    if join_path(root, "uya.toml" as &byte, &uya_toml_path[0] as &byte, PATH_MAX) != 0 {
        return -1;
    }

    if path_is_file(&uya_build_path[0] as &byte) != 0 {
        return copy_string(entrypoint, entrypoint_cap, &uya_build_path[0] as &byte);
    }
    if path_is_file(&uya_toml_path[0] as &byte) != 0 {
        return copy_string(entrypoint, entrypoint_cap, &uya_toml_path[0] as &byte);
    }
    return 1;
}

fn string_has_prefix(text: &byte, prefix: &byte) i32 {
    if text == null || prefix == null {
        return 0;
    }
    const prefix_len: usize = strlen(prefix);
    if strlen(text) < prefix_len {
        return 0;
    }
    if strcmp(prefix as *byte, "" as *byte) == 0 {
        return 1;
    }
    var i: usize = 0;
    while i < prefix_len {
        if text[i] != prefix[i] {
            return 0;
        }
        i = i + 1;
    }
    return 1;
}

fn string_has_suffix(text: &byte, suffix: &byte) i32 {
    if text == null || suffix == null {
        return 0;
    }
    const text_len: usize = strlen(text);
    const suffix_len: usize = strlen(suffix);
    if suffix_len > text_len {
        return 0;
    }
    var i: usize = 0;
    while i < suffix_len {
        if text[text_len - suffix_len + i] != suffix[i] {
            return 0;
        }
        i = i + 1;
    }
    return 1;
}

fn cstr_compare(left: &byte, right: &byte) i32 {
    if left == null && right == null {
        return 0;
    }
    if left == null {
        return -1;
    }
    if right == null {
        return 1;
    }
    return strcmp(left as *byte, right as *byte);
}

fn arena_alloc_zero(arena: &Arena, size: usize) &byte {
    const ptr: &byte = arena_alloc(arena, size);
    if ptr == null {
        return null;
    }
    memset(ptr, 0, size);
    return ptr;
}

fn usize_to_i32_checked(value: usize) i32 {
    const result: !i32 = value as! i32;
    return result catch {
        return 2147483647;
    };
}

fn i32_to_usize_checked(value: i32) usize {
    const result: !usize = value as! usize;
    return result catch {
        return 0usize;
    };
}

fn clone_span(span: &SourceSpan) SourceSpan {
    if span == null {
        return zero_span();
    }
    return new_source_span(span.start.line,
                           span.start.column,
                           span.start.offset,
                           span.end.line,
                           span.end.column,
                           span.end.offset);
}

fn arena_copy_cstr(arena: &Arena, text: &byte) &byte {
    if arena == null || text == null {
        return null;
    }
    const len: usize = strlen(text);
    var out: &byte = arena_alloc_zero(arena, len + 1);
    if out == null {
        return null;
    }
    if len > 0 {
        memcpy(out, text, len);
    }
    const tail_ptr: &byte = out + len;
    tail_ptr[0] = 0 as byte;
    return out;
}

fn arena_copy_range(arena: &Arena, base: &byte, start: usize, len: usize) &byte {
    if arena == null || base == null {
        return null;
    }
    var out: &byte = arena_alloc_zero(arena, len + 1);
    if out == null {
        return null;
    }
    if len > 0 {
        memcpy(out, &base[start] as &byte, len);
    }
    const tail_ptr: &byte = out + len;
    tail_ptr[0] = 0 as byte;
    return out;
}

fn new_source_pos(line: i32, column: i32, offset: i32) SourcePos {
    return SourcePos {
        line: line,
        column: column,
        offset: offset,
    };
}

fn new_source_span(start_line: i32,
                   start_column: i32,
                   start_offset: i32,
                   end_line: i32,
                   end_column: i32,
                   end_offset: i32) SourceSpan {
    return SourceSpan {
        start: new_source_pos(start_line, start_column, start_offset),
        end: new_source_pos(end_line, end_column, end_offset),
    };
}

fn zero_span() SourceSpan {
    return new_source_span(0, 0, 0, 0, 0, 0);
}

fn set_diagnostic(ctx: &Phase1Context,
                  exit_code: i32,
                  code: &byte,
                  message: &byte,
                  detail: &byte,
                  file: &byte,
                  line: i32,
                  column: i32) i32 {
    if ctx == null {
        return -1;
    }
    ctx.diagnostic.exit_code = exit_code;
    ctx.diagnostic.code = code;
    ctx.diagnostic.message = message;
    ctx.diagnostic.detail = detail;
    ctx.diagnostic.file = file;
    ctx.diagnostic.line = line;
    ctx.diagnostic.column = column;
    return -1;
}

fn emit_diagnostic(mode: i32, diag: &Diagnostic) i32 {
    if diag == null {
        return EXIT_CONFIG;
    }

    var detail_text: &byte = diag.detail;
    if detail_text == null {
        detail_text = "" as &byte;
    }
    var file_text: &byte = diag.file;
    if file_text == null {
        file_text = "" as &byte;
    }

    if mode == OUTPUT_JSON {
        fputs("{\"ok\":false,\"exit_code\":" as *byte, libc.stderr);
        fprintf(libc.stderr, "%d" as *byte, diag.exit_code);
        fputs(",\"code\":\"" as *byte, libc.stderr);
        write_json_escape(libc.stderr, diag.code);
        fputs("\",\"message\":\"" as *byte, libc.stderr);
        write_json_escape(libc.stderr, diag.message);
        fputs("\",\"detail\":\"" as *byte, libc.stderr);
        write_json_escape(libc.stderr, detail_text);
        fputs("\",\"file\":\"" as *byte, libc.stderr);
        write_json_escape(libc.stderr, file_text);
        fputs("\",\"line\":" as *byte, libc.stderr);
        fprintf(libc.stderr, "%d" as *byte, diag.line);
        fputs(",\"column\":" as *byte, libc.stderr);
        fprintf(libc.stderr, "%d" as *byte, diag.column);
        fputs("}\n" as *byte, libc.stderr);
    } else {
        fprintf(libc.stderr, "%s: %s\n" as *byte, diag.code as *byte, diag.message as *byte);
        if file_text[0] != 0 as byte && diag.line > 0 && diag.column > 0 {
            fprintf(libc.stderr, "at: %s:%d:%d\n" as *byte, file_text as *byte, diag.line, diag.column);
        } else if file_text[0] != 0 as byte {
            fprintf(libc.stderr, "at: %s\n" as *byte, file_text as *byte);
        }
        if detail_text[0] != 0 as byte {
            fprintf(libc.stderr, "detail: %s\n" as *byte, detail_text as *byte);
        }
    }

    _ = fflush(libc.stderr);
    return diag.exit_code;
}

fn phase1_error(ctx: &Phase1Context,
                code: &byte,
                message: &byte,
                detail: &byte,
                file: &byte,
                line: i32,
                column: i32) i32 {
    return set_diagnostic(ctx, EXIT_CONFIG, code, message, detail, file, line, column);
}

fn normalize_path_text(input: &byte, out: &byte, out_cap: usize) i32 {
    if input == null || out == null || out_cap == 0 {
        return -1;
    }

    var segments: [usize: 512] = [];
    var segment_count: usize = 0;
    var out_pos: usize = 0;
    const absolute: i32 = path_is_absolute(input);
    var i: usize = 0;

    if absolute != 0 {
        if out_cap < 2 {
            return -1;
        }
        out[0] = 47 as byte;
        out_pos = 1;
        while input[i] == 47 as byte {
            i = i + 1;
        }
    }

    while true {
        while input[i] == 47 as byte {
            i = i + 1;
        }
        if input[i] == 0 as byte {
            break;
        }

        const seg_start: usize = i;
        while input[i] != 0 as byte && input[i] != 47 as byte {
            i = i + 1;
        }
        const seg_len: usize = i - seg_start;

        if seg_len == 1 && input[seg_start] == 46 as byte {
            continue;
        }
        if seg_len == 2 &&
            input[seg_start] == 46 as byte &&
            input[seg_start + 1] == 46 as byte {
            if segment_count > 0 {
                const prev_count: usize = segment_count - 1usize;
                if prev_count >= 512usize {
                    return -1;
                }
                segment_count = prev_count;
                out_pos = segments[prev_count];
                out[out_pos] = 0 as byte;
            } else if absolute == 0 {
                if out_pos != 0 {
                    if out_pos + 1 >= out_cap {
                        return -1;
                    }
                    out[out_pos] = 47 as byte;
                    out_pos = out_pos + 1;
                }
                if out_pos + 2 >= out_cap {
                    return -1;
                }
                segments[segment_count] = out_pos;
                segment_count = segment_count + 1;
                out[out_pos] = 46 as byte;
                out[out_pos + 1] = 46 as byte;
                out_pos = out_pos + 2;
                out[out_pos] = 0 as byte;
            }
            continue;
        }

        if segment_count >= 512usize {
            return -1;
        }

        if out_pos > 0 && out[out_pos - 1] != 47 as byte {
            if out_pos + 1 >= out_cap {
                return -1;
            }
            out[out_pos] = 47 as byte;
            out_pos = out_pos + 1;
        }

        segments[segment_count] = out_pos;
        segment_count = segment_count + 1;

        if out_pos + seg_len >= out_cap {
            return -1;
        }

        memcpy(&out[out_pos] as &byte, &input[seg_start] as &byte, seg_len);
        out_pos = out_pos + seg_len;
        out[out_pos] = 0 as byte;
    }

    if out_pos == 0 {
        if absolute != 0 {
            if out_cap < 2 {
                return -1;
            }
            out[0] = 47 as byte;
            out[1] = 0 as byte;
        } else {
            if out_cap < 2 {
                return -1;
            }
            out[0] = 46 as byte;
            out[1] = 0 as byte;
        }
    } else {
        out[out_pos] = 0 as byte;
    }

    return 0;
}

fn join_and_normalize_path(left: &byte, right: &byte, out: &byte, out_cap: usize) i32 {
    var joined: [byte: PATH_MAX] = [];
    if right == null || out == null {
        return -1;
    }
    if path_is_absolute(right) != 0 {
        return normalize_path_text(right, out, out_cap);
    }
    if join_path(left, right, &joined[0] as &byte, PATH_MAX) != 0 {
        return -1;
    }
    return normalize_path_text(&joined[0] as &byte, out, out_cap);
}

fn path_dirname_text(path: &byte, out: &byte, out_cap: usize) i32 {
    if path == null || out == null || out_cap == 0 {
        return -1;
    }
    const len: usize = strlen(path);
    if len == 0 {
        return copy_string(out, out_cap, "." as &byte);
    }

    var slash_index: usize = 0usize;
    var has_slash: i32 = 0;
    var i: usize = 0;
    while i < len {
        if path[i] == 47 as byte {
            slash_index = i;
            has_slash = 1;
        }
        i = i + 1;
    }

    if has_slash == 0 {
        return copy_string(out, out_cap, "." as &byte);
    }
    if slash_index == 0 {
        if out_cap < 2 {
            return -1;
        }
        out[0] = 47 as byte;
        out[1] = 0 as byte;
        return 0;
    }

    const copy_len: usize = slash_index;
    if copy_len + 1 > out_cap {
        return -1;
    }
    memcpy(out, path, copy_len);
    out[copy_len] = 0 as byte;
    return 0;
}

fn path_relative_to_root(root: &byte, path: &byte, out: &byte, out_cap: usize) i32 {
    if root == null || path == null || out == null {
        return -1;
    }
    const root_len: usize = strlen(root);
    if string_has_prefix(path, root) == 0 {
        return copy_string(out, out_cap, path);
    }
    var offset: usize = root_len;
    if path[offset] == 47 as byte {
        offset = offset + 1;
    }
    return copy_string(out, out_cap, &path[offset] as &byte);
}

fn package_from_rel_path(rel_path: &byte, out: &byte, out_cap: usize) i32 {
    var dir_buf: [byte: PATH_MAX] = [];
    if path_dirname_text(rel_path, &dir_buf[0] as &byte, PATH_MAX) != 0 {
        return -1;
    }
    if string_equals(&dir_buf[0] as &byte, "." as &byte) != 0 {
        return copy_string(out, out_cap, "" as &byte);
    }
    return copy_string(out, out_cap, &dir_buf[0] as &byte);
}

fn phase1_ctx_init(ctx: &Phase1Context, workspace_root: &byte, entrypoint_path: &byte) void {
    arena_init(&ctx.arena, &phase1_arena_storage[0] as &byte, PHASE1_ARENA_SIZE as usize);
    ctx.workspace_root = arena_copy_cstr(&ctx.arena, workspace_root);
    ctx.entrypoint_path = arena_copy_cstr(&ctx.arena, entrypoint_path);
    ctx.root_build_path = null;
    ctx.root_toml_path = null;
    ctx.files_head = null;
    ctx.files_tail = null;
    ctx.uses_head = null;
    ctx.uses_tail = null;
    ctx.configs_head = null;
    ctx.configs_tail = null;
    ctx.targets_head = null;
    ctx.workspace_ir = IRWorkspace {
        source_file: null,
        span: zero_span(),
        name: null,
        defaults: null,
        strict: 0,
        has_name: 0,
        has_defaults: 0,
        has_strict: 0,
    };
    ctx.toml_meta = TomlWorkspaceMeta {
        has_name: 0,
        has_default: 0,
        has_strict: 0,
        name: null,
        defaults: null,
        strict: 0,
    };
    ctx.file_count = 0;
    ctx.use_count = 0;
    ctx.config_count = 0;
    ctx.target_count = 0;
    ctx.diagnostic = Diagnostic {
        exit_code: EXIT_CONFIG,
        code: null,
        message: null,
        detail: null,
        file: null,
        line: 0,
        column: 0,
    };
}

fn is_dirent_dot(name: &byte) i32 {
    if name == null {
        return 0;
    }
    if name[0] == 46 as byte && name[1] == 0 as byte {
        return 1;
    }
    if name[0] == 46 as byte && name[1] == 46 as byte && name[2] == 0 as byte {
        return 1;
    }
    return 0;
}

fn dirent_is_directory(entry: &Dirent, abs_path: &byte) i32 {
    if entry == null {
        return 0;
    }
    if entry.d_type as i32 == DT_DIR {
        return 1;
    }
    if entry.d_type as i32 == DT_UNKNOWN {
        return path_is_dir(abs_path);
    }
    return 0;
}

fn dirent_is_regular_file(entry: &Dirent, abs_path: &byte) i32 {
    if entry == null {
        return 0;
    }
    if entry.d_type as i32 == DT_REG {
        return 1;
    }
    if entry.d_type as i32 == DT_UNKNOWN {
        return path_is_file(abs_path);
    }
    return 0;
}

fn new_string_node(ctx: &Phase1Context, text: &byte) &StringNode {
    const node_mem: &byte = arena_alloc_zero(&ctx.arena, @size_of(StringNode));
    if node_mem == null {
        return null;
    }
    const node: &StringNode = node_mem as &StringNode;
    node.text = arena_copy_cstr(&ctx.arena, text);
    node.next = null;
    return node;
}

fn sorted_string_insert(ctx: &Phase1Context, head: &StringNode, text: &byte, inserted: &i32) &StringNode {
    const node: &StringNode = new_string_node(ctx, text);
    if node == null {
        inserted[0] = 0;
        return head;
    }
    inserted[0] = 1;

    if head == null || cstr_compare(text, head.text) < 0 {
        node.next = head;
        return node;
    }

    var current: &StringNode = head;
    while current.next != null && cstr_compare(current.next.text, text) < 0 {
        current = current.next;
    }
    if current.next != null && string_equals(current.next.text, text) != 0 {
        inserted[0] = 0;
        return head;
    }
    if string_equals(current.text, text) != 0 {
        inserted[0] = 0;
        return head;
    }
    node.next = current.next;
    current.next = node;
    return head;
}

