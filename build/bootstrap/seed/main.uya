fn append_ir_field(head: &IRField, field: &IRField) &IRField {
    if head == null {
        return field;
    }
    var current: &IRField = head;
    while current.next != null {
        current = current.next;
    }
    current.next = field;
    return head;
}

fn find_ir_field(head: &IRField, name: &byte) &IRField {
    var current: &IRField = head;
    while current != null {
        if string_equals(current.name, name) != 0 {
            return current;
        }
        current = current.next;
    }
    return null;
}

fn parser_init(parser: &BuildParser, ctx: &Phase1Context, file: &SourceFile) void {
    parser.ctx = ctx;
    parser.file = file;
    parser.source = file.content;
    parser.size = file.size;
    parser.pos = 0usize;
    parser.line = 1;
    parser.column = 1;
    parser.current = Token {
        kind: TOKEN_EOF,
        text: null,
        span: zero_span(),
    };
}

fn parser_current_byte(parser: &BuildParser) byte {
    if parser.pos >= parser.size {
        return 0 as byte;
    }
    return parser.source[parser.pos];
}

fn parser_advance_char(parser: &BuildParser) byte {
    const ch: byte = parser_current_byte(parser);
    if ch == 0 as byte {
        return ch;
    }
    parser.pos = parser.pos + 1;
    if ch == 10 as byte {
        parser.line = parser.line + 1;
        parser.column = 1;
    } else {
        parser.column = parser.column + 1;
    }
    return ch;
}

fn parser_skip_ws_and_comments(parser: &BuildParser) void {
    while true {
        const ch: byte = parser_current_byte(parser);
        if ch == 32 as byte || ch == 9 as byte || ch == 10 as byte || ch == 13 as byte {
            _ = parser_advance_char(parser);
            continue;
        }
        if ch == 35 as byte {
            while parser_current_byte(parser) != 0 as byte &&
                parser_current_byte(parser) != 10 as byte {
                _ = parser_advance_char(parser);
            }
            continue;
        }
        break;
    }
}

fn parser_make_simple_token(parser: &BuildParser, kind: i32, ch: byte) Token {
    var buf: [byte: 2] = [];
    buf[0] = ch;
    buf[1] = 0 as byte;
    return Token {
        kind: kind,
        text: arena_copy_cstr(&parser.ctx.arena, &buf[0] as &byte),
        span: new_source_span(parser.line,
                              parser.column,
                              usize_to_i32_checked(parser.pos),
                              parser.line,
                              parser.column + 1,
                              usize_to_i32_checked(parser.pos + 1usize)),
    };
}

fn parser_next_token(parser: &BuildParser) i32 {
    parser_skip_ws_and_comments(parser);
    const start_line: i32 = parser.line;
    const start_column: i32 = parser.column;
    const start_offset: i32 = usize_to_i32_checked(parser.pos);
    const ch: byte = parser_current_byte(parser);

    if ch == 0 as byte {
        parser.current = Token {
            kind: TOKEN_EOF,
            text: "" as &byte,
            span: new_source_span(start_line, start_column, start_offset, start_line, start_column, start_offset),
        };
        return 0;
    }

    if ch == 123 as byte {
        parser.current = parser_make_simple_token(parser, TOKEN_LBRACE, ch);
        _ = parser_advance_char(parser);
        return 0;
    }
    if ch == 125 as byte {
        parser.current = parser_make_simple_token(parser, TOKEN_RBRACE, ch);
        _ = parser_advance_char(parser);
        return 0;
    }
    if ch == 91 as byte {
        parser.current = parser_make_simple_token(parser, TOKEN_LBRACKET, ch);
        _ = parser_advance_char(parser);
        return 0;
    }
    if ch == 93 as byte {
        parser.current = parser_make_simple_token(parser, TOKEN_RBRACKET, ch);
        _ = parser_advance_char(parser);
        return 0;
    }
    if ch == 40 as byte {
        parser.current = parser_make_simple_token(parser, TOKEN_LPAREN, ch);
        _ = parser_advance_char(parser);
        return 0;
    }
    if ch == 41 as byte {
        parser.current = parser_make_simple_token(parser, TOKEN_RPAREN, ch);
        _ = parser_advance_char(parser);
        return 0;
    }
    if ch == 61 as byte {
        parser.current = parser_make_simple_token(parser, TOKEN_EQUAL, ch);
        _ = parser_advance_char(parser);
        return 0;
    }
    if ch == 44 as byte {
        parser.current = parser_make_simple_token(parser, TOKEN_COMMA, ch);
        _ = parser_advance_char(parser);
        return 0;
    }
    if ch == 46 as byte {
        parser.current = parser_make_simple_token(parser, TOKEN_DOT, ch);
        _ = parser_advance_char(parser);
        return 0;
    }

    if ch == 34 as byte {
        _ = parser_advance_char(parser);
        var decoded: [byte: MAX_STRING_BUILD] = [];
        var out_pos: usize = 0usize;
        while true {
            const current: byte = parser_current_byte(parser);
            if current == 0 as byte {
                return phase1_error(parser.ctx,
                                    "UYABUILD_E_PARSE_STRING" as &byte,
                                    "unterminated string literal" as &byte,
                                    "expected a closing quote before end of file" as &byte,
                                    source_display_path(parser.ctx, parser.file),
                                    start_line,
                                    start_column);
            }
            if current == 34 as byte {
                _ = parser_advance_char(parser);
                break;
            }
            if current == 92 as byte {
                _ = parser_advance_char(parser);
                const escaped: byte = parser_current_byte(parser);
                if escaped == 0 as byte {
                    return phase1_error(parser.ctx,
                                        "UYABUILD_E_PARSE_STRING" as &byte,
                                        "unterminated string escape" as &byte,
                                        "escape sequence ended unexpectedly" as &byte,
                                        source_display_path(parser.ctx, parser.file),
                                        parser.line,
                                        parser.column);
                }
                if out_pos + 1 >= MAX_STRING_BUILD {
                    return phase1_error(parser.ctx,
                                        "UYABUILD_E_PARSE_STRING" as &byte,
                                        "string literal is too long" as &byte,
                                        "increase the bootstrap literal buffer or shorten the literal" as &byte,
                                        source_display_path(parser.ctx, parser.file),
                                        start_line,
                                        start_column);
                }
                if escaped == 110 as byte {
                    decoded[out_pos] = 10 as byte;
                } else if escaped == 114 as byte {
                    decoded[out_pos] = 13 as byte;
                } else if escaped == 116 as byte {
                    decoded[out_pos] = 9 as byte;
                } else {
                    decoded[out_pos] = escaped;
                }
                out_pos = out_pos + 1;
                _ = parser_advance_char(parser);
                continue;
            }
            if out_pos + 1 >= MAX_STRING_BUILD {
                return phase1_error(parser.ctx,
                                    "UYABUILD_E_PARSE_STRING" as &byte,
                                    "string literal is too long" as &byte,
                                    "increase the bootstrap literal buffer or shorten the literal" as &byte,
                                    source_display_path(parser.ctx, parser.file),
                                    start_line,
                                    start_column);
            }
            decoded[out_pos] = current;
            out_pos = out_pos + 1;
            _ = parser_advance_char(parser);
        }
        decoded[out_pos] = 0 as byte;
        parser.current = Token {
            kind: TOKEN_STRING,
            text: arena_copy_cstr(&parser.ctx.arena, &decoded[0] as &byte),
            span: new_source_span(start_line,
                                  start_column,
                                  start_offset,
                                  parser.line,
                                  parser.column,
                                  usize_to_i32_checked(parser.pos)),
        };
        return 0;
    }

    if (ch >= 65 as byte && ch <= 90 as byte) ||
        (ch >= 97 as byte && ch <= 122 as byte) ||
        ch == 95 as byte {
        const ident_start: usize = parser.pos;
        while true {
            const c: byte = parser_current_byte(parser);
            if (c >= 65 as byte && c <= 90 as byte) ||
                (c >= 97 as byte && c <= 122 as byte) ||
                (c >= 48 as byte && c <= 57 as byte) ||
                c == 95 as byte {
                _ = parser_advance_char(parser);
                continue;
            }
            break;
        }
        const ident_len: usize = parser.pos - ident_start;
        const ident_text: &byte = arena_copy_range(&parser.ctx.arena, parser.source, ident_start, ident_len);
        var kind: i32 = TOKEN_IDENT;
        if string_equals(ident_text, "true" as &byte) != 0 {
            kind = TOKEN_TRUE;
        } else if string_equals(ident_text, "false" as &byte) != 0 {
            kind = TOKEN_FALSE;
        }
        parser.current = Token {
            kind: kind,
            text: ident_text,
            span: new_source_span(start_line,
                                  start_column,
                                  start_offset,
                                  parser.line,
                                  parser.column,
                                  parser.pos as i32),
        };
        return 0;
    }

    return phase1_error(parser.ctx,
                        "UYABUILD_E_PARSE_CHAR" as &byte,
                        "unexpected character in uya.build" as &byte,
                        "expected a declaration, field, or expression token" as &byte,
                        source_display_path(parser.ctx, parser.file),
                        start_line,
                        start_column);
}

fn token_is_ident_text(token: &Token, text: &byte) i32 {
    if token == null || token.kind != TOKEN_IDENT {
        return 0;
    }
    return string_equals(token.text, text);
}

fn parser_expect(parser: &BuildParser, kind: i32, code: &byte, message: &byte, detail: &byte) i32 {
    if parser.current.kind != kind {
        return phase1_error(parser.ctx,
                            code,
                            message,
                            detail,
                            source_display_path(parser.ctx, parser.file),
                            parser.current.span.start.line,
                            parser.current.span.start.column);
    }
    return 0;
}

fn parser_parse_dotted_name(parser: &BuildParser, out_name: &byte) i32 {
    if parser_expect(parser,
                     TOKEN_IDENT,
                     "UYABUILD_E_PARSE_IDENT" as &byte,
                     "expected an identifier" as &byte,
                     "declarations and fields begin with identifiers" as &byte) != 0 {
        return -1;
    }

    var buf: [byte: MAX_STRING_BUILD] = [];
    var out_pos: usize = 0usize;
    var token: Token = parser.current;
    while true {
        const segment_len: usize = strlen(token.text);
        if out_pos != 0 {
            if out_pos + 1 >= MAX_STRING_BUILD {
                return phase1_error(parser.ctx,
                                    "UYABUILD_E_PARSE_IDENT" as &byte,
                                    "identifier is too long" as &byte,
                                    "reduce the dotted identifier length" as &byte,
                                    source_display_path(parser.ctx, parser.file),
                                    token.span.start.line,
                                    token.span.start.column);
            }
            buf[out_pos] = 46 as byte;
            out_pos = out_pos + 1;
        }
        if out_pos + segment_len + 1 >= MAX_STRING_BUILD {
            return phase1_error(parser.ctx,
                                "UYABUILD_E_PARSE_IDENT" as &byte,
                                "identifier is too long" as &byte,
                                "reduce the dotted identifier length" as &byte,
                                source_display_path(parser.ctx, parser.file),
                                token.span.start.line,
                                token.span.start.column);
        }
        memcpy(&buf[out_pos] as &byte, token.text, segment_len);
        out_pos = out_pos + segment_len;
        buf[out_pos] = 0 as byte;
        if parser_next_token(parser) != 0 {
            return -1;
        }
        if parser.current.kind != TOKEN_DOT {
            break;
        }
        if parser_next_token(parser) != 0 {
            return -1;
        }
        if parser_expect(parser,
                         TOKEN_IDENT,
                         "UYABUILD_E_PARSE_IDENT" as &byte,
                         "expected an identifier after '.'" as &byte,
                         "dotted identifiers must use segment.segment syntax" as &byte) != 0 {
            return -1;
        }
        token = parser.current;
    }

    const result: &byte = arena_copy_cstr(&parser.ctx.arena, &buf[0] as &byte);
    if result == null {
        return phase1_error(parser.ctx,
                            "UYABUILD_E_MEMORY" as &byte,
                            "phase1 arena is exhausted" as &byte,
                            "increase PHASE1_ARENA_SIZE to parse larger workspaces" as &byte,
                            source_display_path(parser.ctx, parser.file),
                            parser.current.span.start.line,
                            parser.current.span.start.column);
    }
    if copy_string(out_name, MAX_STRING_BUILD, result) != 0 {
        return -1;
    }
    return 0;
}

fn parser_value_from_literal(ctx: &Phase1Context, kind: i32, span: SourceSpan, text: &byte, bool_value: i32) &AstValue {
    const value: &AstValue = new_ast_value(ctx);
    if value == null {
        return null;
    }
    value.kind = kind;
    value.span = span;
    value.text = text;
    value.bool_value = bool_value;
    return value;
}

fn parser_parse_expr(parser: &BuildParser) &AstValue {
    const start_span: SourceSpan = parser.current.span;

    if parser.current.kind == TOKEN_STRING {
        const value: &AstValue = parser_value_from_literal(parser.ctx,
                                                           AST_VALUE_STRING,
                                                           parser.current.span,
                                                           parser.current.text,
                                                           0);
        if parser_next_token(parser) != 0 {
            return null;
        }
        return value;
    }
    if parser.current.kind == TOKEN_TRUE || parser.current.kind == TOKEN_FALSE {
        const bool_value: i32 = parser.current.kind == TOKEN_TRUE;
        const value: &AstValue = parser_value_from_literal(parser.ctx,
                                                           AST_VALUE_BOOL,
                                                           parser.current.span,
                                                           null,
                                                           bool_value);
        if parser_next_token(parser) != 0 {
            return null;
        }
        return value;
    }
    if parser.current.kind == TOKEN_LBRACKET {
        const list_value: &AstValue = new_ast_value(parser.ctx);
        if list_value == null {
            return null;
        }
        list_value.kind = AST_VALUE_LIST;
        list_value.span = clone_span(&start_span);
        if parser_next_token(parser) != 0 {
            return null;
        }
        if parser.current.kind != TOKEN_RBRACKET {
            while true {
                const item_value: &AstValue = parser_parse_expr(parser);
                if item_value == null {
                    return null;
                }
                const item: &AstValueItem = new_ast_value_item(parser.ctx);
                if item == null {
                    return null;
                }
                item.value = item_value;
                append_ast_list_item(list_value, item);
                if parser.current.kind == TOKEN_COMMA {
                    if parser_next_token(parser) != 0 {
                        return null;
                    }
                    if parser.current.kind == TOKEN_RBRACKET {
                        break;
                    }
                    continue;
                }
                break;
            }
        }
        if parser_expect(parser,
                         TOKEN_RBRACKET,
                         "UYABUILD_E_PARSE_LIST" as &byte,
                         "expected ']'" as &byte,
                         "list literals use [item, item] syntax" as &byte) != 0 {
            return null;
        }
        list_value.span.end = parser.current.span.end;
        if parser_next_token(parser) != 0 {
            return null;
        }
        return list_value;
    }
    if parser.current.kind == TOKEN_LBRACE {
        const map_value: &AstValue = new_ast_value(parser.ctx);
        if map_value == null {
            return null;
        }
        map_value.kind = AST_VALUE_MAP;
        map_value.span = clone_span(&start_span);
        if parser_next_token(parser) != 0 {
            return null;
        }
        if parser.current.kind != TOKEN_RBRACE {
            while true {
                if parser.current.kind != TOKEN_IDENT && parser.current.kind != TOKEN_STRING {
                    phase1_error(parser.ctx,
                                 "UYABUILD_E_PARSE_MAP" as &byte,
                                 "expected a key inside map literal" as &byte,
                                 "map keys must be identifiers or strings" as &byte,
                                 source_display_path(parser.ctx, parser.file),
                                 parser.current.span.start.line,
                                 parser.current.span.start.column);
                    return null;
                }
                const key_text: &byte = parser.current.text;
                const key_span: SourceSpan = clone_span(&parser.current.span);
                if parser_next_token(parser) != 0 {
                    return null;
                }
                if parser_expect(parser,
                                 TOKEN_EQUAL,
                                 "UYABUILD_E_PARSE_MAP" as &byte,
                                 "expected '=' after map key" as &byte,
                                 "map literals use { key = value } syntax" as &byte) != 0 {
                    return null;
                }
                if parser_next_token(parser) != 0 {
                    return null;
                }
                const entry_value: &AstValue = parser_parse_expr(parser);
                if entry_value == null {
                    return null;
                }
                const entry: &AstMapEntry = new_ast_map_entry(parser.ctx);
                if entry == null {
                    return null;
                }
                entry.key = key_text;
                entry.value = entry_value;
                entry.span = clone_span(&key_span);
                append_ast_map_entry(map_value, entry);
                if parser.current.kind == TOKEN_COMMA {
                    if parser_next_token(parser) != 0 {
                        return null;
                    }
                    if parser.current.kind == TOKEN_RBRACE {
                        break;
                    }
                    continue;
                }
                break;
            }
        }
        if parser_expect(parser,
                         TOKEN_RBRACE,
                         "UYABUILD_E_PARSE_MAP" as &byte,
                         "expected '}'" as &byte,
                         "map literals must close with '}'" as &byte) != 0 {
            return null;
        }
        map_value.span.end = parser.current.span.end;
        if parser_next_token(parser) != 0 {
            return null;
        }
        return map_value;
    }
    if parser.current.kind == TOKEN_IDENT {
        var name_buf: [byte: MAX_STRING_BUILD] = [];
        const span_start: SourceSpan = parser.current.span;
        if parser_parse_dotted_name(parser, &name_buf[0] as &byte) != 0 {
            return null;
        }
        const name_text: &byte = arena_copy_cstr(&parser.ctx.arena, &name_buf[0] as &byte);
        if parser.current.kind != TOKEN_LPAREN {
            return parser_value_from_literal(parser.ctx,
                                             AST_VALUE_IDENT,
                                             span_start,
                                             name_text,
                                             0);
        }
        const call_value: &AstValue = new_ast_value(parser.ctx);
        if call_value == null {
            return null;
        }
        call_value.kind = AST_VALUE_CALL;
        call_value.text = name_text;
        call_value.span = span_start;
        if parser_next_token(parser) != 0 {
            return null;
        }
        if parser.current.kind != TOKEN_RPAREN {
            while true {
                const arg_value: &AstValue = parser_parse_expr(parser);
                if arg_value == null {
                    return null;
                }
                const arg: &AstValueItem = new_ast_value_item(parser.ctx);
                if arg == null {
                    return null;
                }
                arg.value = arg_value;
                append_ast_call_arg(call_value, arg);
                if parser.current.kind == TOKEN_COMMA {
                    if parser_next_token(parser) != 0 {
                        return null;
                    }
                    if parser.current.kind == TOKEN_RPAREN {
                        break;
                    }
                    continue;
                }
                break;
            }
        }
        if parser_expect(parser,
                         TOKEN_RPAREN,
                         "UYABUILD_E_PARSE_CALL" as &byte,
                         "expected ')'" as &byte,
                         "function calls must close with ')'" as &byte) != 0 {
            return null;
        }
        call_value.span.end = parser.current.span.end;
        if parser_next_token(parser) != 0 {
            return null;
        }
        return call_value;
    }

    phase1_error(parser.ctx,
                 "UYABUILD_E_PARSE_EXPR" as &byte,
                 "expected an expression" as &byte,
                 "supported literals are strings, booleans, lists, maps, identifiers, and calls" as &byte,
                 source_display_path(parser.ctx, parser.file),
                 parser.current.span.start.line,
                 parser.current.span.start.column);
    return null;
}

fn parser_parse_field_block(parser: &BuildParser, decl: &AstDecl) i32 {
    if parser_expect(parser,
                     TOKEN_LBRACE,
                     "UYABUILD_E_PARSE_BLOCK" as &byte,
                     "expected '{'" as &byte,
                     "declarations use block syntax with curly braces" as &byte) != 0 {
        return -1;
    }
    if parser_next_token(parser) != 0 {
        return -1;
    }

    while parser.current.kind != TOKEN_RBRACE {
        if parser.current.kind == TOKEN_EOF {
            return phase1_error(parser.ctx,
                                "UYABUILD_E_PARSE_BLOCK" as &byte,
                                "unterminated block" as &byte,
                                "expected '}' before end of file" as &byte,
                                source_display_path(parser.ctx, parser.file),
                                decl.span.start.line,
                                decl.span.start.column);
        }
        if parser.current.kind != TOKEN_IDENT {
            return phase1_error(parser.ctx,
                                "UYABUILD_E_PARSE_FIELD" as &byte,
                                "expected a field name" as &byte,
                                "blocks may only contain field assignments" as &byte,
                                source_display_path(parser.ctx, parser.file),
                                parser.current.span.start.line,
                                parser.current.span.start.column);
        }
        const field_name: &byte = parser.current.text;
        const field_span: SourceSpan = parser.current.span;
        if parser_next_token(parser) != 0 {
            return -1;
        }
        if parser_expect(parser,
                         TOKEN_EQUAL,
                         "UYABUILD_E_PARSE_FIELD" as &byte,
                         "expected '=' after field name" as &byte,
                         "fields use name = value syntax" as &byte) != 0 {
            return -1;
        }
        if parser_next_token(parser) != 0 {
            return -1;
        }
        const field_value: &AstValue = parser_parse_expr(parser);
        if field_value == null {
            return -1;
        }
        const field: &AstField = new_ast_field(parser.ctx);
        if field == null {
            return phase1_error(parser.ctx,
                                "UYABUILD_E_MEMORY" as &byte,
                                "phase1 arena is exhausted" as &byte,
                                "increase PHASE1_ARENA_SIZE to parse larger workspaces" as &byte,
                                source_display_path(parser.ctx, parser.file),
                                field_span.start.line,
                                field_span.start.column);
        }
        field.name = field_name;
        field.value = field_value;
        field.span = clone_span(&field_span);
        append_ast_field(decl, field);
    }

    decl.span.end = parser.current.span.end;
    return parser_next_token(parser);
}

fn parser_parse_file(ctx: &Phase1Context, file: &SourceFile) i32 {
    var parser: BuildParser = BuildParser {
        ctx: null,
        file: null,
        source: null,
        size: 0usize,
        pos: 0usize,
        line: 1,
        column: 1,
        current: Token { kind: TOKEN_EOF, text: null, span: zero_span() },
    };
    parser_init(&parser, ctx, file);
    if parser_next_token(&parser) != 0 {
        return -1;
    }

    while parser.current.kind != TOKEN_EOF {
        if parser.current.kind != TOKEN_IDENT {
            return phase1_error(ctx,
                                "UYABUILD_E_PARSE_DECL" as &byte,
                                "expected a top-level declaration" as &byte,
                                "top-level statements must start with workspace, config, use, include, or a rule kind" as &byte,
                                source_display_path(ctx, file),
                                parser.current.span.start.line,
                                parser.current.span.start.column);
        }

        var dotted_name: [byte: MAX_STRING_BUILD] = [];
        const decl_span_start: SourceSpan = clone_span(&parser.current.span);
        if parser_parse_dotted_name(&parser, &dotted_name[0] as &byte) != 0 {
            return -1;
        }
        const decl_name: &byte = arena_copy_cstr(&ctx.arena, &dotted_name[0] as &byte);
        const decl: &AstDecl = new_ast_decl(ctx);
        if decl == null {
            return phase1_error(ctx,
                                "UYABUILD_E_MEMORY" as &byte,
                                "phase1 arena is exhausted" as &byte,
                                "increase PHASE1_ARENA_SIZE to parse larger workspaces" as &byte,
                                source_display_path(ctx, file),
                                decl_span_start.start.line,
                                decl_span_start.start.column);
        }
        decl.file = file;
        decl.span = clone_span(&decl_span_start);
        decl.name = decl_name;
        decl.label_text = null;

        if string_equals(decl_name, "workspace" as &byte) != 0 {
            decl.kind = AST_DECL_WORKSPACE;
            if parser_parse_field_block(&parser, decl) != 0 {
                return -1;
            }
            append_ast_decl(file, decl);
            continue;
        }
        if string_equals(decl_name, "config" as &byte) != 0 {
            decl.kind = AST_DECL_CONFIG;
            if parser_expect(&parser,
                             TOKEN_STRING,
                             "UYABUILD_E_PARSE_CONFIG" as &byte,
                             "expected config name string" as &byte,
                             "config declarations use config \"name\" { ... } syntax" as &byte) != 0 {
                return -1;
            }
            decl.label_text = parser.current.text;
            if parser_next_token(&parser) != 0 {
                return -1;
            }
            if parser_parse_field_block(&parser, decl) != 0 {
                return -1;
            }
            append_ast_decl(file, decl);
            continue;
        }
        if string_equals(decl_name, "use" as &byte) != 0 {
            decl.kind = AST_DECL_USE;
            if parser_expect(&parser,
                             TOKEN_IDENT,
                             "UYABUILD_E_PARSE_USE" as &byte,
                             "expected rule pack name after use" as &byte,
                             "use declarations name a rule pack such as cxx or node" as &byte) != 0 {
                return -1;
            }
            var use_name_buf: [byte: MAX_STRING_BUILD] = [];
            if parser_parse_dotted_name(&parser, &use_name_buf[0] as &byte) != 0 {
                return -1;
            }
            decl.label_text = arena_copy_cstr(&ctx.arena, &use_name_buf[0] as &byte);
            decl.span.end = decl_span_start.end;
            append_ast_decl(file, decl);
            continue;
        }
        if string_equals(decl_name, "include" as &byte) != 0 {
            decl.kind = AST_DECL_INCLUDE;
            if parser_expect(&parser,
                             TOKEN_STRING,
                             "UYABUILD_E_PARSE_INCLUDE" as &byte,
                             "expected include pattern string" as &byte,
                             "include declarations use include \"path/uya.build\" syntax" as &byte) != 0 {
                return -1;
            }
            decl.label_text = parser.current.text;
            decl.span.end = parser.current.span.end;
            if parser_next_token(&parser) != 0 {
                return -1;
            }
            append_ast_decl(file, decl);
            continue;
        }

        decl.kind = AST_DECL_TARGET;
        if parser_expect(&parser,
                         TOKEN_STRING,
                         "UYABUILD_E_PARSE_TARGET" as &byte,
                         "expected target label string" as &byte,
                         "target declarations use rule.kind \"//pkg:name\" { ... } syntax" as &byte) != 0 {
            return -1;
        }
        decl.label_text = parser.current.text;
        if parser_next_token(&parser) != 0 {
            return -1;
        }
        if parser_parse_field_block(&parser, decl) != 0 {
            return -1;
        }
        append_ast_decl(file, decl);
    }

    return 0;
}

fn new_pattern_segment(ctx: &Phase1Context) &PatternSegment {
    const mem: &byte = arena_alloc_zero(&ctx.arena, @size_of(PatternSegment));
    if mem == null {
        return null;
    }
    return mem as &PatternSegment;
}

fn wildcard_match(name: &byte, pattern: &byte) i32 {
    if name == null || pattern == null {
        return 0;
    }
    var ni: usize = 0usize;
    var pi: usize = 0usize;
    var star_pi: i32 = -1;
    var star_ni: usize = 0usize;

    while name[ni] != 0 as byte {
        if pattern[pi] == name[ni] || pattern[pi] == 63 as byte {
            ni = ni + 1;
            pi = pi + 1;
            continue;
        }
        if pattern[pi] == 42 as byte {
            star_pi = usize_to_i32_checked(pi);
            pi = pi + 1;
            star_ni = ni;
            continue;
        }
        if star_pi >= 0 {
            pi = (star_pi as usize) + 1usize;
            star_ni = star_ni + 1usize;
            ni = star_ni;
            continue;
        }
        return 0;
    }

    while pattern[pi] == 42 as byte {
        pi = pi + 1usize;
    }
    if pattern[pi] == 0 as byte {
        return 1;
    }
    return 0;
}

fn parse_pattern_segments(ctx: &Phase1Context, pattern: &byte) &PatternSegment {
    if pattern == null {
        return null;
    }
    var start: usize = 0usize;
    var head: &PatternSegment = null;
    var tail: &PatternSegment = null;

    while true {
        while pattern[start] == 47 as byte {
            start = start + 1usize;
        }
        if pattern[start] == 0 as byte {
            break;
        }
        var end: usize = start;
        while pattern[end] != 0 as byte && pattern[end] != 47 as byte {
            end = end + 1usize;
        }
        const segment: &PatternSegment = new_pattern_segment(ctx);
        if segment == null {
            return head;
        }
        segment.text = arena_copy_range(&ctx.arena, pattern, start, end - start);
        if head == null {
            head = segment;
            tail = segment;
        } else {
            tail.next = segment;
            tail = segment;
        }
        start = end;
    }

    return head;
}

fn glob_collect_recursive(ctx: &Phase1Context,
                          base_abs: &byte,
                          current_rel: &byte,
                          segment: &PatternSegment,
                          results: &StringNode,
                          matched_count: &i32) &StringNode {
    var current_abs: [byte: PATH_MAX] = [];
    var results_mut: &StringNode = results;
    if current_rel == null || string_equals(current_rel, "" as &byte) != 0 {
        if copy_string(&current_abs[0] as &byte, PATH_MAX, base_abs) != 0 {
            return results_mut;
        }
    } else if join_and_normalize_path(base_abs, current_rel, &current_abs[0] as &byte, PATH_MAX) != 0 {
        return results_mut;
    }

    if segment == null {
        if path_is_file(&current_abs[0] as &byte) != 0 {
            var inserted: i32 = 0;
            results_mut = sorted_string_insert(ctx, results_mut, current_rel, &inserted);
            if inserted != 0 {
                matched_count[0] = matched_count[0] + 1;
            }
        }
        return results_mut;
    }

    if string_equals(segment.text, "**" as &byte) != 0 {
        results_mut = glob_collect_recursive(ctx, base_abs, current_rel, segment.next, results_mut, matched_count);
        const dir_zero: &DIR = opendir(&current_abs[0] as &const byte);
        if dir_zero == null {
            return results_mut;
        }
        var entry_zero: &Dirent = readdir(dir_zero);
        while entry_zero != null {
            if is_dirent_dot(&entry_zero.d_name[0] as &byte) == 0 {
                var next_rel: [byte: PATH_MAX] = [];
                var next_abs: [byte: PATH_MAX] = [];
                if string_equals(current_rel, "" as &byte) != 0 {
                    if copy_string(&next_rel[0] as &byte, PATH_MAX, &entry_zero.d_name[0] as &byte) == 0 &&
                        join_and_normalize_path(base_abs,
                                                &next_rel[0] as &byte,
                                                &next_abs[0] as &byte,
                                                PATH_MAX) == 0 &&
                        dirent_is_directory(entry_zero, &next_abs[0] as &byte) != 0 {
                        results_mut = glob_collect_recursive(ctx,
                                                             base_abs,
                                                             &next_rel[0] as &byte,
                                                             segment,
                                                             results_mut,
                                                             matched_count);
                    }
                } else if join_path(current_rel,
                                    &entry_zero.d_name[0] as &byte,
                                    &next_rel[0] as &byte,
                                    PATH_MAX) == 0 &&
                    join_and_normalize_path(base_abs,
                                            &next_rel[0] as &byte,
                                            &next_abs[0] as &byte,
                                            PATH_MAX) == 0 &&
                    dirent_is_directory(entry_zero, &next_abs[0] as &byte) != 0 {
                    results_mut = glob_collect_recursive(ctx,
                                                         base_abs,
                                                         &next_rel[0] as &byte,
                                                         segment,
                                                         results_mut,
                                                         matched_count);
                }
            }
            entry_zero = readdir(dir_zero);
        }
        _ = closedir(dir_zero);
        return results_mut;
    }

    const dir: &DIR = opendir(&current_abs[0] as &const byte);
    if dir == null {
        return results_mut;
    }

    var entry: &Dirent = readdir(dir);
    while entry != null {
        const entry_name: &byte = &entry.d_name[0] as &byte;
        if is_dirent_dot(entry_name) == 0 && wildcard_match(entry_name, segment.text) != 0 {
            var next_rel: [byte: PATH_MAX] = [];
            var next_abs: [byte: PATH_MAX] = [];
            if string_equals(current_rel, "" as &byte) != 0 {
                if copy_string(&next_rel[0] as &byte, PATH_MAX, entry_name) != 0 {
                    entry = readdir(dir);
                    continue;
                }
            } else if join_path(current_rel, entry_name, &next_rel[0] as &byte, PATH_MAX) != 0 {
                entry = readdir(dir);
                continue;
            }
            if join_and_normalize_path(base_abs, &next_rel[0] as &byte, &next_abs[0] as &byte, PATH_MAX) != 0 {
                entry = readdir(dir);
                continue;
            }

            if segment.next == null {
                if dirent_is_regular_file(entry, &next_abs[0] as &byte) != 0 {
                    var inserted: i32 = 0;
                    results_mut = sorted_string_insert(ctx, results_mut, &next_rel[0] as &byte, &inserted);
                    if inserted != 0 {
                        matched_count[0] = matched_count[0] + 1;
                    }
                }
            } else if dirent_is_directory(entry, &next_abs[0] as &byte) != 0 {
                results_mut = glob_collect_recursive(ctx,
                                                     base_abs,
                                                     &next_rel[0] as &byte,
                                                     segment.next,
                                                     results_mut,
                                                     matched_count);
            }
        }
        entry = readdir(dir);
    }

    _ = closedir(dir);
    return results_mut;
}

fn collect_glob_matches(ctx: &Phase1Context,
                        base_abs: &byte,
                        pattern: &byte,
                        matched_count: &i32) &StringNode {
    const segments: &PatternSegment = parse_pattern_segments(ctx, pattern);
    matched_count[0] = 0;
    return glob_collect_recursive(ctx, base_abs, "" as &byte, segments, null, matched_count);
}

fn load_build_file(ctx: &Phase1Context, abs_path: &byte, is_root: i32) i32 {
    var normalized: [byte: PATH_MAX] = [];
    if normalize_path_text(abs_path, &normalized[0] as &byte, PATH_MAX) != 0 {
        return phase1_error(ctx,
                            "UYABUILD_E_PATH" as &byte,
                            "failed to normalize build file path" as &byte,
                            abs_path,
                            source_display_path(ctx, null),
                            0,
                            0);
    }
    if find_source_file(ctx, &normalized[0] as &byte) != null {
        return 0;
    }
    if path_is_file(&normalized[0] as &byte) == 0 {
        return phase1_error(ctx,
                            "UYABUILD_E_LOAD_FILE" as &byte,
                            "uya.build include target does not exist" as &byte,
                            &normalized[0] as &byte,
                            "" as &byte,
                            0,
                            0);
    }

    const file: &SourceFile = new_source_file(ctx);
    if file == null {
        return phase1_error(ctx,
                            "UYABUILD_E_MEMORY" as &byte,
                            "phase1 arena is exhausted" as &byte,
                            "increase PHASE1_ARENA_SIZE to parse larger workspaces" as &byte,
                            "" as &byte,
                            0,
                            0);
    }
    file.abs_path = arena_copy_cstr(&ctx.arena, &normalized[0] as &byte);
    file.is_root = is_root;

    var rel_buf: [byte: PATH_MAX] = [];
    if path_relative_to_root(ctx.workspace_root,
                             &normalized[0] as &byte,
                             &rel_buf[0] as &byte,
                             PATH_MAX) != 0 {
        return phase1_error(ctx,
                            "UYABUILD_E_PATH" as &byte,
                            "failed to derive relative build file path" as &byte,
                            &normalized[0] as &byte,
                            "" as &byte,
                            0,
                            0);
    }
    file.rel_path = arena_copy_cstr(&ctx.arena, &rel_buf[0] as &byte);

    var dir_buf: [byte: PATH_MAX] = [];
    if path_dirname_text(&normalized[0] as &byte, &dir_buf[0] as &byte, PATH_MAX) != 0 {
        return phase1_error(ctx,
                            "UYABUILD_E_PATH" as &byte,
                            "failed to compute build file directory" as &byte,
                            &normalized[0] as &byte,
                            "" as &byte,
                            0,
                            0);
    }
    file.dir_abs = arena_copy_cstr(&ctx.arena, &dir_buf[0] as &byte);

    var package_buf: [byte: PATH_MAX] = [];
    if package_from_rel_path(&rel_buf[0] as &byte, &package_buf[0] as &byte, PATH_MAX) != 0 {
        return phase1_error(ctx,
                            "UYABUILD_E_PATH" as &byte,
                            "failed to derive package path from uya.build" as &byte,
                            &rel_buf[0] as &byte,
                            "" as &byte,
                            0,
                            0);
    }
    file.package_path = arena_copy_cstr(&ctx.arena, &package_buf[0] as &byte);

    var file_size: usize = 0usize;
    file.content = read_file_into_arena(ctx, &normalized[0] as &byte, &file_size);
    if file.content == null {
        return phase1_error(ctx,
                            "UYABUILD_E_LOAD_FILE" as &byte,
                            "failed to read uya.build file" as &byte,
                            &normalized[0] as &byte,
                            file.rel_path,
                            0,
                            0);
    }
    file.size = file_size;

    append_source_file(ctx, file);
    if parser_parse_file(ctx, file) != 0 {
        return -1;
    }

    var decl: &AstDecl = file.decl_head;
    while decl != null {
        if decl.kind == AST_DECL_INCLUDE {
            var matched_count: i32 = 0;
            var matches: &StringNode = collect_glob_matches(ctx, file.dir_abs, decl.label_text, &matched_count);
            if matched_count == 0 {
                return phase1_error(ctx,
                                    "UYABUILD_E_INCLUDE_EMPTY" as &byte,
                                    "include pattern did not match any uya.build files" as &byte,
                                    decl.label_text,
                                    file.rel_path,
                                    decl.span.start.line,
                                    decl.span.start.column);
            }
            var node: &StringNode = matches;
            while node != null {
                var include_abs: [byte: PATH_MAX] = [];
                if join_and_normalize_path(file.dir_abs,
                                           node.text,
                                           &include_abs[0] as &byte,
                                           PATH_MAX) != 0 {
                    return phase1_error(ctx,
                                        "UYABUILD_E_INCLUDE_PATH" as &byte,
                                        "failed to resolve include path" as &byte,
                                        node.text,
                                        file.rel_path,
                                        decl.span.start.line,
                                        decl.span.start.column);
                }
                if load_build_file(ctx, &include_abs[0] as &byte, 0) != 0 {
                    return -1;
                }
                node = node.next;
            }
        }
        decl = decl.next;
    }

    return 0;
}

fn load_workspace_files(ctx: &Phase1Context) i32 {
    var root_build: [byte: PATH_MAX] = [];
    if join_path(ctx.workspace_root,
                 "uya.build" as &byte,
                 &root_build[0] as &byte,
                 PATH_MAX) != 0 {
        return phase1_error(ctx,
                            "UYABUILD_E_PATH" as &byte,
                            "failed to construct root uya.build path" as &byte,
                            ctx.workspace_root,
                            "" as &byte,
                            0,
                            0);
    }
    if path_is_file(&root_build[0] as &byte) == 0 {
        return phase1_error(ctx,
                            "UYABUILD_E_ROOT_BUILD" as &byte,
                            "root workspace is missing uya.build" as &byte,
                            "Phase 1 requires uya.build as the authoritative build graph entrypoint" as &byte,
                            "" as &byte,
                            0,
                            0);
    }
    ctx.root_build_path = arena_copy_cstr(&ctx.arena, &root_build[0] as &byte);

    var root_toml: [byte: PATH_MAX] = [];
    if join_path(ctx.workspace_root,
                 "uya.toml" as &byte,
                 &root_toml[0] as &byte,
                 PATH_MAX) == 0 &&
        path_is_file(&root_toml[0] as &byte) != 0 {
        ctx.root_toml_path = arena_copy_cstr(&ctx.arena, &root_toml[0] as &byte);
    }

    return load_build_file(ctx, ctx.root_build_path, 1);
}

fn typed_make_string(ctx: &Phase1Context, span: SourceSpan, text: &byte) &TypedValue {
    const value: &TypedValue = new_typed_value(ctx);
    if value == null {
        return null;
    }
    value.kind = TYPED_VALUE_STRING;
    value.span = span;
    value.text = arena_copy_cstr(&ctx.arena, text);
    return value;
}

fn typed_make_label(ctx: &Phase1Context, span: SourceSpan, text: &byte) &TypedValue {
    const value: &TypedValue = new_typed_value(ctx);
    if value == null {
        return null;
    }
    value.kind = TYPED_VALUE_LABEL;
    value.span = span;
    value.text = arena_copy_cstr(&ctx.arena, text);
    return value;
}

fn typed_make_bool(ctx: &Phase1Context, span: SourceSpan, bool_value: i32) &TypedValue {
    const value: &TypedValue = new_typed_value(ctx);
    if value == null {
        return null;
    }
    value.kind = TYPED_VALUE_BOOL;
    value.span = span;
    value.bool_value = bool_value;
    return value;
}

fn typed_make_ident(ctx: &Phase1Context, span: SourceSpan, text: &byte) &TypedValue {
    const value: &TypedValue = new_typed_value(ctx);
    if value == null {
        return null;
    }
    value.kind = TYPED_VALUE_IDENT;
    value.span = span;
    value.text = arena_copy_cstr(&ctx.arena, text);
    return value;
}

fn typed_make_list(ctx: &Phase1Context, span: SourceSpan) &TypedValue {
    const value: &TypedValue = new_typed_value(ctx);
    if value == null {
        return null;
    }
    value.kind = TYPED_VALUE_LIST;
    value.span = span;
    return value;
}

fn typed_make_map(ctx: &Phase1Context, span: SourceSpan) &TypedValue {
    const value: &TypedValue = new_typed_value(ctx);
    if value == null {
        return null;
    }
    value.kind = TYPED_VALUE_MAP;
    value.span = span;
    return value;
}

fn typed_make_call(ctx: &Phase1Context, span: SourceSpan, name: &byte) &TypedValue {
    const value: &TypedValue = new_typed_value(ctx);
    if value == null {
        return null;
    }
    value.kind = TYPED_VALUE_CALL;
    value.span = span;
    value.call_name = arena_copy_cstr(&ctx.arena, name);
    return value;
}

fn typed_list_append_value(ctx: &Phase1Context, list_value: &TypedValue, child: &TypedValue) i32 {
    const item: &TypedValueItem = new_typed_value_item(ctx);
    if item == null {
        return -1;
    }
    item.value = child;
    append_typed_list_item(list_value, item);
    return 0;
}

fn typed_call_append_arg(ctx: &Phase1Context, call_value: &TypedValue, child: &TypedValue) i32 {
    const item: &TypedValueItem = new_typed_value_item(ctx);
    if item == null {
        return -1;
    }
    item.value = child;
    append_typed_call_arg(call_value, item);
    return 0;
}

fn typed_map_append_entry(ctx: &Phase1Context, map_value: &TypedValue, key: &byte, child: &TypedValue) i32 {
    const entry: &TypedMapEntry = new_typed_map_entry(ctx);
    if entry == null {
        return -1;
    }
    entry.key = arena_copy_cstr(&ctx.arena, key);
    entry.value = child;
    append_typed_map_entry(map_value, entry);
    return 0;
}

fn build_label_text(ctx: &Phase1Context, package_path: &byte, name: &byte) &byte {
    var buf: [byte: PATH_MAX] = [];
    if package_path == null || package_path[0] == 0 as byte {
        _ = snprintf(&buf[0] as *byte, PATH_MAX, "//:%s" as *byte, name as *byte);
    } else {
        _ = snprintf(&buf[0] as *byte, PATH_MAX, "//%s:%s" as *byte, package_path as *byte, name as *byte);
    }
    return arena_copy_cstr(&ctx.arena, &buf[0] as &byte);
}

fn rule_pack_for_kind(kind: &byte) &byte {
    if string_has_prefix(kind, "cxx." as &byte) != 0 {
        return "cxx" as &byte;
    }
    if string_has_prefix(kind, "node." as &byte) != 0 {
        return "node" as &byte;
    }
    if string_has_prefix(kind, "oci." as &byte) != 0 {
        return "oci" as &byte;
    }
    if string_has_prefix(kind, "legacy." as &byte) != 0 {
        return "legacy" as &byte;
    }
    if string_equals(kind, "task" as &byte) != 0 {
        return "" as &byte;
    }
    return null;
}

fn provider_mask_for_kind(kind: &byte) u32 {
    if string_equals(kind, "cxx.library" as &byte) != 0 {
        return PROVIDER_CXX_LINKABLE;
    }
    if string_equals(kind, "node.workspace" as &byte) != 0 {
        return PROVIDER_NODE_WORKSPACE;
    }
    if string_equals(kind, "node.app" as &byte) != 0 {
        return PROVIDER_NODE_APP;
    }
    if string_equals(kind, "oci.image" as &byte) != 0 {
        return PROVIDER_OCI_IMAGE;
    }
    if string_equals(kind, "legacy.shell" as &byte) != 0 {
        return PROVIDER_LEGACY_ACTION;
    }
    if string_equals(kind, "task" as &byte) != 0 {
        return PROVIDER_TASK;
    }
    return 0u32;
}

fn field_expected_type(kind: &byte, field_name: &byte) i32 {
    if string_equals(field_name, "deps" as &byte) != 0 {
        return EXPECT_LABEL_LIST;
    }
    if string_equals(field_name, "tags" as &byte) != 0 ||
        string_equals(field_name, "visibility" as &byte) != 0 {
        return EXPECT_STRING_LIST;
    }

    if string_equals(kind, "cxx.library" as &byte) != 0 {
        if string_equals(field_name, "srcs" as &byte) != 0 ||
            string_equals(field_name, "hdrs" as &byte) != 0 ||
            string_equals(field_name, "include_dirs" as &byte) != 0 {
            return EXPECT_STRING_LIST;
        }
        if string_equals(field_name, "discover" as &byte) != 0 {
            return EXPECT_CALL;
        }
        return -1;
    }
    if string_equals(kind, "cxx.binary" as &byte) != 0 {
        if string_equals(field_name, "srcs" as &byte) != 0 {
            return EXPECT_STRING_LIST;
        }
        if string_equals(field_name, "out" as &byte) != 0 ||
            string_equals(field_name, "toolchain" as &byte) != 0 {
            return EXPECT_STRING;
        }
        return -1;
    }
    if string_equals(kind, "node.workspace" as &byte) != 0 {
        if string_equals(field_name, "root" as &byte) != 0 ||
            string_equals(field_name, "lockfile" as &byte) != 0 {
            return EXPECT_STRING;
        }
        if string_equals(field_name, "workspaces" as &byte) != 0 {
            return EXPECT_BOOL;
        }
        return -1;
    }
    if string_equals(kind, "node.app" as &byte) != 0 {
        if string_equals(field_name, "workspace" as &byte) != 0 {
            return EXPECT_LABEL;
        }
        if string_equals(field_name, "package" as &byte) != 0 ||
            string_equals(field_name, "out" as &byte) != 0 {
            return EXPECT_STRING;
        }
        return -1;
    }
    if string_equals(kind, "oci.image" as &byte) != 0 {
        if string_equals(field_name, "dockerfile" as &byte) != 0 ||
            string_equals(field_name, "context" as &byte) != 0 {
            return EXPECT_STRING;
        }
        if string_equals(field_name, "tags" as &byte) != 0 {
            return EXPECT_STRING_LIST;
        }
        return -1;
    }
    if string_equals(kind, "legacy.shell" as &byte) != 0 {
        if string_equals(field_name, "script" as &byte) != 0 ||
            string_equals(field_name, "run" as &byte) != 0 ||
            string_equals(field_name, "inputs" as &byte) != 0 ||
            string_equals(field_name, "outputs" as &byte) != 0 ||
            string_equals(field_name, "env_allowlist" as &byte) != 0 {
            return EXPECT_STRING_LIST;
        }
        if string_equals(field_name, "mode" as &byte) != 0 {
            return EXPECT_STRING;
        }
        if string_equals(field_name, "always" as &byte) != 0 {
            return EXPECT_BOOL;
        }
        return -1;
    }
    if string_equals(kind, "task" as &byte) != 0 {
        if string_equals(field_name, "run" as &byte) != 0 {
            return EXPECT_STRING_LIST;
        }
        if string_equals(field_name, "always" as &byte) != 0 {
            return EXPECT_BOOL;
        }
        return -1;
    }
    return -1;
}

fn workspace_field_expected_type(field_name: &byte) i32 {
    if string_equals(field_name, "name" as &byte) != 0 {
        return EXPECT_STRING;
    }
    if string_equals(field_name, "default" as &byte) != 0 {
        return EXPECT_LABEL_LIST;
    }
    if string_equals(field_name, "strict" as &byte) != 0 {
        return EXPECT_BOOL;
    }
    return -1;
}

fn normalize_label(ctx: &Phase1Context,
                   base_package: &byte,
                   raw: &byte,
                   display_file: &byte,
                   line: i32,
                   column: i32) &byte {
    if raw == null || raw[0] == 0 as byte {
        phase1_error(ctx,
                     "UYABUILD_E_LABEL_SYNTAX" as &byte,
                     "empty label is not allowed" as &byte,
                     "labels must resolve to //pkg:name or :name" as &byte,
                     display_file,
                     line,
                     column);
        return null;
    }

    if string_has_prefix(raw, "//" as &byte) != 0 {
        var colon_index: i32 = -1;
        var i: usize = 2usize;
        while raw[i] != 0 as byte {
            if raw[i] == 58 as byte {
                colon_index = usize_to_i32_checked(i);
                break;
            }
            i = i + 1usize;
        }
        if colon_index < 2 {
            phase1_error(ctx,
                         "UYABUILD_E_LABEL_SYNTAX" as &byte,
                         "absolute label is missing ':'" as &byte,
                         raw,
                         display_file,
                         line,
                         column);
            return null;
        }
        const package_text: &byte = arena_copy_range(&ctx.arena, raw, 2usize, (colon_index as usize) - 2usize);
        const name_text: &byte = arena_copy_range(&ctx.arena,
                                                  raw,
                                                  (colon_index as usize) + 1usize,
                                                  strlen(raw) - ((colon_index as usize) + 1usize));
        if name_text == null || name_text[0] == 0 as byte {
            phase1_error(ctx,
                         "UYABUILD_E_LABEL_SYNTAX" as &byte,
                         "absolute label is missing target name" as &byte,
                         raw,
                         display_file,
                         line,
                         column);
            return null;
        }
        return build_label_text(ctx, package_text, name_text);
    }

    if raw[0] == 58 as byte {
        const name_text: &byte = arena_copy_range(&ctx.arena, raw, 1usize, strlen(raw) - 1usize);
        if name_text == null || name_text[0] == 0 as byte {
            phase1_error(ctx,
                         "UYABUILD_E_LABEL_SYNTAX" as &byte,
                         "relative label is missing target name" as &byte,
                         raw,
                         display_file,
                         line,
                         column);
            return null;
        }
        return build_label_text(ctx, base_package, name_text);
    }

    var colon_index_local: i32 = -1;
    var j: usize = 0usize;
    while raw[j] != 0 as byte {
        if raw[j] == 58 as byte {
                colon_index_local = usize_to_i32_checked(j);
            break;
        }
        j = j + 1usize;
    }

    if colon_index_local >= 0 {
        const rel_pkg: &byte = arena_copy_range(&ctx.arena, raw, 0usize, colon_index_local as usize);
        const rel_name: &byte = arena_copy_range(&ctx.arena,
                                                 raw,
                                                 (colon_index_local as usize) + 1usize,
                                                 strlen(raw) - ((colon_index_local as usize) + 1usize));
        if rel_name == null || rel_name[0] == 0 as byte {
            phase1_error(ctx,
                         "UYABUILD_E_LABEL_SYNTAX" as &byte,
                         "relative label is missing target name" as &byte,
                         raw,
                         display_file,
                         line,
                         column);
            return null;
        }
        if base_package == null || base_package[0] == 0 as byte {
            return build_label_text(ctx, rel_pkg, rel_name);
        }
        var package_buf: [byte: PATH_MAX] = [];
        if join_and_normalize_path(base_package, rel_pkg, &package_buf[0] as &byte, PATH_MAX) != 0 {
            phase1_error(ctx,
                         "UYABUILD_E_LABEL_SYNTAX" as &byte,
                         "failed to normalize relative package label" as &byte,
                         raw,
                         display_file,
                         line,
                         column);
            return null;
        }
        if string_equals(&package_buf[0] as &byte, "." as &byte) != 0 {
            return build_label_text(ctx, "" as &byte, rel_name);
        }
        return build_label_text(ctx, &package_buf[0] as &byte, rel_name);
    }

    return build_label_text(ctx, base_package, raw);
}

fn typed_value_equals(left: &TypedValue, right: &TypedValue) i32 {
    if left == null && right == null {
        return 1;
    }
    if left == null || right == null {
        return 0;
    }
    if left.kind != right.kind {
        return 0;
    }
    if left.kind == TYPED_VALUE_STRING ||
        left.kind == TYPED_VALUE_LABEL ||
        left.kind == TYPED_VALUE_IDENT {
        return string_equals(left.text, right.text);
    }
    if left.kind == TYPED_VALUE_BOOL {
        if left.bool_value == right.bool_value {
            return 1;
        }
        return 0;
    }
    if left.kind == TYPED_VALUE_LIST {
        var li: &TypedValueItem = left.list_head;
        var ri: &TypedValueItem = right.list_head;
        while li != null && ri != null {
            if typed_value_equals(li.value, ri.value) == 0 {
                return 0;
            }
            li = li.next;
            ri = ri.next;
        }
        if li != null || ri != null {
            return 0;
        }
        return 1;
    }
    return 0;
}

fn typed_merge_list(ctx: &Phase1Context, dst: &TypedValue, src: &TypedValue) i32 {
    if dst == null || src == null || dst.kind != TYPED_VALUE_LIST || src.kind != TYPED_VALUE_LIST {
        return -1;
    }
    var item: &TypedValueItem = src.list_head;
    while item != null {
        if typed_list_append_value(ctx, dst, item.value) != 0 {
            return -1;
        }
        item = item.next;
    }
    return 0;
}

fn analyze_select_call(ctx: &Phase1Context,
                       file: &SourceFile,
                       base_package: &byte,
                       base_dir: &byte,
                       ast: &AstValue,
                       expected: i32) &TypedValue {
    const call_value: &TypedValue = typed_make_call(ctx, ast.span, "select" as &byte);
    if call_value == null {
        return null;
    }
    var arg: &AstValueItem = ast.arg_head;
    while arg != null {
        var typed_arg: &TypedValue = null;
        if arg.value.kind == AST_VALUE_MAP {
            typed_arg = typed_make_map(ctx, arg.value.span);
            if typed_arg == null {
                return null;
            }
            var entry: &AstMapEntry = arg.value.map_head;
            while entry != null {
                const child: &TypedValue = analyze_value(ctx,
                                                         file,
                                                         base_package,
                                                         base_dir,
                                                         entry.value,
                                                         expected);
                if child == null {
                    return null;
                }
                if typed_map_append_entry(ctx, typed_arg, entry.key, child) != 0 {
                    return null;
                }
                entry = entry.next;
            }
        } else {
            typed_arg = analyze_value(ctx, file, base_package, base_dir, arg.value, EXPECT_ANY);
            if typed_arg == null {
                return null;
            }
        }
        if typed_call_append_arg(ctx, call_value, typed_arg) != 0 {
            return null;
        }
        arg = arg.next;
    }
    return call_value;
}

fn evaluate_glob_call(ctx: &Phase1Context,
                      file: &SourceFile,
                      base_dir: &byte,
                      ast: &AstValue) &TypedValue {
    const collected: &TypedValue = typed_make_list(ctx, ast.span);
    if collected == null {
        return null;
    }
    var seen: &StringNode = null;

    var arg: &AstValueItem = ast.arg_head;
    while arg != null {
        if arg.value.kind == AST_VALUE_STRING {
            var matched_count: i32 = 0;
            var matches: &StringNode = collect_glob_matches(ctx, base_dir, arg.value.text, &matched_count);
            var node: &StringNode = matches;
            while node != null {
                var inserted: i32 = 0;
                seen = sorted_string_insert(ctx, seen, node.text, &inserted);
                node = node.next;
            }
        } else if arg.value.kind == AST_VALUE_LIST {
            var item: &AstValueItem = arg.value.list_head;
            while item != null {
                if item.value.kind != AST_VALUE_STRING {
                    phase1_error(ctx,
                                 "UYABUILD_E_GLOB_ARG" as &byte,
                                 "glob() only accepts string patterns" as &byte,
                                 "use glob(\"path/**/*.cc\") or glob([\"a\", \"b\"])" as &byte,
                                 file.rel_path,
                                 item.value.span.start.line,
                                 item.value.span.start.column);
                    return null;
                }
                var matched_count_list: i32 = 0;
                var matches_list: &StringNode = collect_glob_matches(ctx, base_dir, item.value.text, &matched_count_list);
                var node_list: &StringNode = matches_list;
                while node_list != null {
                    var inserted_list: i32 = 0;
                    seen = sorted_string_insert(ctx, seen, node_list.text, &inserted_list);
                    node_list = node_list.next;
                }
                item = item.next;
            }
        } else {
            phase1_error(ctx,
                         "UYABUILD_E_GLOB_ARG" as &byte,
                         "glob() only accepts string patterns" as &byte,
                         "use glob(\"path/**/*.cc\") or glob([\"a\", \"b\"])" as &byte,
                         file.rel_path,
                         arg.value.span.start.line,
                         arg.value.span.start.column);
            return null;
        }
        arg = arg.next;
    }

    var node_out: &StringNode = seen;
    while node_out != null {
        const string_value: &TypedValue = typed_make_string(ctx, ast.span, node_out.text);
        if string_value == null {
            return null;
        }
        if typed_list_append_value(ctx, collected, string_value) != 0 {
            return null;
        }
        node_out = node_out.next;
    }

    return collected;
}

fn analyze_generic_call(ctx: &Phase1Context,
                        file: &SourceFile,
                        base_package: &byte,
                        base_dir: &byte,
                        ast: &AstValue) &TypedValue {
    if string_equals(ast.text, "glob" as &byte) != 0 {
        return evaluate_glob_call(ctx, file, base_dir, ast);
    }
    if string_equals(ast.text, "select" as &byte) != 0 {
        return analyze_select_call(ctx, file, base_package, base_dir, ast, EXPECT_ANY);
    }

    const call_value: &TypedValue = typed_make_call(ctx, ast.span, ast.text);
    if call_value == null {
        return null;
    }
    var arg: &AstValueItem = ast.arg_head;
    while arg != null {
        const child: &TypedValue = analyze_value(ctx, file, base_package, base_dir, arg.value, EXPECT_ANY);
        if child == null {
            return null;
        }
        if typed_call_append_arg(ctx, call_value, child) != 0 {
            return null;
        }
        arg = arg.next;
    }
    return call_value;
}

fn analyze_value(ctx: &Phase1Context,
                 file: &SourceFile,
                 base_package: &byte,
                 base_dir: &byte,
                 ast: &AstValue,
                 expected: i32) &TypedValue {
    if ast == null {
        return null;
    }

    if ast.kind == AST_VALUE_CALL && string_equals(ast.text, "select" as &byte) != 0 {
        return analyze_select_call(ctx, file, base_package, base_dir, ast, expected);
    }

    if expected == EXPECT_ANY {
        if ast.kind == AST_VALUE_STRING {
            return typed_make_string(ctx, ast.span, ast.text);
        }
        if ast.kind == AST_VALUE_BOOL {
            return typed_make_bool(ctx, ast.span, ast.bool_value);
        }
        if ast.kind == AST_VALUE_IDENT {
            return typed_make_ident(ctx, ast.span, ast.text);
        }
        if ast.kind == AST_VALUE_LIST {
            const list_value: &TypedValue = typed_make_list(ctx, ast.span);
            if list_value == null {
                return null;
            }
            var item: &AstValueItem = ast.list_head;
            while item != null {
                const child: &TypedValue = analyze_value(ctx, file, base_package, base_dir, item.value, EXPECT_ANY);
                if child == null {
                    return null;
                }
                if typed_list_append_value(ctx, list_value, child) != 0 {
                    return null;
                }
                item = item.next;
            }
            return list_value;
        }
        if ast.kind == AST_VALUE_MAP {
            const map_value: &TypedValue = typed_make_map(ctx, ast.span);
            if map_value == null {
                return null;
            }
            var entry: &AstMapEntry = ast.map_head;
            while entry != null {
                const child_map: &TypedValue = analyze_value(ctx, file, base_package, base_dir, entry.value, EXPECT_ANY);
                if child_map == null {
                    return null;
                }
                if typed_map_append_entry(ctx, map_value, entry.key, child_map) != 0 {
                    return null;
                }
                entry = entry.next;
            }
            return map_value;
        }
        if ast.kind == AST_VALUE_CALL {
            return analyze_generic_call(ctx, file, base_package, base_dir, ast);
        }
    }

    if expected == EXPECT_STRING {
        if ast.kind == AST_VALUE_STRING {
            return typed_make_string(ctx, ast.span, ast.text);
        }
        phase1_error(ctx,
                     "UYABUILD_E_SCHEMA_TYPE" as &byte,
                     "expected a string value" as &byte,
                     "this field only accepts string literals or select(...)" as &byte,
                     file.rel_path,
                     ast.span.start.line,
                     ast.span.start.column);
        return null;
    }
    if expected == EXPECT_BOOL {
        if ast.kind == AST_VALUE_BOOL {
            return typed_make_bool(ctx, ast.span, ast.bool_value);
        }
        phase1_error(ctx,
                     "UYABUILD_E_SCHEMA_TYPE" as &byte,
                     "expected a boolean value" as &byte,
                     "use true or false for this field" as &byte,
                     file.rel_path,
                     ast.span.start.line,
                     ast.span.start.column);
        return null;
    }
    if expected == EXPECT_CALL {
        if ast.kind == AST_VALUE_CALL {
            return analyze_generic_call(ctx, file, base_package, base_dir, ast);
        }
        phase1_error(ctx,
                     "UYABUILD_E_SCHEMA_TYPE" as &byte,
                     "expected a call expression" as &byte,
                     "this field expects a scanner-style call such as cpp.headers()" as &byte,
                     file.rel_path,
                     ast.span.start.line,
                     ast.span.start.column);
        return null;
    }
    if expected == EXPECT_LABEL {
        if ast.kind == AST_VALUE_STRING {
            const normalized: &byte = normalize_label(ctx,
                                                      base_package,
                                                      ast.text,
                                                      file.rel_path,
                                                      ast.span.start.line,
                                                      ast.span.start.column);
            if normalized == null {
                return null;
            }
            return typed_make_label(ctx, ast.span, normalized);
        }
        phase1_error(ctx,
                     "UYABUILD_E_SCHEMA_TYPE" as &byte,
                     "expected a label string" as &byte,
                     "labels use //pkg:name or :name syntax" as &byte,
                     file.rel_path,
                     ast.span.start.line,
                     ast.span.start.column);
        return null;
    }
    if expected == EXPECT_STRING_LIST || expected == EXPECT_LABEL_LIST {
        if ast.kind == AST_VALUE_CALL &&
            expected == EXPECT_STRING_LIST &&
            string_equals(ast.text, "glob" as &byte) != 0 {
            return evaluate_glob_call(ctx, file, base_dir, ast);
        }

        const list_value: &TypedValue = typed_make_list(ctx, ast.span);
        if list_value == null {
            return null;
        }

        if ast.kind == AST_VALUE_STRING || ast.kind == AST_VALUE_CALL {
            var single_expected: i32 = EXPECT_LABEL;
            if expected == EXPECT_STRING_LIST {
                single_expected = EXPECT_STRING;
            }
            const child_single: &TypedValue = analyze_value(ctx,
                                                            file,
                                                            base_package,
                                                            base_dir,
                                                            ast,
                                                            single_expected);
            if child_single == null {
                if ast.kind == AST_VALUE_CALL &&
                    expected == EXPECT_STRING_LIST &&
                    string_equals(ast.text, "glob" as &byte) != 0 {
                    return evaluate_glob_call(ctx, file, base_dir, ast);
                }
                return null;
            }
            if child_single.kind == TYPED_VALUE_LIST {
                if typed_merge_list(ctx, list_value, child_single) != 0 {
                    return null;
                }
            } else if typed_list_append_value(ctx, list_value, child_single) != 0 {
                return null;
            }
            return list_value;
        }

        if ast.kind != AST_VALUE_LIST {
            phase1_error(ctx,
                         "UYABUILD_E_SCHEMA_TYPE" as &byte,
                         "expected a list value" as &byte,
                         "use [item, item] syntax for list fields" as &byte,
                         file.rel_path,
                         ast.span.start.line,
                         ast.span.start.column);
            return null;
        }

        var item_list: &AstValueItem = ast.list_head;
        while item_list != null {
            var child_value: &TypedValue = null;
            var item_expected: i32 = EXPECT_LABEL;
            if expected == EXPECT_STRING_LIST {
                item_expected = EXPECT_STRING;
            }
            if expected == EXPECT_STRING_LIST &&
                item_list.value.kind == AST_VALUE_CALL &&
                string_equals(item_list.value.text, "glob" as &byte) != 0 {
                child_value = evaluate_glob_call(ctx, file, base_dir, item_list.value);
            } else {
                child_value = analyze_value(ctx,
                                            file,
                                            base_package,
                                            base_dir,
                                            item_list.value,
                                            item_expected);
            }
            if child_value == null {
                return null;
            }
            if child_value.kind == TYPED_VALUE_LIST {
                if typed_merge_list(ctx, list_value, child_value) != 0 {
                    return null;
                }
            } else if typed_list_append_value(ctx, list_value, child_value) != 0 {
                return null;
            }
            item_list = item_list.next;
        }
        return list_value;
    }

    phase1_error(ctx,
                 "UYABUILD_E_SCHEMA_TYPE" as &byte,
                 "unsupported schema expectation" as &byte,
                 "internal analyzer expectation mismatch" as &byte,
                 file.rel_path,
                 ast.span.start.line,
                 ast.span.start.column);
    return null;
}

fn record_rule_use(ctx: &Phase1Context, name: &byte) i32 {
    var current: &RuleUse = ctx.uses_head;
    while current != null {
        if string_equals(current.name, name) != 0 {
            return 0;
        }
        current = current.next;
    }
    const use_item: &RuleUse = new_rule_use(ctx);
    if use_item == null {
        return -1;
    }
    use_item.name = arena_copy_cstr(&ctx.arena, name);
    if ctx.uses_head == null {
        ctx.uses_head = use_item;
        ctx.uses_tail = use_item;
    } else {
        ctx.uses_tail.next = use_item;
        ctx.uses_tail = use_item;
    }
    ctx.use_count = ctx.use_count + 1;
    return 0;
}

fn has_rule_use(ctx: &Phase1Context, name: &byte) i32 {
    var current: &RuleUse = ctx.uses_head;
    while current != null {
        if string_equals(current.name, name) != 0 {
            return 1;
        }
        current = current.next;
    }
    return 0;
}

fn find_target_by_label(ctx: &Phase1Context, label: &byte) &IRTarget {
    var current: &IRTarget = ctx.targets_head;
    while current != null {
        if string_equals(current.label, label) != 0 {
            return current;
        }
        current = current.next;
    }
    return null;
}

fn insert_target_sorted(ctx: &Phase1Context, target: &IRTarget) void {
    if ctx.targets_head == null || cstr_compare(target.label, ctx.targets_head.label) < 0 {
        target.next = ctx.targets_head;
        ctx.targets_head = target;
        ctx.target_count = ctx.target_count + 1;
        return;
    }
    var current: &IRTarget = ctx.targets_head;
    while current.next != null && cstr_compare(current.next.label, target.label) < 0 {
        current = current.next;
    }
    target.next = current.next;
    current.next = target;
    ctx.target_count = ctx.target_count + 1;
}

fn parse_toml_workspace(ctx: &Phase1Context) i32 {
    if ctx.root_toml_path == null {
        return 0;
    }

    var size_out: usize = 0usize;
    const content: &byte = read_file_into_arena(ctx, ctx.root_toml_path, &size_out);
    if content == null {
        return phase1_error(ctx,
                            "UYABUILD_E_TOML_READ" as &byte,
                            "failed to read uya.toml" as &byte,
                            ctx.root_toml_path,
                            "uya.toml" as &byte,
                            0,
                            0);
    }

    var in_workspace: i32 = 0;
    var line_no: i32 = 1;
    var pos: usize = 0usize;

    while pos < size_out {
        var line_buf: [byte: MAX_STRING_BUILD] = [];
        var line_len: usize = 0usize;
        while pos < size_out && content[pos] != 10 as byte && line_len + 1 < MAX_STRING_BUILD {
            line_buf[line_len] = content[pos];
            line_len = line_len + 1usize;
            pos = pos + 1usize;
        }
        if pos < size_out && content[pos] == 10 as byte {
            pos = pos + 1usize;
        }
        line_buf[line_len] = 0 as byte;

        var start: usize = 0usize;
        while line_buf[start] == 32 as byte || line_buf[start] == 9 as byte {
            start = start + 1usize;
        }
        if line_buf[start] == 0 as byte || line_buf[start] == 35 as byte {
            line_no = line_no + 1;
            continue;
        }
        if line_buf[start] == 91 as byte {
            in_workspace = 0;
            if string_equals(&line_buf[start] as &byte, "[workspace]" as &byte) != 0 {
                in_workspace = 1;
            }
            line_no = line_no + 1;
            continue;
        }
        if in_workspace == 0 {
            line_no = line_no + 1;
            continue;
        }

        var eq_index: i32 = -1;
        var i: usize = start;
        while line_buf[i] != 0 as byte {
            if line_buf[i] == 61 as byte {
                eq_index = usize_to_i32_checked(i);
                break;
            }
            i = i + 1usize;
        }
        if eq_index < 0 {
            line_no = line_no + 1;
            continue;
        }

        const key_raw: &byte = arena_copy_range(&ctx.arena, &line_buf[0] as &byte, start, eq_index as usize - start);
        var key_trim_start: usize = 0usize;
        while key_raw[key_trim_start] == 32 as byte || key_raw[key_trim_start] == 9 as byte {
            key_trim_start = key_trim_start + 1usize;
        }
        var key_trim_end: usize = strlen(key_raw);
        while key_trim_end > key_trim_start &&
            (key_raw[key_trim_end - 1usize] == 32 as byte || key_raw[key_trim_end - 1usize] == 9 as byte) {
            key_trim_end = key_trim_end - 1usize;
        }
        const key: &byte = arena_copy_range(&ctx.arena,
                                            key_raw,
                                            key_trim_start,
                                            key_trim_end - key_trim_start);

        var value_start: usize = (eq_index as usize) + 1usize;
        while line_buf[value_start] == 32 as byte || line_buf[value_start] == 9 as byte {
            value_start = value_start + 1usize;
        }

        if string_equals(key, "name" as &byte) != 0 {
            if line_buf[value_start] == 34 as byte {
                var end_quote: usize = value_start + 1usize;
                while end_quote < MAX_STRING_BUILD &&
                    line_buf[end_quote] != 0 as byte &&
                    line_buf[end_quote] != 34 as byte {
                    end_quote = end_quote + 1usize;
                }
                ctx.toml_meta.name = arena_copy_range(&ctx.arena,
                                                      &line_buf[0] as &byte,
                                                      value_start + 1usize,
                                                      end_quote - (value_start + 1usize));
                ctx.toml_meta.has_name = 1;
            }
        } else if string_equals(key, "strict" as &byte) != 0 {
            if string_equals(&line_buf[value_start] as &byte, "true" as &byte) != 0 {
                ctx.toml_meta.strict = 1;
                ctx.toml_meta.has_strict = 1;
            } else if string_equals(&line_buf[value_start] as &byte, "false" as &byte) != 0 {
                ctx.toml_meta.strict = 0;
                ctx.toml_meta.has_strict = 1;
            }
        } else if string_equals(key, "default" as &byte) != 0 && line_buf[value_start] == 91 as byte {
            const list_value: &TypedValue = typed_make_list(ctx, zero_span());
            if list_value == null {
                return -1;
            }
            var idx: usize = value_start + 1usize;
            while idx < MAX_STRING_BUILD &&
                line_buf[idx] != 0 as byte &&
                line_buf[idx] != 93 as byte {
                while idx < MAX_STRING_BUILD &&
                    (line_buf[idx] == 32 as byte || line_buf[idx] == 9 as byte || line_buf[idx] == 44 as byte) {
                    idx = idx + 1usize;
                }
                if idx < MAX_STRING_BUILD && line_buf[idx] == 34 as byte {
                    var q_end: usize = idx + 1usize;
                    while q_end < MAX_STRING_BUILD &&
                        line_buf[q_end] != 0 as byte &&
                        line_buf[q_end] != 34 as byte {
                        q_end = q_end + 1usize;
                    }
                    const raw_label: &byte = arena_copy_range(&ctx.arena,
                                                              &line_buf[0] as &byte,
                                                              idx + 1usize,
                                                              q_end - (idx + 1usize));
                    const normalized: &byte = normalize_label(ctx,
                                                              "" as &byte,
                                                              raw_label,
                                                              "uya.toml" as &byte,
                                                              line_no,
                                                              1);
                    if normalized == null {
                        return -1;
                    }
                    const label_value: &TypedValue = typed_make_label(ctx, zero_span(), normalized);
                    if label_value == null || typed_list_append_value(ctx, list_value, label_value) != 0 {
                        return -1;
                    }
                    idx = q_end + 1usize;
                    continue;
                }
                idx = idx + 1usize;
            }
            ctx.toml_meta.defaults = list_value;
            ctx.toml_meta.has_default = 1;
        }

        line_no = line_no + 1;
    }

    return 0;
}

fn analyze_workspace_decl(ctx: &Phase1Context, decl: &AstDecl) i32 {
    if decl.file == null || decl.file.is_root == 0 {
        return phase1_error(ctx,
                            "UYABUILD_E_WORKSPACE_SCOPE" as &byte,
                            "workspace {} can only appear in the root uya.build" as &byte,
                            "move the workspace declaration back to the root build file" as &byte,
                            decl.file.rel_path,
                            decl.span.start.line,
                            decl.span.start.column);
    }
    if ctx.workspace_ir.source_file != null {
        return phase1_error(ctx,
                            "UYABUILD_E_WORKSPACE_DUP" as &byte,
                            "workspace {} may only be declared once" as &byte,
                            "remove the duplicate workspace block" as &byte,
                            decl.file.rel_path,
                            decl.span.start.line,
                            decl.span.start.column);
    }

    ctx.workspace_ir.source_file = decl.file;
    ctx.workspace_ir.span = decl.span;

    var field: &AstField = decl.field_head;
    while field != null {
        const expected: i32 = workspace_field_expected_type(field.name);
        if expected < 0 {
            return phase1_error(ctx,
                                "UYABUILD_E_SCHEMA_FIELD" as &byte,
                                "unknown workspace field" as &byte,
                                field.name,
                                decl.file.rel_path,
                                field.span.start.line,
                                field.span.start.column);
        }
        if string_equals(field.name, "name" as &byte) != 0 {
            if ctx.workspace_ir.has_name != 0 {
                return phase1_error(ctx,
                                    "UYABUILD_E_SCHEMA_DUP_FIELD" as &byte,
                                    "duplicate workspace field" as &byte,
                                    field.name,
                                    decl.file.rel_path,
                                    field.span.start.line,
                                    field.span.start.column);
            }
            const typed_name: &TypedValue = analyze_value(ctx,
                                                          decl.file,
                                                          decl.file.package_path,
                                                          decl.file.dir_abs,
                                                          field.value,
                                                          expected);
            if typed_name == null {
                return -1;
            }
            ctx.workspace_ir.name = typed_name.text;
            ctx.workspace_ir.has_name = 1;
        } else if string_equals(field.name, "default" as &byte) != 0 {
            if ctx.workspace_ir.has_defaults != 0 {
                return phase1_error(ctx,
                                    "UYABUILD_E_SCHEMA_DUP_FIELD" as &byte,
                                    "duplicate workspace field" as &byte,
                                    field.name,
                                    decl.file.rel_path,
                                    field.span.start.line,
                                    field.span.start.column);
            }
            ctx.workspace_ir.defaults = analyze_value(ctx,
                                                      decl.file,
                                                      decl.file.package_path,
                                                      decl.file.dir_abs,
                                                      field.value,
                                                      expected);
            if ctx.workspace_ir.defaults == null {
                return -1;
            }
            ctx.workspace_ir.has_defaults = 1;
        } else if string_equals(field.name, "strict" as &byte) != 0 {
            if ctx.workspace_ir.has_strict != 0 {
                return phase1_error(ctx,
                                    "UYABUILD_E_SCHEMA_DUP_FIELD" as &byte,
                                    "duplicate workspace field" as &byte,
                                    field.name,
                                    decl.file.rel_path,
                                    field.span.start.line,
                                    field.span.start.column);
            }
            const typed_strict: &TypedValue = analyze_value(ctx,
                                                            decl.file,
                                                            decl.file.package_path,
                                                            decl.file.dir_abs,
                                                            field.value,
                                                            expected);
            if typed_strict == null {
                return -1;
            }
            ctx.workspace_ir.strict = typed_strict.bool_value;
            ctx.workspace_ir.has_strict = 1;
        }
        field = field.next;
    }

    return 0;
}

fn analyze_config_decl(ctx: &Phase1Context, decl: &AstDecl) i32 {
    var current: &IRConfig = ctx.configs_head;
    while current != null {
        if string_equals(current.name, decl.label_text) != 0 {
            return phase1_error(ctx,
                                "UYABUILD_E_CONFIG_DUP" as &byte,
                                "config name is declared more than once" as &byte,
                                decl.label_text,
                                decl.file.rel_path,
                                decl.span.start.line,
                                decl.span.start.column);
        }
        current = current.next;
    }

    const config: &IRConfig = new_ir_config(ctx);
    if config == null {
        return -1;
    }
    config.name = arena_copy_cstr(&ctx.arena, decl.label_text);
    config.file = decl.file;
    config.span = decl.span;
    config.attrs = null;

    var field: &AstField = decl.field_head;
    while field != null {
        if find_ir_field(config.attrs, field.name) != null {
            return phase1_error(ctx,
                                "UYABUILD_E_SCHEMA_DUP_FIELD" as &byte,
                                "duplicate config field" as &byte,
                                field.name,
                                decl.file.rel_path,
                                field.span.start.line,
                                field.span.start.column);
        }
        const typed_value: &TypedValue = analyze_value(ctx,
                                                       decl.file,
                                                       decl.file.package_path,
                                                       decl.file.dir_abs,
                                                       field.value,
                                                       EXPECT_ANY);
        if typed_value == null {
            return -1;
        }
        const ir_field: &IRField = new_ir_field(ctx);
        if ir_field == null {
            return -1;
        }
        ir_field.name = arena_copy_cstr(&ctx.arena, field.name);
        ir_field.value = typed_value;
        config.attrs = append_ir_field(config.attrs, ir_field);
        field = field.next;
    }

    if ctx.configs_head == null {
        ctx.configs_head = config;
        ctx.configs_tail = config;
    } else {
        ctx.configs_tail.next = config;
        ctx.configs_tail = config;
    }
    ctx.config_count = ctx.config_count + 1;
    return 0;
}

fn label_package_part(ctx: &Phase1Context, canonical: &byte) &byte {
    _ = ctx;
    var i: usize = 2usize;
    while canonical[i] != 0 as byte && canonical[i] != 58 as byte {
        i = i + 1usize;
    }
    return arena_copy_range(&ctx.arena, canonical, 2usize, i - 2usize);
}

fn label_name_part(ctx: &Phase1Context, canonical: &byte) &byte {
    var i: usize = 0usize;
    while canonical[i] != 0 as byte {
        if canonical[i] == 58 as byte {
            return arena_copy_range(&ctx.arena, canonical, i + 1usize, strlen(canonical) - i - 1usize);
        }
        i = i + 1usize;
    }
    return arena_copy_cstr(&ctx.arena, canonical);
}

fn analyze_target_decl(ctx: &Phase1Context, decl: &AstDecl) i32 {
    const pack: &byte = rule_pack_for_kind(decl.name);
    if pack == null {
        return phase1_error(ctx,
                            "UYABUILD_E_RULE_KIND" as &byte,
                            "unknown rule kind" as &byte,
                            decl.name,
                            decl.file.rel_path,
                            decl.span.start.line,
                            decl.span.start.column);
    }
    if pack[0] != 0 as byte && has_rule_use(ctx, pack) == 0 {
        return phase1_error(ctx,
                            "UYABUILD_E_RULE_USE" as &byte,
                            "rule kind is used before its rule pack is imported" as &byte,
                            decl.name,
                            decl.file.rel_path,
                            decl.span.start.line,
                            decl.span.start.column);
    }

    const canonical: &byte = normalize_label(ctx,
                                             decl.file.package_path,
                                             decl.label_text,
                                             decl.file.rel_path,
                                             decl.span.start.line,
                                             decl.span.start.column);
    if canonical == null {
        return -1;
    }
    if find_target_by_label(ctx, canonical) != null {
        return phase1_error(ctx,
                            "UYABUILD_E_TARGET_DUP" as &byte,
                            "target label is declared more than once" as &byte,
                            canonical,
                            decl.file.rel_path,
                            decl.span.start.line,
                            decl.span.start.column);
    }

    const target: &IRTarget = new_ir_target(ctx);
    if target == null {
        return -1;
    }
    target.label = canonical;
    target.package_path = label_package_part(ctx, canonical);
    target.name = label_name_part(ctx, canonical);
    target.kind = arena_copy_cstr(&ctx.arena, decl.name);
    target.file = decl.file;
    target.span = decl.span;
    target.attrs = null;
    target.provider_mask = provider_mask_for_kind(decl.name);

    var field: &AstField = decl.field_head;
    while field != null {
        if find_ir_field(target.attrs, field.name) != null {
            return phase1_error(ctx,
                                "UYABUILD_E_SCHEMA_DUP_FIELD" as &byte,
                                "duplicate target field" as &byte,
                                field.name,
                                decl.file.rel_path,
                                field.span.start.line,
                                field.span.start.column);
        }
        const expected: i32 = field_expected_type(decl.name, field.name);
        if expected < 0 {
            return phase1_error(ctx,
                                "UYABUILD_E_SCHEMA_FIELD" as &byte,
                                "unknown field for rule kind" as &byte,
                                field.name,
                                decl.file.rel_path,
                                field.span.start.line,
                                field.span.start.column);
        }
        const typed_value: &TypedValue = analyze_value(ctx,
                                                       decl.file,
                                                       decl.file.package_path,
                                                       decl.file.dir_abs,
                                                       field.value,
                                                       expected);
        if typed_value == null {
            return -1;
        }
        const ir_field: &IRField = new_ir_field(ctx);
        if ir_field == null {
            return -1;
        }
        ir_field.name = arena_copy_cstr(&ctx.arena, field.name);
        ir_field.value = typed_value;
        target.attrs = append_ir_field(target.attrs, ir_field);
        field = field.next;
    }

    insert_target_sorted(ctx, target);
    return 0;
}

fn typed_value_has_labels(ctx: &Phase1Context,
                          owner_file: &byte,
                          span: SourceSpan,
                          value: &TypedValue,
                          required_mask: u32,
                          relation: &byte) i32 {
    if value == null {
        return 0;
    }
    if value.kind == TYPED_VALUE_LABEL {
        const dep: &IRTarget = find_target_by_label(ctx, value.text);
        if dep == null {
            return phase1_error(ctx,
                                "UYABUILD_E_TARGET_NOT_FOUND" as &byte,
                                "referenced target does not exist" as &byte,
                                value.text,
                                owner_file,
                                span.start.line,
                                span.start.column);
        }
        if required_mask != 0u32 && (dep.provider_mask & required_mask) == 0u32 {
            return phase1_error(ctx,
                                "UYABUILD_E_PROVIDER_MISMATCH" as &byte,
                                "referenced target does not provide the required provider" as &byte,
                                relation,
                                owner_file,
                                span.start.line,
                                span.start.column);
        }
        return 0;
    }
    if value.kind == TYPED_VALUE_LIST {
        var item: &TypedValueItem = value.list_head;
        while item != null {
            if typed_value_has_labels(ctx, owner_file, span, item.value, required_mask, relation) != 0 {
                return -1;
            }
            item = item.next;
        }
        return 0;
    }
    if value.kind == TYPED_VALUE_CALL && string_equals(value.call_name, "select" as &byte) != 0 {
        var arg: &TypedValueItem = value.arg_head;
        while arg != null {
            if arg.value.kind == TYPED_VALUE_MAP {
                var entry: &TypedMapEntry = arg.value.map_head;
                while entry != null {
                    if typed_value_has_labels(ctx, owner_file, span, entry.value, required_mask, relation) != 0 {
                        return -1;
                    }
                    entry = entry.next;
                }
            } else if typed_value_has_labels(ctx, owner_file, span, arg.value, required_mask, relation) != 0 {
                return -1;
            }
            arg = arg.next;
        }
    }
    return 0;
}

fn target_field_exists(target: &IRTarget, name: &byte) i32 {
    if find_ir_field(target.attrs, name) != null {
        return 1;
    }
    return 0;
}

fn validate_targets(ctx: &Phase1Context) i32 {
    var target: &IRTarget = ctx.targets_head;
    while target != null {
        if string_equals(target.kind, "legacy.shell" as &byte) != 0 {
            if target_field_exists(target, "script" as &byte) == 0 &&
                target_field_exists(target, "run" as &byte) == 0 {
                return phase1_error(ctx,
                                    "UYABUILD_E_SCHEMA_REQUIRED" as &byte,
                                    "legacy.shell requires script or run" as &byte,
                                    target.label,
                                    target.file.rel_path,
                                    target.span.start.line,
                                    target.span.start.column);
            }
            if target_field_exists(target, "outputs" as &byte) == 0 {
                return phase1_error(ctx,
                                    "UYABUILD_E_SCHEMA_REQUIRED" as &byte,
                                    "legacy.shell requires outputs" as &byte,
                                    target.label,
                                    target.file.rel_path,
                                    target.span.start.line,
                                    target.span.start.column);
            }
        }
        if string_equals(target.kind, "node.workspace" as &byte) != 0 {
            if target_field_exists(target, "root" as &byte) == 0 ||
                target_field_exists(target, "lockfile" as &byte) == 0 {
                return phase1_error(ctx,
                                    "UYABUILD_E_SCHEMA_REQUIRED" as &byte,
                                    "node.workspace requires root and lockfile" as &byte,
                                    target.label,
                                    target.file.rel_path,
                                    target.span.start.line,
                                    target.span.start.column);
            }
        }
        if string_equals(target.kind, "node.app" as &byte) != 0 {
            const workspace_field: &IRField = find_ir_field(target.attrs, "workspace" as &byte);
            if workspace_field == null || target_field_exists(target, "package" as &byte) == 0 {
                return phase1_error(ctx,
                                    "UYABUILD_E_SCHEMA_REQUIRED" as &byte,
                                    "node.app requires workspace and package" as &byte,
                                    target.label,
                                    target.file.rel_path,
                                    target.span.start.line,
                                    target.span.start.column);
            }
            if typed_value_has_labels(ctx,
                                      target.file.rel_path,
                                      target.span,
                                      workspace_field.value,
                                      PROVIDER_NODE_WORKSPACE,
                                      "workspace provider mismatch" as &byte) != 0 {
                return -1;
            }
        }
        if string_equals(target.kind, "oci.image" as &byte) != 0 {
            if target_field_exists(target, "dockerfile" as &byte) == 0 ||
                target_field_exists(target, "context" as &byte) == 0 {
                return phase1_error(ctx,
                                    "UYABUILD_E_SCHEMA_REQUIRED" as &byte,
                                    "oci.image requires dockerfile and context" as &byte,
                                    target.label,
                                    target.file.rel_path,
                                    target.span.start.line,
                                    target.span.start.column);
            }
        }
        if string_equals(target.kind, "task" as &byte) != 0 &&
            target_field_exists(target, "run" as &byte) == 0 {
            return phase1_error(ctx,
                                "UYABUILD_E_SCHEMA_REQUIRED" as &byte,
                                "task requires run" as &byte,
                                target.label,
                                target.file.rel_path,
                                target.span.start.line,
                                target.span.start.column);
        }

        const deps_field: &IRField = find_ir_field(target.attrs, "deps" as &byte);
        if deps_field != null {
            var required_mask: u32 = 0u32;
            if string_equals(target.kind, "cxx.binary" as &byte) != 0 ||
                string_equals(target.kind, "cxx.library" as &byte) != 0 {
                required_mask = PROVIDER_CXX_LINKABLE;
            }
            if typed_value_has_labels(ctx,
                                      target.file.rel_path,
                                      target.span,
                                      deps_field.value,
                                      required_mask,
                                      "dependency provider mismatch" as &byte) != 0 {
                return -1;
            }
        }

        target = target.next;
    }

    if ctx.workspace_ir.defaults != null &&
        typed_value_has_labels(ctx,
                               "uya.build" as &byte,
                               ctx.workspace_ir.span,
                               ctx.workspace_ir.defaults,
                               0u32,
                               "workspace default target is missing" as &byte) != 0 {
        return -1;
    }
    return 0;
}

fn analyze_workspace(ctx: &Phase1Context) i32 {
    if parse_toml_workspace(ctx) != 0 {
        return -1;
    }

    var file: &SourceFile = ctx.files_head;
    while file != null {
        var decl: &AstDecl = file.decl_head;
        while decl != null {
            if decl.kind == AST_DECL_USE {
                if record_rule_use(ctx, decl.label_text) != 0 {
                    return -1;
                }
            } else if decl.kind == AST_DECL_WORKSPACE {
                if analyze_workspace_decl(ctx, decl) != 0 {
                    return -1;
                }
            } else if decl.kind == AST_DECL_CONFIG {
                if analyze_config_decl(ctx, decl) != 0 {
                    return -1;
                }
            } else if decl.kind == AST_DECL_TARGET {
                if analyze_target_decl(ctx, decl) != 0 {
                    return -1;
                }
            }
            decl = decl.next;
        }
        file = file.next;
    }

    if ctx.toml_meta.has_name != 0 {
        if ctx.workspace_ir.has_name == 0 {
            ctx.workspace_ir.name = ctx.toml_meta.name;
            ctx.workspace_ir.has_name = 1;
        } else if string_equals(ctx.workspace_ir.name, ctx.toml_meta.name) == 0 {
            return phase1_error(ctx,
                                "UYABUILD_E_TOML_CONFLICT" as &byte,
                                "workspace.name conflicts with uya.toml" as &byte,
                                "root uya.build is authoritative; keep both values consistent" as &byte,
                                "uya.toml" as &byte,
                                1,
                                1);
        }
    }
    if ctx.toml_meta.has_default != 0 {
        if ctx.workspace_ir.has_defaults == 0 {
            ctx.workspace_ir.defaults = ctx.toml_meta.defaults;
            ctx.workspace_ir.has_defaults = 1;
        } else if typed_value_equals(ctx.workspace_ir.defaults, ctx.toml_meta.defaults) == 0 {
            return phase1_error(ctx,
                                "UYABUILD_E_TOML_CONFLICT" as &byte,
                                "workspace.default conflicts with uya.toml" as &byte,
                                "root uya.build is authoritative; keep both values consistent" as &byte,
                                "uya.toml" as &byte,
                                1,
                                1);
        }
    }
    if ctx.toml_meta.has_strict != 0 {
        if ctx.workspace_ir.has_strict == 0 {
            ctx.workspace_ir.strict = ctx.toml_meta.strict;
            ctx.workspace_ir.has_strict = 1;
        } else if ctx.workspace_ir.strict != ctx.toml_meta.strict {
            return phase1_error(ctx,
                                "UYABUILD_E_TOML_CONFLICT" as &byte,
                                "workspace.strict conflicts with uya.toml" as &byte,
                                "root uya.build is authoritative; keep both values consistent" as &byte,
                                "uya.toml" as &byte,
                                1,
                                1);
        }
    }

    if ctx.workspace_ir.has_name == 0 {
        return phase1_error(ctx,
                            "UYABUILD_E_WORKSPACE_NAME" as &byte,
                            "workspace.name is required" as &byte,
                            "set it in root uya.build or uya.toml [workspace]" as &byte,
                            "uya.build" as &byte,
                            1,
                            1);
    }
    if ctx.workspace_ir.has_defaults == 0 {
        ctx.workspace_ir.defaults = typed_make_list(ctx, zero_span());
        ctx.workspace_ir.has_defaults = 1;
    }
    if ctx.workspace_ir.has_strict == 0 {
        ctx.workspace_ir.strict = 0;
        ctx.workspace_ir.has_strict = 1;
    }

    return validate_targets(ctx);
}

fn emit_typed_value_json(stream: &FILE, value: &TypedValue) void {
    if value == null {
        fputs("null" as *byte, stream);
        return;
    }
    if value.kind == TYPED_VALUE_STRING || value.kind == TYPED_VALUE_LABEL {
        fputc(34, stream);
        write_json_escape(stream, value.text);
        fputc(34, stream);
        return;
    }
    if value.kind == TYPED_VALUE_BOOL {
        if value.bool_value != 0 {
            fputs("true" as *byte, stream);
        } else {
            fputs("false" as *byte, stream);
        }
        return;
    }
    if value.kind == TYPED_VALUE_IDENT {
        fputs("{\"$ident\":\"" as *byte, stream);
        write_json_escape(stream, value.text);
        fputs("\"}" as *byte, stream);
        return;
    }
    if value.kind == TYPED_VALUE_LIST {
        fputs("[" as *byte, stream);
        var first_list: i32 = 1;
        var item: &TypedValueItem = value.list_head;
        while item != null {
            if first_list == 0 {
                fputs("," as *byte, stream);
            }
            emit_typed_value_json(stream, item.value);
            first_list = 0;
            item = item.next;
        }
        fputs("]" as *byte, stream);
        return;
    }
    if value.kind == TYPED_VALUE_MAP {
        fputs("{" as *byte, stream);
        var first_map: i32 = 1;
        var entry: &TypedMapEntry = value.map_head;
        while entry != null {
            if first_map == 0 {
                fputs("," as *byte, stream);
            }
            fputc(34, stream);
            write_json_escape(stream, entry.key);
            fputs("\":" as *byte, stream);
            emit_typed_value_json(stream, entry.value);
            first_map = 0;
            entry = entry.next;
        }
        fputs("}" as *byte, stream);
        return;
    }
    if value.kind == TYPED_VALUE_CALL {
        fputs("{\"$call\":\"" as *byte, stream);
        write_json_escape(stream, value.call_name);
        fputs("\",\"args\":[" as *byte, stream);
        var first_arg: i32 = 1;
        var arg: &TypedValueItem = value.arg_head;
        while arg != null {
            if first_arg == 0 {
                fputs("," as *byte, stream);
            }
            emit_typed_value_json(stream, arg.value);
            first_arg = 0;
            arg = arg.next;
        }
        fputs("]}" as *byte, stream);
        return;
    }
    fputs("null" as *byte, stream);
}

fn emit_ir_fields_json(stream: &FILE, fields: &IRField) void {
    fputs("{" as *byte, stream);
    var first: i32 = 1;
    var field: &IRField = fields;
    while field != null {
        if first == 0 {
            fputs("," as *byte, stream);
        }
        fputc(34, stream);
        write_json_escape(stream, field.name);
        fputs("\":" as *byte, stream);
        emit_typed_value_json(stream, field.value);
        first = 0;
        field = field.next;
    }
    fputs("}" as *byte, stream);
}

fn emit_provider_mask_json(stream: &FILE, mask: u32) void {
    fputs("[" as *byte, stream);
    var first: i32 = 1;
    if (mask & PROVIDER_CXX_LINKABLE) != 0u32 {
        fputs("\"cxx.linkable\"" as *byte, stream);
        first = 0;
    }
    if (mask & PROVIDER_NODE_WORKSPACE) != 0u32 {
        if first == 0 { fputs("," as *byte, stream); }
        fputs("\"node.workspace\"" as *byte, stream);
        first = 0;
    }
    if (mask & PROVIDER_NODE_APP) != 0u32 {
        if first == 0 { fputs("," as *byte, stream); }
        fputs("\"node.app\"" as *byte, stream);
        first = 0;
    }
    if (mask & PROVIDER_OCI_IMAGE) != 0u32 {
        if first == 0 { fputs("," as *byte, stream); }
        fputs("\"oci.image\"" as *byte, stream);
        first = 0;
    }
    if (mask & PROVIDER_LEGACY_ACTION) != 0u32 {
        if first == 0 { fputs("," as *byte, stream); }
        fputs("\"legacy.action\"" as *byte, stream);
        first = 0;
    }
    if (mask & PROVIDER_TASK) != 0u32 {
        if first == 0 { fputs("," as *byte, stream); }
        fputs("\"task\"" as *byte, stream);
    }
    fputs("]" as *byte, stream);
}

fn query_expression_matches(label: &byte, expression: &byte) i32 {
    if string_equals(expression, "//..." as &byte) != 0 {
        return 1;
    }
    if string_has_suffix(expression, "/..." as &byte) != 0 {
        const prefix_len: usize = strlen(expression) - 4usize;
        if label[0] != 47 as byte || label[1] != 47 as byte {
            return 0;
        }
        var i: usize = 2usize;
        while i < prefix_len {
            if expression[i] != label[i] {
                return 0;
            }
            i = i + 1usize;
        }
        if label[prefix_len] == 58 as byte || label[prefix_len] == 47 as byte {
            return 1;
        }
        return 0;
    }
    return string_equals(label, expression);
}

fn collect_query_matches(ctx: &Phase1Context, expression: &byte, match_count: &i32) &StringNode {
    var matches: &StringNode = null;
    match_count[0] = 0;
    var target: &IRTarget = ctx.targets_head;
    while target != null {
        if query_expression_matches(target.label, expression) != 0 {
            var inserted: i32 = 0;
            matches = sorted_string_insert(ctx, matches, target.label, &inserted);
            if inserted != 0 {
                match_count[0] = match_count[0] + 1;
            }
        }
        target = target.next;
    }
    return matches;
}

fn collect_default_targets(ctx: &Phase1Context, match_count: &i32) &StringNode {
    var matches: &StringNode = null;
    match_count[0] = 0;
    if ctx.workspace_ir.defaults == null || ctx.workspace_ir.defaults.kind != TYPED_VALUE_LIST {
        return matches;
    }
    var item: &TypedValueItem = ctx.workspace_ir.defaults.list_head;
    while item != null {
        if item.value != null && item.value.text != null {
            var inserted: i32 = 0;
            matches = sorted_string_insert(ctx, matches, item.value.text, &inserted);
            if inserted != 0 {
                match_count[0] = match_count[0] + 1;
            }
        }
        item = item.next;
    }
    return matches;
}

fn resolve_requested_targets(ctx: &Phase1Context,
                            requested: [&byte: MAX_ARGS],
                            requested_count: i32,
                            match_count: &i32) &StringNode {
    if requested_count == 0 {
        return collect_default_targets(ctx, match_count);
    }

    var matches: &StringNode = null;
    match_count[0] = 0;
    var i: i32 = 0;
    while i < requested_count {
        var local_count: i32 = 0;
        var local_matches: &StringNode = collect_query_matches(ctx, requested[i as usize], &local_count);
        if local_count == 0 {
            phase1_error(ctx,
                         "UYABUILD_E_TARGET_NOT_FOUND" as &byte,
                         "requested target expression matched nothing" as &byte,
                         requested[i as usize],
                         "uya.build" as &byte,
                         1,
                         1);
            return null;
        }
        var node: &StringNode = local_matches;
        while node != null {
            var inserted: i32 = 0;
            matches = sorted_string_insert(ctx, matches, node.text, &inserted);
            if inserted != 0 {
                match_count[0] = match_count[0] + 1;
            }
            node = node.next;
        }
        i = i + 1;
    }
    return matches;
}

fn action_append_command(ctx: &Phase1Context, action: &PlannedAction, text: &byte) i32 {
    const node: &StringNode = new_string_node(ctx, text);
    if node == null {
        return -1;
    }
    if action.command_head == null {
        action.command_head = node;
        action.command_tail = node;
    } else {
        action.command_tail.next = node;
        action.command_tail = node;
    }
    return 0;
}

fn action_insert_input(ctx: &Phase1Context, action: &PlannedAction, text: &byte) void {
    var inserted: i32 = 0;
    action.input_head = sorted_string_insert(ctx, action.input_head, text, &inserted);
    _ = inserted;
}

fn action_insert_output(ctx: &Phase1Context, action: &PlannedAction, text: &byte) void {
    var inserted: i32 = 0;
    action.output_head = sorted_string_insert(ctx, action.output_head, text, &inserted);
    _ = inserted;
}

fn action_insert_dep(ctx: &Phase1Context, action: &PlannedAction, text: &byte) void {
    var inserted: i32 = 0;
    action.dep_head = sorted_string_insert(ctx, action.dep_head, text, &inserted);
    _ = inserted;
}

fn collect_typed_labels_sorted(ctx: &Phase1Context, value: &TypedValue, head: &StringNode) &StringNode {
    var result: &StringNode = head;
    if value == null {
        return result;
    }
    if value.kind == TYPED_VALUE_LABEL {
        var inserted: i32 = 0;
        result = sorted_string_insert(ctx, result, value.text, &inserted);
        return result;
    }
    if value.kind == TYPED_VALUE_LIST {
        var item: &TypedValueItem = value.list_head;
        while item != null {
            result = collect_typed_labels_sorted(ctx, item.value, result);
            item = item.next;
        }
        return result;
    }
    if value.kind == TYPED_VALUE_CALL && string_equals(value.call_name, "select" as &byte) != 0 {
        var arg: &TypedValueItem = value.arg_head;
        while arg != null {
            if arg.value != null && arg.value.kind == TYPED_VALUE_MAP {
                var entry: &TypedMapEntry = arg.value.map_head;
                while entry != null {
                    result = collect_typed_labels_sorted(ctx, entry.value, result);
                    entry = entry.next;
                }
            } else {
                result = collect_typed_labels_sorted(ctx, arg.value, result);
            }
            arg = arg.next;
        }
    }
    return result;
}

fn collect_typed_strings_sorted(ctx: &Phase1Context, value: &TypedValue, head: &StringNode) &StringNode {
    var result: &StringNode = head;
    if value == null {
        return result;
    }
    if value.kind == TYPED_VALUE_STRING {
        var inserted: i32 = 0;
        result = sorted_string_insert(ctx, result, value.text, &inserted);
        return result;
    }
    if value.kind == TYPED_VALUE_LIST {
        var item: &TypedValueItem = value.list_head;
        while item != null {
            result = collect_typed_strings_sorted(ctx, item.value, result);
            item = item.next;
        }
        return result;
    }
    if value.kind == TYPED_VALUE_CALL && string_equals(value.call_name, "select" as &byte) != 0 {
        var arg: &TypedValueItem = value.arg_head;
        while arg != null {
            if arg.value != null && arg.value.kind == TYPED_VALUE_MAP {
                var entry: &TypedMapEntry = arg.value.map_head;
                while entry != null {
                    result = collect_typed_strings_sorted(ctx, entry.value, result);
                    entry = entry.next;
                }
            } else {
                result = collect_typed_strings_sorted(ctx, arg.value, result);
            }
            arg = arg.next;
        }
    }
    return result;
}

fn insert_tree_child_sorted(ctx: &Phase1Context,
                            head: &TreeChild,
                            name: &byte,
                            kind: i32,
                            digest_hex: &byte) &TreeChild {
    const child: &TreeChild = new_tree_child(ctx);
    if child == null {
        return head;
    }
    child.name = arena_copy_cstr(&ctx.arena, name);
    child.kind = kind;
    child.digest_hex = arena_copy_cstr(&ctx.arena, digest_hex);
    child.next = null;

    if head == null || cstr_compare(name, head.name) < 0 {
        child.next = head;
        return child;
    }

    var current: &TreeChild = head;
    while current.next != null && cstr_compare(current.next.name, name) < 0 {
        current = current.next;
    }
    if current.next != null && string_equals(current.next.name, name) != 0 {
        return head;
    }
    if string_equals(current.name, name) != 0 {
        return head;
    }
    child.next = current.next;
    current.next = child;
    return head;
}

fn find_snapshot_entry(ctx: &Phase2Context, rel_path: &byte, kind: i32) &SnapshotEntry {
    var entry: &SnapshotEntry = ctx.snapshot_head;
    while entry != null {
        if entry.kind == kind && string_equals(entry.rel_path, rel_path) != 0 {
            return entry;
        }
        entry = entry.next;
    }
    return null;
}

fn find_planned_action_by_label(ctx: &Phase2Context, label: &byte) &PlannedAction {
    var action: &PlannedAction = ctx.action_head;
    while action != null {
        if string_equals(action.label, label) != 0 {
            return action;
        }
        action = action.next;
    }
    return null;
}

fn find_visit_mark(ctx: &Phase2Context, label: &byte) &VisitMark {
    var mark: &VisitMark = ctx.visit_head;
    while mark != null {
        if string_equals(mark.label, label) != 0 {
            return mark;
        }
        mark = mark.next;
    }
    return null;
}

fn string_has_wildcard(text: &byte) i32 {
    if text == null {
        return 0;
    }
    var i: usize = 0usize;
    while text[i] != 0 as byte {
        if text[i] == 42 as byte || text[i] == 63 as byte {
            return 1;
        }
        i = i + 1usize;
    }
    return 0;
}

fn should_skip_snapshot_name(name: &byte) i32 {
    if name == null {
        return 0;
    }
    if string_equals(name, ".git" as &byte) != 0 ||
        string_equals(name, ".uya-build" as &byte) != 0 {
        return 1;
    }
    return 0;
}

fn resolve_target_path(ctx: &Phase1Context,
                       target: &IRTarget,
                       raw: &byte,
                       rel_out: &byte,
                       abs_out: &byte) i32 {
    if ctx == null || target == null || raw == null {
        return -1;
    }
    if join_and_normalize_path(target.file.dir_abs, raw, abs_out, PATH_MAX) != 0 {
        return -1;
    }
    if path_relative_to_root(ctx.workspace_root, abs_out, rel_out, PATH_MAX) != 0 {
        return -1;
    }
    if rel_out[0] == 0 as byte {
        return copy_string(rel_out, PATH_MAX, "." as &byte);
    }
    return 0;
}

fn persist_bytes(path: &byte, data: &byte, data_len: usize) i32 {
    if path == null || data == null {
        return -1;
    }
    if path_is_file(path) != 0 {
        return 0;
    }
    const file: &FILE = fopen(path as &const byte, "wb" as &const byte);
    if file == null {
        return -1;
    }
    const written: usize = fwrite(data as &const byte, 1usize, data_len, file);
    _ = fflush(file);
    if fclose(file) != 0 {
        return -1;
    }
    if written != data_len {
        return -1;
    }
    return 0;
}

fn persist_text(path: &byte, text: &byte) i32 {
    if path == null || text == null {
        return -1;
    }
    return persist_bytes(path, text, strlen(text));
}

fn phase_number_for_subcommand(subcommand: &byte) i32 {
    if string_equals(subcommand, "build" as &byte) != 0 {
        return BUILD_PHASE_NUMBER;
    }
    if string_equals(subcommand, "plan" as &byte) != 0 {
        return PLAN_PHASE_NUMBER;
    }
    if string_equals(subcommand, "query" as &byte) != 0 {
        return 1;
    }
    return BUILD_PHASE_NUMBER;
}

fn path_basename_text(path: &byte, out: &byte, out_cap: usize) i32 {
    if path == null || out == null || out_cap == 0 {
        return -1;
    }
    const len: usize = strlen(path);
    if len == 0 {
        return copy_string(out, out_cap, "." as &byte);
    }

    var start: usize = 0usize;
    var i: usize = 0usize;
    while i < len {
        if path[i] == 47 as byte {
            start = i + 1usize;
        }
        i = i + 1usize;
    }
    return copy_string(out, out_cap, &path[start] as &byte);
}

fn wait_status_signal(wait_status: i32) i32 {
    if wait_status < 0 {
        return 0;
    }
    const low: i32 = wait_status & 127;
    if low == 0 {
        return 0;
    }
    return low & 127;
}

fn wait_status_exit_code(wait_status: i32) i32 {
    if wait_status < 0 {
        return 1;
    }
    const signal_code: i32 = wait_status_signal(wait_status);
    if signal_code != 0 {
        return 128 + signal_code;
    }
    return (wait_status >> 8) & 255;
}

fn set_action_diagnostic(ctx: &Phase2Context,
                         action: &PlannedAction,
                         exit_code: i32,
                         code: &byte,
                         message: &byte,
                         detail: &byte) i32 {
    var file_text: &byte = action.label;
    var line: i32 = 0;
    var column: i32 = 0;
    if action != null && action.owner != null && action.owner.file != null {
        file_text = action.owner.file.rel_path;
        line = action.owner.span.start.line;
        column = action.owner.span.start.column;
    }
    return set_diagnostic(ctx.phase1, exit_code, code, message, detail, file_text, line, column);
}

fn shell_append_quoted(buffer: &byte, used: &usize, cap: usize, text: &byte) i32 {
    if append_buffer_byte(buffer, used, cap, 39 as byte) != 0 {
        return -1;
    }
    if text != null {
        var i: usize = 0usize;
        while text[i] != 0 as byte {
            const ch: byte = text[i];
            if ch == 39 as byte {
                if append_buffer_byte(buffer, used, cap, 39 as byte) != 0 ||
                    append_buffer_byte(buffer, used, cap, 92 as byte) != 0 ||
                    append_buffer_byte(buffer, used, cap, 39 as byte) != 0 ||
                    append_buffer_byte(buffer, used, cap, 39 as byte) != 0 {
                    return -1;
                }
            } else if append_buffer_byte(buffer, used, cap, ch) != 0 {
                return -1;
            }
            i = i + 1usize;
        }
    }
    return append_buffer_byte(buffer, used, cap, 39 as byte);
}

fn build_action_shell_command(ctx: &Phase1Context,
                              action: &PlannedAction,
                              stdout_path: &byte,
                              stderr_path: &byte) &byte {
    if ctx == null || action == null || action.command_head == null {
        return null;
    }
    var buffer: [byte: MAX_STRING_BUILD] = [];
    var used: usize = 0usize;
    var first: i32 = 1;
    var arg: &StringNode = action.command_head;
    while arg != null {
        if first == 0 && append_buffer_byte(&buffer[0] as &byte, &used, MAX_STRING_BUILD, 32 as byte) != 0 {
            return null;
        }
        if shell_append_quoted(&buffer[0] as &byte, &used, MAX_STRING_BUILD, arg.text) != 0 {
            return null;
        }
        first = 0;
        arg = arg.next;
    }
    if stdout_path != null {
        if append_buffer_text(&buffer[0] as &byte, &used, MAX_STRING_BUILD, " > " as &byte) != 0 ||
            shell_append_quoted(&buffer[0] as &byte, &used, MAX_STRING_BUILD, stdout_path) != 0 {
            return null;
        }
    }
    if stderr_path != null {
        if append_buffer_text(&buffer[0] as &byte, &used, MAX_STRING_BUILD, " 2> " as &byte) != 0 ||
            shell_append_quoted(&buffer[0] as &byte, &used, MAX_STRING_BUILD, stderr_path) != 0 {
            return null;
        }
    }
    return arena_copy_cstr(&ctx.arena, &buffer[0] as &byte);
}

fn copy_file_path(ctx: &Phase1Context, source_abs: &byte, dest_abs: &byte) i32 {
    if ctx == null || source_abs == null || dest_abs == null {
        return -1;
    }
    var parent: [byte: PATH_MAX] = [];
    if path_dirname_text(dest_abs, &parent[0] as &byte, PATH_MAX) != 0 ||
        ensure_dir_recursive(&parent[0] as &byte) != 0 {
        return -1;
    }
    if path_is_file(dest_abs) != 0 && remove(dest_abs as &const byte) != 0 {
        return -1;
    }
    var size_out: usize = 0usize;
    const content: &byte = read_file_into_arena(ctx, source_abs, &size_out);
    if content == null {
        return -1;
    }
    return persist_bytes(dest_abs, content, size_out);
}

fn copy_path_recursive(ctx: &Phase1Context, source_abs: &byte, dest_abs: &byte) i32 {
    if ctx == null || source_abs == null || dest_abs == null {
        return -1;
    }
    if path_is_file(source_abs) != 0 {
        return copy_file_path(ctx, source_abs, dest_abs);
    }
    if path_is_dir(source_abs) == 0 {
        return -1;
    }
    if ensure_dir_recursive(dest_abs) != 0 {
        return -1;
    }
    const dir: &DIR = opendir(source_abs as &const byte);
    if dir == null {
        return -1;
    }
    var entry_dir: &Dirent = readdir(dir);
    while entry_dir != null {
        const name: &byte = &entry_dir.d_name[0] as &byte;
        if is_dirent_dot(name) != 0 {
            entry_dir = readdir(dir);
            continue;
        }
        var child_source: [byte: PATH_MAX] = [];
        var child_dest: [byte: PATH_MAX] = [];
        if join_path(source_abs, name, &child_source[0] as &byte, PATH_MAX) != 0 ||
            join_path(dest_abs, name, &child_dest[0] as &byte, PATH_MAX) != 0 ||
            copy_path_recursive(ctx, &child_source[0] as &byte, &child_dest[0] as &byte) != 0 {
            _ = closedir(dir);
            return -1;
        }
        entry_dir = readdir(dir);
    }
    _ = closedir(dir);
    return 0;
}

fn recursive_remove_path(path: &byte) i32 {
    if path == null {
        return -1;
    }
    if path_is_file(path) != 0 {
        if remove(path as &const byte) != 0 {
            return -1;
        }
        return 0;
    }
    if path_is_dir(path) == 0 {
        return 0;
    }
    const dir: &DIR = opendir(path as &const byte);
    if dir == null {
        return -1;
    }
    var entry_dir: &Dirent = readdir(dir);
    while entry_dir != null {
        const name: &byte = &entry_dir.d_name[0] as &byte;
        if is_dirent_dot(name) != 0 {
            entry_dir = readdir(dir);
            continue;
        }
        var child_path: [byte: PATH_MAX] = [];
        if join_path(path, name, &child_path[0] as &byte, PATH_MAX) != 0 ||
            recursive_remove_path(&child_path[0] as &byte) != 0 {
            _ = closedir(dir);
            return -1;
        }
        entry_dir = readdir(dir);
    }
    _ = closedir(dir);
    if remove(path as &const byte) != 0 {
        return -1;
    }
    return 0;
}

fn build_action_workspace_root(ctx: &Phase2Context, action: &PlannedAction, out: &byte, out_cap: usize) i32 {
    if ctx == null || action == null || out == null {
        return -1;
    }
    var parent_path: [byte: PATH_MAX] = [];
    if path_dirname_text(ctx.phase1.workspace_root, &parent_path[0] as &byte, PATH_MAX) != 0 {
        return -1;
    }
    const written: i32 = snprintf(out as *byte,
                                  out_cap,
                                  "%s/.uyabuild-action-%s-%d" as *byte,
                                  &parent_path[0] as *byte,
                                  &ctx.manifest.run_id[0] as *byte,
                                  action.order_index);
    if written < 0 || written >= out_cap as i32 {
        return -1;
    }
    return 0;
}

fn build_action_log_paths(ctx: &Phase2Context,
                          action: &PlannedAction,
                          stdout_out: &byte,
                          stderr_out: &byte,
                          stdout_cap: usize,
                          stderr_cap: usize) i32 {
    if ctx == null || action == null || stdout_out == null || stderr_out == null {
        return -1;
    }
    var action_tmp_root: [byte: PATH_MAX] = [];
    var run_root: [byte: PATH_MAX] = [];
    if join_path(&ctx.state_layout.tmp[0] as &byte, "actions" as &byte, &action_tmp_root[0] as &byte, PATH_MAX) != 0 ||
        ensure_dir_recursive(&action_tmp_root[0] as &byte) != 0 ||
        join_path(&action_tmp_root[0] as &byte, &ctx.manifest.run_id[0] as &byte, &run_root[0] as &byte, PATH_MAX) != 0 ||
        ensure_dir_recursive(&run_root[0] as &byte) != 0 {
        return -1;
    }
    var action_root: [byte: PATH_MAX] = [];
    if join_path(&run_root[0] as &byte, action.action_key, &action_root[0] as &byte, PATH_MAX) != 0 ||
        ensure_dir_recursive(&action_root[0] as &byte) != 0 {
        return -1;
    }
    if join_path(&action_root[0] as &byte, "stdout.log" as &byte, stdout_out, stdout_cap) != 0 ||
        join_path(&action_root[0] as &byte, "stderr.log" as &byte, stderr_out, stderr_cap) != 0 {
        return -1;
    }
    return 0;
}

fn materialize_workspace_rel_path(ctx: &Phase2Context,
                                  rel_path: &byte,
                                  action_root: &byte,
                                  must_exist: i32) i32 {
    if ctx == null || rel_path == null || action_root == null {
        return -1;
    }
    var source_abs: [byte: PATH_MAX] = [];
    var dest_abs: [byte: PATH_MAX] = [];
    if join_and_normalize_path(ctx.phase1.workspace_root, rel_path, &source_abs[0] as &byte, PATH_MAX) != 0 ||
        join_path(action_root, rel_path, &dest_abs[0] as &byte, PATH_MAX) != 0 {
        return -1;
    }
    if path_is_file(&source_abs[0] as &byte) == 0 && path_is_dir(&source_abs[0] as &byte) == 0 {
        if must_exist != 0 {
            return -1;
        }
        return 0;
    }
    return copy_path_recursive(ctx.phase1, &source_abs[0] as &byte, &dest_abs[0] as &byte);
}

fn materialize_action_workspace(ctx: &Phase2Context, action: &PlannedAction, action_root: &byte) i32 {
    if ctx == null || action == null || action_root == null {
        return -1;
    }
    var input: &StringNode = action.input_head;
    while input != null {
        if materialize_workspace_rel_path(ctx, input.text, action_root, 1) != 0 {
            return -1;
        }
        input = input.next;
    }
    var dep: &StringNode = action.dep_head;
    while dep != null {
        const dep_action: &PlannedAction = find_planned_action_by_label(ctx, dep.text);
        if dep_action != null {
            var dep_output: &StringNode = dep_action.output_head;
            while dep_output != null {
                if materialize_workspace_rel_path(ctx, dep_output.text, action_root, 0) != 0 {
                    return -1;
                }
                dep_output = dep_output.next;
            }
        }
        dep = dep.next;
    }
    return 0;
}

fn append_env_name(names: [&byte: MAX_ARGS], count: &i32, name: &byte) i32 {
    if count == null || name == null || name[0] == 0 as byte {
        return -1;
    }
    var i: i32 = 0;
    while i < count[0] {
        const idx: usize = i32_to_usize_checked(i);
        if idx >= MAX_ARGS as usize {
            return -1;
        }
        if string_equals(names[idx], name) != 0 {
            return 0;
        }
        i = i + 1;
    }
    if count[0] >= MAX_ARGS - 1 {
        return -1;
    }
    const out_index: usize = i32_to_usize_checked(count[0]);
    if out_index >= MAX_ARGS as usize {
        return -1;
    }
    names[out_index] = name;
    count[0] = count[0] + 1;
    return 0;
}

fn append_env_entry(ctx: &Phase1Context,
                    env_out: [&byte: MAX_ARGS],
                    env_count: &i32,
                    name: &byte,
                    value: &byte) i32 {
    if ctx == null || env_count == null || name == null || value == null {
        return -1;
    }
    if env_count[0] >= MAX_ARGS - 1 {
        return -1;
    }
    const name_len: usize = strlen(name);
    const value_len: usize = strlen(value);
    const entry: &byte = arena_alloc_zero(&ctx.arena, name_len + 1usize + value_len + 1usize);
    if entry == null {
        return -1;
    }
    if name_len > 0 {
        memcpy(entry, name, name_len);
    }
    const sep_ptr: &byte = entry + name_len;
    sep_ptr[0] = 61 as byte;
    if value_len > 0 {
        memcpy(entry + name_len + 1usize, value, value_len);
    }
    const tail_ptr: &byte = entry + name_len + 1usize + value_len;
    tail_ptr[0] = 0 as byte;
    const out_index: usize = i32_to_usize_checked(env_count[0]);
    if out_index >= MAX_ARGS as usize {
        return -1;
    }
    env_out[out_index] = entry;
    env_count[0] = env_count[0] + 1;
    return 0;
}

fn build_action_exec_env(ctx: &Phase2Context,
                         action: &PlannedAction,
                         action_root: &byte,
                         env_out: [&byte: MAX_ARGS],
                         env_count: &i32) i32 {
    if ctx == null || action == null || action_root == null || env_count == null {
        return -1;
    }
    env_count[0] = 0;
    var names: [&byte: MAX_ARGS] = [];
    var name_count: i32 = 0;
    if append_env_name(names, &name_count, "PATH" as &byte) != 0 ||
        append_env_name(names, &name_count, "HOME" as &byte) != 0 ||
        append_env_name(names, &name_count, "TMPDIR" as &byte) != 0 ||
        append_env_name(names, &name_count, "TMP" as &byte) != 0 ||
        append_env_name(names, &name_count, "TEMP" as &byte) != 0 ||
        append_env_name(names, &name_count, "USER" as &byte) != 0 ||
        append_env_name(names, &name_count, "LOGNAME" as &byte) != 0 ||
        append_env_name(names, &name_count, "LANG" as &byte) != 0 ||
        append_env_name(names, &name_count, "LC_ALL" as &byte) != 0 ||
        append_env_name(names, &name_count, "SHELL" as &byte) != 0 ||
        append_env_name(names, &name_count, "UYA_BOOTSTRAP" as &byte) != 0 ||
        append_env_name(names, &name_count, "UYA_BUILD_FLAGS" as &byte) != 0 {
        return -1;
    }

    const allow_field: &IRField = find_ir_field(action.owner.attrs, "env_allowlist" as &byte);
    if allow_field != null && allow_field.value != null && allow_field.value.kind == TYPED_VALUE_LIST {
        var allow_item: &StringNode = collect_typed_strings_sorted(ctx.phase1, allow_field.value, null);
        while allow_item != null {
            if append_env_name(names, &name_count, allow_item.text) != 0 {
                return -1;
            }
            allow_item = allow_item.next;
        }
    }

    var i: i32 = 0;
    while i < name_count {
        const name_index: usize = i32_to_usize_checked(i);
        if name_index >= MAX_ARGS as usize {
            return -1;
        }
        const current_value: &byte = getenv(names[name_index] as &const byte);
        if current_value != null && append_env_entry(ctx.phase1, env_out, env_count, names[name_index], current_value) != 0 {
            return -1;
        }
        i = i + 1;
    }
    if append_env_entry(ctx.phase1, env_out, env_count, "PWD" as &byte, action_root) != 0 {
        return -1;
    }
    const tail_index: usize = i32_to_usize_checked(env_count[0]);
    if tail_index >= MAX_ARGS as usize {
        return -1;
    }
    env_out[tail_index] = null;
    return 0;
}

fn commit_action_outputs(ctx: &Phase2Context, action: &PlannedAction, action_root: &byte) i32 {
    if ctx == null || action == null || action_root == null {
        return -1;
    }
    var output: &StringNode = action.output_head;
    while output != null {
        var staged_abs: [byte: PATH_MAX] = [];
        if join_path(action_root, output.text, &staged_abs[0] as &byte, PATH_MAX) != 0 {
            return -1;
        }
        if path_is_file(&staged_abs[0] as &byte) == 0 && path_is_dir(&staged_abs[0] as &byte) == 0 {
            return -1;
        }
        output = output.next;
    }

    output = action.output_head;
    while output != null {
        var staged_abs: [byte: PATH_MAX] = [];
        var final_abs: [byte: PATH_MAX] = [];
        var final_parent: [byte: PATH_MAX] = [];
        if join_path(action_root, output.text, &staged_abs[0] as &byte, PATH_MAX) != 0 ||
            join_and_normalize_path(ctx.phase1.workspace_root, output.text, &final_abs[0] as &byte, PATH_MAX) != 0 ||
            path_dirname_text(&final_abs[0] as &byte, &final_parent[0] as &byte, PATH_MAX) != 0 ||
            ensure_dir_recursive(&final_parent[0] as &byte) != 0 {
            return -1;
        }
        if path_is_file(&final_abs[0] as &byte) != 0 || path_is_dir(&final_abs[0] as &byte) != 0 {
            if recursive_remove_path(&final_abs[0] as &byte) != 0 {
                return -1;
            }
        }
        if rename(&staged_abs[0] as &const byte, &final_abs[0] as &const byte) != 0 {
            if copy_path_recursive(ctx.phase1, &staged_abs[0] as &byte, &final_abs[0] as &byte) != 0 ||
                recursive_remove_path(&staged_abs[0] as &byte) != 0 {
                return -1;
            }
        }
        output = output.next;
    }
    return 0;
}

fn action_supports_local_executor(action: &PlannedAction) i32 {
    if action == null {
        return 0;
    }
    if string_equals(action.kind, "legacy.shell" as &byte) != 0 ||
        string_equals(action.kind, "task" as &byte) != 0 {
        return 1;
    }
    return 0;
}

fn execute_local_action(ctx: &Phase2Context, action: &PlannedAction) i32 {
    if ctx == null || action == null {
        return -1;
    }
    var action_root: [byte: PATH_MAX] = [];
    var stdout_path: [byte: PATH_MAX] = [];
    var stderr_path: [byte: PATH_MAX] = [];
    if build_action_workspace_root(ctx, action, &action_root[0] as &byte, PATH_MAX) != 0 ||
        build_action_log_paths(ctx,
                               action,
                               &stdout_path[0] as &byte,
                               &stderr_path[0] as &byte,
                               PATH_MAX,
                               PATH_MAX) != 0 {
        return set_action_diagnostic(ctx,
                                     action,
                                     EXIT_IO,
                                     "UYABUILD_E_EXECUTOR_SETUP" as &byte,
                                     "failed to prepare local executor directories" as &byte,
                                     "check temporary directory permissions and path lengths" as &byte);
    }
    if path_is_file(&action_root[0] as &byte) != 0 || path_is_dir(&action_root[0] as &byte) != 0 {
        if recursive_remove_path(&action_root[0] as &byte) != 0 {
            return set_action_diagnostic(ctx,
                                         action,
                                         EXIT_IO,
                                         "UYABUILD_E_EXECUTOR_SETUP" as &byte,
                                         "failed to clear a stale local executor workspace" as &byte,
                                         &action_root[0] as &byte);
        }
    }
    if ensure_dir_recursive(&action_root[0] as &byte) != 0 ||
        materialize_action_workspace(ctx, action, &action_root[0] as &byte) != 0 {
        return set_action_diagnostic(ctx,
                                     action,
                                     EXIT_IO,
                                     "UYABUILD_E_ACTION_MATERIALIZE" as &byte,
                                     "failed to materialize the action workspace" as &byte,
                                     action.label);
    }
    const command_text: &byte = build_action_shell_command(ctx.phase1,
                                                           action,
                                                           &stdout_path[0] as &byte,
                                                           &stderr_path[0] as &byte);
    if command_text == null {
        return set_action_diagnostic(ctx,
                                     action,
                                     EXIT_CONFIG,
                                     "UYABUILD_E_ACTION_COMMAND" as &byte,
                                     "failed to serialize the action command line" as &byte,
                                     action.label);
    }

    var envp: [&byte: MAX_ARGS] = [];
    var env_count: i32 = 0;
    if build_action_exec_env(ctx, action, &action_root[0] as &byte, envp, &env_count) != 0 {
        return set_action_diagnostic(ctx,
                                     action,
                                     EXIT_IO,
                                     "UYABUILD_E_EXECUTOR_ENV" as &byte,
                                     "failed to build the action environment whitelist" as &byte,
                                     action.label);
    }

    const shell_path: &byte = "/bin/sh" as &byte;
    var exec_args: [&byte: 4] = [shell_path, "-c" as &byte, command_text, null];
    const child_pid: i32 = fork();
    if child_pid < 0 {
        return set_action_diagnostic(ctx,
                                     action,
                                     EXIT_IO,
                                     "UYABUILD_E_EXECUTOR_FORK" as &byte,
                                     "failed to fork the local executor child" as &byte,
                                     action.label);
    }
    if child_pid == 0 {
        if chdir(&action_root[0] as &const byte) != 0 {
            _exit(127);
        }
        execve(shell_path as &const byte, &exec_args[0] as & &byte, &envp[0] as & &byte);
        _exit(127);
    }

    action.stdout_path = arena_copy_cstr(&ctx.phase1.arena, &stdout_path[0] as &byte);
    action.stderr_path = arena_copy_cstr(&ctx.phase1.arena, &stderr_path[0] as &byte);

    var wait_status: i32 = 0;
    if waitpid(child_pid, &wait_status, 0) < 0 {
        action.cache_status = "execution-failed" as &byte;
        action.pending_execution = 0;
        action.exit_code = 127;
        if ctx.pending_count > 0 {
            ctx.pending_count = ctx.pending_count - 1;
        }
        return set_action_diagnostic(ctx,
                                     action,
                                     EXIT_IO,
                                     "UYABUILD_E_EXECUTOR_WAIT" as &byte,
                                     "failed to collect the local executor result" as &byte,
                                     action.label);
    }

    action.exit_code = wait_status_exit_code(wait_status);
    action.pending_execution = 0;
    if ctx.pending_count > 0 {
        ctx.pending_count = ctx.pending_count - 1;
    }
    if action.exit_code != 0 {
        action.cache_status = "execution-failed" as &byte;
        var detail_buf: [byte: PATH_MAX] = [];
        _ = snprintf(&detail_buf[0] as *byte,
                     PATH_MAX,
                     "%s exited with status %d; see %s" as *byte,
                     action.label as *byte,
                     action.exit_code,
                     &stderr_path[0] as *byte);
        return set_action_diagnostic(ctx,
                                     action,
                                     EXIT_ACTION,
                                     "UYABUILD_E_ACTION_FAILED" as &byte,
                                     "build action exited with a non-zero status" as &byte,
                                     arena_copy_cstr(&ctx.phase1.arena, &detail_buf[0] as &byte));
    }

    if commit_action_outputs(ctx, action, &action_root[0] as &byte) != 0 {
        action.cache_status = "execution-failed" as &byte;
        return set_action_diagnostic(ctx,
                                     action,
                                     EXIT_ACTION,
                                     "UYABUILD_E_OUTPUT_COMMIT" as &byte,
                                     "action completed but declared outputs could not be committed" as &byte,
                                     action.label);
    }
    action.output_root_digest = action_collect_observed_outputs(ctx, action);
    if action.output_head != null && action.output_root_digest == null {
        action.cache_status = "execution-failed" as &byte;
        return set_action_diagnostic(ctx,
                                     action,
                                     EXIT_ACTION,
                                     "UYABUILD_E_OUTPUT_MISSING" as &byte,
                                     "action completed without producing every declared output" as &byte,
                                     action.label);
    }
    action.cache_status = "executed-local" as &byte;
    _ = recursive_remove_path(&action_root[0] as &byte);
    return 0;
}

fn execute_pending_actions(ctx: &Phase2Context) i32 {
    if ctx == null {
        return -1;
    }
    var action: &PlannedAction = ctx.action_head;
    while action != null {
        if action.pending_execution != 0 {
            if action_supports_local_executor(action) == 0 {
                return set_action_diagnostic(ctx,
                                             action,
                                             EXIT_NOT_IMPLEMENTED,
                                             "UYABUILD_E_EXECUTOR_UNSUPPORTED" as &byte,
                                             "the local executor does not yet support this action kind" as &byte,
                                             action.kind);
            }
            if execute_local_action(ctx, action) != 0 {
                return -1;
            }
        }
        action = action.next;
    }
    return 0;
}

fn snapshot_store_blob(ctx: &Phase2Context, digest_hex: &byte, data: &byte, data_len: usize) i32 {
    var path: [byte: PATH_MAX] = [];
    if join_path(&ctx.state_layout.cas_blobs[0] as &byte, digest_hex, &path[0] as &byte, PATH_MAX) != 0 {
        return -1;
    }
    return persist_bytes(&path[0] as &byte, data, data_len);
}

fn snapshot_store_tree_json(ctx: &Phase2Context, digest_hex: &byte, text: &byte) i32 {
    var path: [byte: PATH_MAX] = [];
    if join_path(&ctx.state_layout.cas_trees[0] as &byte, digest_hex, &path[0] as &byte, PATH_MAX) != 0 {
        return -1;
    }
    return persist_text(&path[0] as &byte, text);
}

fn action_store_manifest_json(ctx: &Phase2Context, digest_hex: &byte, text: &byte) i32 {
    var path: [byte: PATH_MAX] = [];
    if join_path(&ctx.state_layout.cas_manifests[0] as &byte, digest_hex, &path[0] as &byte, PATH_MAX) != 0 {
        return -1;
    }
    return persist_text(&path[0] as &byte, text);
}

fn snapshot_file(ctx: &Phase2Context, abs_path: &byte, rel_path: &byte) &SnapshotEntry {
    const existing: &SnapshotEntry = find_snapshot_entry(ctx, rel_path, SNAPSHOT_FILE);
    if existing != null {
        return existing;
    }

    var size_out: usize = 0usize;
    const content: &byte = read_file_into_arena(ctx.phase1, abs_path, &size_out);
    if content == null {
        _ = set_diagnostic(ctx.phase1,
                           EXIT_IO,
                           "UYABUILD_E_INPUT_READ" as &byte,
                           "failed to read declared input" as &byte,
                           rel_path,
                           rel_path,
                           0,
                           0);
        return null;
    }

    const content_digest: &byte = blake2s_hex_bytes(ctx.phase1, content, size_out);
    if content_digest == null {
        return null;
    }

    var manifest: [byte: MAX_DIGEST_MANIFEST] = [];
    var used: usize = 0usize;
    var size_buf: [byte: 64] = [];
    _ = snprintf(&size_buf[0] as *byte, 64usize, "%zu" as *byte, size_out);
    if append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, "file\n" as &byte) != 0 ||
        append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, rel_path) != 0 ||
        append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, "\n" as &byte) != 0 ||
        append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, content_digest) != 0 ||
        append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, "\n" as &byte) != 0 ||
        append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, &size_buf[0] as &byte) != 0 {
        return null;
    }

    const digest_hex: &byte = blake2s_hex_bytes(ctx.phase1, &manifest[0] as &byte, used);
    if digest_hex == null {
        return null;
    }

    const entry: &SnapshotEntry = new_snapshot_entry(ctx.phase1);
    if entry == null {
        return null;
    }
    entry.rel_path = arena_copy_cstr(&ctx.phase1.arena, rel_path);
    entry.abs_path = arena_copy_cstr(&ctx.phase1.arena, abs_path);
    entry.kind = SNAPSHOT_FILE;
    entry.digest_hex = digest_hex;
    entry.content_digest_hex = content_digest;
    entry.size = size_out;
    entry.next = ctx.snapshot_head;
    ctx.snapshot_head = entry;
    ctx.snapshot_count = ctx.snapshot_count + 1;

    _ = snapshot_store_blob(ctx, content_digest, content, size_out);
    _ = snapshot_store_tree_json(ctx, digest_hex, &manifest[0] as &byte);
    return entry;
}

fn snapshot_directory(ctx: &Phase2Context, abs_path: &byte, rel_path: &byte) &SnapshotEntry {
    const existing: &SnapshotEntry = find_snapshot_entry(ctx, rel_path, SNAPSHOT_DIR);
    if existing != null {
        return existing;
    }

    const dir: &DIR = opendir(abs_path as &const byte);
    if dir == null {
        _ = set_diagnostic(ctx.phase1,
                           EXIT_IO,
                           "UYABUILD_E_INPUT_READ" as &byte,
                           "failed to open declared input directory" as &byte,
                           rel_path,
                           rel_path,
                           0,
                           0);
        return null;
    }

    var children: &TreeChild = null;
    var child_count: i32 = 0;
    var entry_dir: &Dirent = readdir(dir);
    while entry_dir != null {
        const name: &byte = &entry_dir.d_name[0] as &byte;
        if is_dirent_dot(name) != 0 || should_skip_snapshot_name(name) != 0 {
            entry_dir = readdir(dir);
            continue;
        }

        var child_abs: [byte: PATH_MAX] = [];
        var child_rel: [byte: PATH_MAX] = [];
        if join_path(abs_path, name, &child_abs[0] as &byte, PATH_MAX) != 0 ||
            join_path(rel_path, name, &child_rel[0] as &byte, PATH_MAX) != 0 {
            _ = closedir(dir);
            return null;
        }

        var child_snapshot: &SnapshotEntry = null;
        var child_kind: i32 = 0;
        if dirent_is_directory(entry_dir, &child_abs[0] as &byte) != 0 {
            child_kind = SNAPSHOT_DIR;
            child_snapshot = snapshot_directory(ctx, &child_abs[0] as &byte, &child_rel[0] as &byte);
        } else if dirent_is_regular_file(entry_dir, &child_abs[0] as &byte) != 0 {
            child_kind = SNAPSHOT_FILE;
            child_snapshot = snapshot_file(ctx, &child_abs[0] as &byte, &child_rel[0] as &byte);
        }
        if child_snapshot == null {
            _ = closedir(dir);
            return null;
        }

        children = insert_tree_child_sorted(ctx.phase1, children, name, child_kind, child_snapshot.digest_hex);
        child_count = child_count + 1;
        entry_dir = readdir(dir);
    }
    _ = closedir(dir);

    var manifest: [byte: MAX_DIGEST_MANIFEST] = [];
    var used: usize = 0usize;
    if append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, "dir\n" as &byte) != 0 ||
        append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, rel_path) != 0 ||
        append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, "\n" as &byte) != 0 {
        return null;
    }
    var child: &TreeChild = children;
    while child != null {
        if append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, child.name) != 0 ||
            append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, ":" as &byte) != 0 ||
            append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, child.digest_hex) != 0 ||
            append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, "\n" as &byte) != 0 {
            return null;
        }
        child = child.next;
    }

    const digest_hex: &byte = blake2s_hex_bytes(ctx.phase1, &manifest[0] as &byte, used);
    if digest_hex == null {
        return null;
    }

    const snapshot: &SnapshotEntry = new_snapshot_entry(ctx.phase1);
    if snapshot == null {
        return null;
    }
    snapshot.rel_path = arena_copy_cstr(&ctx.phase1.arena, rel_path);
    snapshot.abs_path = arena_copy_cstr(&ctx.phase1.arena, abs_path);
    snapshot.kind = SNAPSHOT_DIR;
    snapshot.digest_hex = digest_hex;
    snapshot.content_digest_hex = digest_hex;
    snapshot.size = i32_to_usize_checked(child_count);
    snapshot.next = ctx.snapshot_head;
    ctx.snapshot_head = snapshot;
    ctx.snapshot_count = ctx.snapshot_count + 1;

    _ = snapshot_store_tree_json(ctx, digest_hex, &manifest[0] as &byte);
    return snapshot;
}

fn snapshot_workspace_path(ctx: &Phase2Context, rel_path: &byte, must_exist: i32) &SnapshotEntry {
    var abs_path: [byte: PATH_MAX] = [];
    if join_and_normalize_path(ctx.phase1.workspace_root, rel_path, &abs_path[0] as &byte, PATH_MAX) != 0 {
        return null;
    }
    if path_is_file(&abs_path[0] as &byte) != 0 {
        return snapshot_file(ctx, &abs_path[0] as &byte, rel_path);
    }
    if path_is_dir(&abs_path[0] as &byte) != 0 {
        return snapshot_directory(ctx, &abs_path[0] as &byte, rel_path);
    }
    if must_exist != 0 {
        _ = set_diagnostic(ctx.phase1,
                           EXIT_IO,
                           "UYABUILD_E_INPUT_MISSING" as &byte,
                           "declared input path does not exist" as &byte,
                           rel_path,
                           rel_path,
                           0,
                           0);
    }
    return null;
}

fn action_collect_observed_outputs(ctx: &Phase2Context, action: &PlannedAction) &byte {
    if action.output_head == null {
        return null;
    }
    var manifest: [byte: MAX_DIGEST_MANIFEST] = [];
    var used: usize = 0usize;
    if append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, "outputs\n" as &byte) != 0 {
        return null;
    }
    var output: &StringNode = action.output_head;
    while output != null {
        const snapshot: &SnapshotEntry = snapshot_workspace_path(ctx, output.text, 0);
        if snapshot == null {
            return null;
        }
        if append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, output.text) != 0 ||
            append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, ":" as &byte) != 0 ||
            append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, snapshot.digest_hex) != 0 ||
            append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, "\n" as &byte) != 0 {
            return null;
        }
        output = output.next;
    }
    return blake2s_hex_bytes(ctx.phase1, &manifest[0] as &byte, used);
}

fn collect_target_dependencies(ctx: &Phase1Context, target: &IRTarget) &StringNode {
    var deps: &StringNode = null;
    const deps_field: &IRField = find_ir_field(target.attrs, "deps" as &byte);
    if deps_field != null {
        deps = collect_typed_labels_sorted(ctx, deps_field.value, deps);
    }
    if string_equals(target.kind, "node.app" as &byte) != 0 {
        const workspace_field: &IRField = find_ir_field(target.attrs, "workspace" as &byte);
        if workspace_field != null {
            deps = collect_typed_labels_sorted(ctx, workspace_field.value, deps);
        }
    }
    return deps;
}

fn action_add_input_spec(ctx: &Phase2Context, action: &PlannedAction, target: &IRTarget, raw: &byte) i32 {
    if string_has_wildcard(raw) != 0 {
        var matched_count: i32 = 0;
        var matches: &StringNode = collect_glob_matches(ctx.phase1, target.file.dir_abs, raw, &matched_count);
        if matched_count == 0 {
            _ = set_diagnostic(ctx.phase1,
                               EXIT_CONFIG,
                               "UYABUILD_E_INPUT_GLOB_EMPTY" as &byte,
                               "declared input glob matched nothing" as &byte,
                               raw,
                               target.file.rel_path,
                               target.span.start.line,
                               target.span.start.column);
            return -1;
        }
        while matches != null {
            var rel: [byte: PATH_MAX] = [];
            var abs: [byte: PATH_MAX] = [];
            if resolve_target_path(ctx.phase1, target, matches.text, &rel[0] as &byte, &abs[0] as &byte) != 0 {
                return -1;
            }
            action_insert_input(ctx.phase1, action, &rel[0] as &byte);
            matches = matches.next;
        }
        return 0;
    }

    var rel_out: [byte: PATH_MAX] = [];
    var abs_out: [byte: PATH_MAX] = [];
    if resolve_target_path(ctx.phase1, target, raw, &rel_out[0] as &byte, &abs_out[0] as &byte) != 0 {
        return -1;
    }
    action_insert_input(ctx.phase1, action, &rel_out[0] as &byte);
    return 0;
}

fn action_add_output_path(ctx: &Phase1Context, action: &PlannedAction, target: &IRTarget, raw: &byte) i32 {
    var rel_out: [byte: PATH_MAX] = [];
    var abs_out: [byte: PATH_MAX] = [];
    if resolve_target_path(ctx, target, raw, &rel_out[0] as &byte, &abs_out[0] as &byte) != 0 {
        return -1;
    }
    action_insert_output(ctx, action, &rel_out[0] as &byte);
    return 0;
}

fn action_add_placeholder_output(ctx: &Phase1Context, action: &PlannedAction, target: &IRTarget, suffix: &byte) i32 {
    var raw: [byte: PATH_MAX] = [];
    if target.package_path != null && target.package_path[0] != 0 as byte {
        _ = snprintf(&raw[0] as *byte,
                     PATH_MAX,
                     "out/%s/%s%s" as *byte,
                     target.package_path as *byte,
                     target.name as *byte,
                     suffix as *byte);
    } else {
        _ = snprintf(&raw[0] as *byte,
                     PATH_MAX,
                     "out/%s%s" as *byte,
                     target.name as *byte,
                     suffix as *byte);
    }
    return action_add_output_path(ctx, action, target, &raw[0] as &byte);
}

fn populate_planned_action(ctx: &Phase2Context, action: &PlannedAction, target: &IRTarget) i32 {
    action.owner = target;
    action.label = target.label;
    action.kind = target.kind;
    action.mnemonic = target.kind;
    action.cache_status = "pending-execution" as &byte;
    action.pending_execution = 1;

    var deps: &StringNode = collect_target_dependencies(ctx.phase1, target);
    while deps != null {
        action_insert_dep(ctx.phase1, action, deps.text);
        deps = deps.next;
    }

    if string_equals(target.kind, "legacy.shell" as &byte) != 0 ||
        string_equals(target.kind, "task" as &byte) != 0 {
        const command_field: &IRField = find_ir_field(target.attrs, "script" as &byte);
        var effective_field: &IRField = command_field;
        if effective_field == null {
            effective_field = find_ir_field(target.attrs, "run" as &byte);
        }
        if effective_field != null && effective_field.value != null && effective_field.value.kind == TYPED_VALUE_LIST {
            var arg: &TypedValueItem = effective_field.value.list_head;
            while arg != null {
                if arg.value != null && arg.value.text != null {
                    if action_append_command(ctx.phase1, action, arg.value.text) != 0 {
                        return -1;
                    }
                }
                arg = arg.next;
            }
        }
        const inputs_field: &IRField = find_ir_field(target.attrs, "inputs" as &byte);
        if inputs_field != null {
            var inputs: &StringNode = collect_typed_strings_sorted(ctx.phase1, inputs_field.value, null);
            while inputs != null {
                if action_add_input_spec(ctx, action, target, inputs.text) != 0 {
                    return -1;
                }
                inputs = inputs.next;
            }
        }
        const outputs_field: &IRField = find_ir_field(target.attrs, "outputs" as &byte);
        if outputs_field != null {
            var outputs: &StringNode = collect_typed_strings_sorted(ctx.phase1, outputs_field.value, null);
            while outputs != null {
                if action_add_output_path(ctx.phase1, action, target, outputs.text) != 0 {
                    return -1;
                }
                outputs = outputs.next;
            }
        }
        return 0;
    }

    if string_equals(target.kind, "cxx.library" as &byte) != 0 {
        _ = action_append_command(ctx.phase1, action, "uya-cxx-archive" as &byte);
        _ = action_append_command(ctx.phase1, action, target.label);
        const srcs_field: &IRField = find_ir_field(target.attrs, "srcs" as &byte);
        const hdrs_field: &IRField = find_ir_field(target.attrs, "hdrs" as &byte);
        var inputs: &StringNode = null;
        if srcs_field != null { inputs = collect_typed_strings_sorted(ctx.phase1, srcs_field.value, inputs); }
        if hdrs_field != null { inputs = collect_typed_strings_sorted(ctx.phase1, hdrs_field.value, inputs); }
        while inputs != null {
            if action_add_input_spec(ctx, action, target, inputs.text) != 0 {
                return -1;
            }
            inputs = inputs.next;
        }
        return action_add_placeholder_output(ctx.phase1, action, target, ".a" as &byte);
    }

    if string_equals(target.kind, "cxx.binary" as &byte) != 0 {
        _ = action_append_command(ctx.phase1, action, "uya-cxx-link" as &byte);
        _ = action_append_command(ctx.phase1, action, target.label);
        const srcs_field: &IRField = find_ir_field(target.attrs, "srcs" as &byte);
        if srcs_field != null {
            var inputs: &StringNode = collect_typed_strings_sorted(ctx.phase1, srcs_field.value, null);
            while inputs != null {
                if action_add_input_spec(ctx, action, target, inputs.text) != 0 {
                    return -1;
                }
                inputs = inputs.next;
            }
        }
        const out_field: &IRField = find_ir_field(target.attrs, "out" as &byte);
        if out_field != null && out_field.value != null && out_field.value.text != null {
            return action_add_output_path(ctx.phase1, action, target, out_field.value.text);
        }
        return action_add_placeholder_output(ctx.phase1, action, target, "" as &byte);
    }

    if string_equals(target.kind, "node.workspace" as &byte) != 0 {
        _ = action_append_command(ctx.phase1, action, "npm" as &byte);
        _ = action_append_command(ctx.phase1, action, "ci" as &byte);
        const root_field: &IRField = find_ir_field(target.attrs, "root" as &byte);
        const lock_field: &IRField = find_ir_field(target.attrs, "lockfile" as &byte);
        if root_field != null && root_field.value != null && root_field.value.text != null {
            if action_add_input_spec(ctx, action, target, root_field.value.text) != 0 {
                return -1;
            }
        }
        if lock_field != null && lock_field.value != null && lock_field.value.text != null {
            if action_add_input_spec(ctx, action, target, lock_field.value.text) != 0 {
                return -1;
            }
        }
        return action_add_placeholder_output(ctx.phase1, action, target, ".workspace.json" as &byte);
    }

    if string_equals(target.kind, "node.app" as &byte) != 0 {
        _ = action_append_command(ctx.phase1, action, "npm" as &byte);
        _ = action_append_command(ctx.phase1, action, "run" as &byte);
        _ = action_append_command(ctx.phase1, action, "build" as &byte);
        const package_field: &IRField = find_ir_field(target.attrs, "package" as &byte);
        if package_field != null && package_field.value != null && package_field.value.text != null {
            if action_add_input_spec(ctx, action, target, package_field.value.text) != 0 {
                return -1;
            }
        }
        const out_field: &IRField = find_ir_field(target.attrs, "out" as &byte);
        if out_field != null && out_field.value != null && out_field.value.text != null {
            return action_add_output_path(ctx.phase1, action, target, out_field.value.text);
        }
        return action_add_placeholder_output(ctx.phase1, action, target, ".app" as &byte);
    }

    if string_equals(target.kind, "oci.image" as &byte) != 0 {
        _ = action_append_command(ctx.phase1, action, "docker" as &byte);
        _ = action_append_command(ctx.phase1, action, "buildx" as &byte);
        _ = action_append_command(ctx.phase1, action, "build" as &byte);
        const dockerfile_field: &IRField = find_ir_field(target.attrs, "dockerfile" as &byte);
        const context_field: &IRField = find_ir_field(target.attrs, "context" as &byte);
        if dockerfile_field != null && dockerfile_field.value != null && dockerfile_field.value.text != null {
            if action_add_input_spec(ctx, action, target, dockerfile_field.value.text) != 0 {
                return -1;
            }
        }
        if context_field != null && context_field.value != null && context_field.value.text != null {
            if action_add_input_spec(ctx, action, target, context_field.value.text) != 0 {
                return -1;
            }
        }
        return action_add_placeholder_output(ctx.phase1, action, target, ".image.json" as &byte);
    }

    return 0;
}

fn compute_action_digests(ctx: &Phase2Context, action: &PlannedAction) i32 {
    var input_manifest: [byte: MAX_DIGEST_MANIFEST] = [];
    var input_used: usize = 0usize;
    if append_buffer_text(&input_manifest[0] as &byte, &input_used, MAX_DIGEST_MANIFEST, "inputs\n" as &byte) != 0 {
        return -1;
    }
    var input: &StringNode = action.input_head;
    while input != null {
        const snapshot: &SnapshotEntry = snapshot_workspace_path(ctx, input.text, 1);
        if snapshot == null {
            return -1;
        }
        if append_buffer_text(&input_manifest[0] as &byte, &input_used, MAX_DIGEST_MANIFEST, input.text) != 0 ||
            append_buffer_text(&input_manifest[0] as &byte, &input_used, MAX_DIGEST_MANIFEST, ":" as &byte) != 0 ||
            append_buffer_text(&input_manifest[0] as &byte, &input_used, MAX_DIGEST_MANIFEST, snapshot.digest_hex) != 0 ||
            append_buffer_text(&input_manifest[0] as &byte, &input_used, MAX_DIGEST_MANIFEST, "\n" as &byte) != 0 {
            return -1;
        }
        input = input.next;
    }
    action.input_root_digest = blake2s_hex_bytes(ctx.phase1, &input_manifest[0] as &byte, input_used);
    action.output_root_digest = action_collect_observed_outputs(ctx, action);

    var manifest: [byte: MAX_DIGEST_MANIFEST] = [];
    var used: usize = 0usize;
    if append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, "action\n" as &byte) != 0 ||
        append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, action.kind) != 0 ||
        append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, "\n" as &byte) != 0 ||
        append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, action.label) != 0 ||
        append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, "\n" as &byte) != 0 ||
        append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, action.input_root_digest) != 0 ||
        append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, "\n" as &byte) != 0 {
        return -1;
    }

    var dep: &StringNode = action.dep_head;
    while dep != null {
        const dep_action: &PlannedAction = find_planned_action_by_label(ctx, dep.text);
        if dep_action == null || dep_action.action_key == null {
            return -1;
        }
        var dep_digest: &byte = dep_action.action_key;
        var dep_mode: &byte = "action" as &byte;
        if dep_action.output_root_digest != null {
            dep_digest = dep_action.output_root_digest;
            dep_mode = "output" as &byte;
        }
        if append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, dep.text) != 0 ||
            append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, ":" as &byte) != 0 ||
            append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, dep_mode) != 0 ||
            append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, ":" as &byte) != 0 ||
            append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, dep_digest) != 0 ||
            append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, "\n" as &byte) != 0 {
            return -1;
        }
        dep = dep.next;
    }

    var output: &StringNode = action.output_head;
    while output != null {
        if append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, output.text) != 0 ||
            append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, "\n" as &byte) != 0 {
            return -1;
        }
        output = output.next;
    }

    var command: &StringNode = action.command_head;
    while command != null {
        if append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, command.text) != 0 ||
            append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, "\n" as &byte) != 0 {
            return -1;
        }
        command = command.next;
    }

    action.action_key = blake2s_hex_bytes(ctx.phase1, &manifest[0] as &byte, used);
    if action.action_key == null {
        return -1;
    }
    var cached_output_digest: [byte: DIGEST_HEX_BYTES + 1usize] = [];
    var previous_output_digest: [byte: DIGEST_HEX_BYTES + 1usize] = [];
    if action.output_root_digest != null {
        if read_cache_output_digest(ctx, action.action_key, &cached_output_digest[0] as &byte, DIGEST_HEX_BYTES + 1usize) == 0 &&
            string_equals(&cached_output_digest[0] as &byte, action.output_root_digest) != 0 {
            action.cache_status = "local-hit" as &byte;
            action.pending_execution = 0;
            ctx.cache_hit_count = ctx.cache_hit_count + 1;
        } else if read_latest_owner_output_digest(ctx,
                                                  action.label,
                                                  &previous_output_digest[0] as &byte,
                                                  DIGEST_HEX_BYTES + 1usize) == 0 &&
            string_equals(&previous_output_digest[0] as &byte, action.output_root_digest) != 0 {
            action.cache_status = "success-no-change" as &byte;
            action.pending_execution = 0;
            ctx.no_change_count = ctx.no_change_count + 1;
        } else {
            action.cache_status = "seeded-output" as &byte;
            action.pending_execution = 0;
            ctx.seeded_count = ctx.seeded_count + 1;
        }
    } else {
        action.cache_status = "pending-execution" as &byte;
        action.pending_execution = 1;
        ctx.pending_count = ctx.pending_count + 1;
    }
    _ = action_store_manifest_json(ctx, action.action_key, &manifest[0] as &byte);
    return 0;
}

fn plan_target_recursive(ctx: &Phase2Context, label: &byte) i32 {
    var mark: &VisitMark = find_visit_mark(ctx, label);
    if mark != null {
        if mark.state == VISIT_STATE_DONE {
            return 0;
        }
        if mark.state == VISIT_STATE_VISITING {
            return phase1_error(ctx.phase1,
                                "UYABUILD_E_TARGET_CYCLE" as &byte,
                                "target dependency cycle detected" as &byte,
                                label,
                                "uya.build" as &byte,
                                1,
                                1);
        }
    } else {
        mark = new_visit_mark(ctx.phase1);
        if mark == null {
            return -1;
        }
        mark.label = arena_copy_cstr(&ctx.phase1.arena, label);
        mark.state = VISIT_STATE_VISITING;
        mark.next = ctx.visit_head;
        ctx.visit_head = mark;
    }

    const target: &IRTarget = find_target_by_label(ctx.phase1, label);
    if target == null {
        return phase1_error(ctx.phase1,
                            "UYABUILD_E_TARGET_NOT_FOUND" as &byte,
                            "planned target was not found in the typed graph" as &byte,
                            label,
                            "uya.build" as &byte,
                            1,
                            1);
    }

    var deps: &StringNode = collect_target_dependencies(ctx.phase1, target);
    while deps != null {
        if plan_target_recursive(ctx, deps.text) != 0 {
            return -1;
        }
        deps = deps.next;
    }

    if find_planned_action_by_label(ctx, label) == null {
        const action: &PlannedAction = new_planned_action(ctx.phase1);
        if action == null {
            return -1;
        }
        if populate_planned_action(ctx, action, target) != 0 {
            return -1;
        }
        action.order_index = ctx.action_count;
        if compute_action_digests(ctx, action) != 0 {
            return -1;
        }
        if ctx.action_head == null {
            ctx.action_head = action;
            ctx.action_tail = action;
        } else {
            ctx.action_tail.next = action;
            ctx.action_tail = action;
        }
        ctx.action_count = ctx.action_count + 1;
    }

    mark.state = VISIT_STATE_DONE;
    return 0;
}

fn compute_plan_root_digest(ctx: &Phase2Context, matched: &StringNode) &byte {
    var manifest: [byte: MAX_DIGEST_MANIFEST] = [];
    var used: usize = 0usize;
    if append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, "plan\n" as &byte) != 0 {
        return null;
    }
    var node: &StringNode = matched;
    while node != null {
        if append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, node.text) != 0 ||
            append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, "\n" as &byte) != 0 {
            return null;
        }
        node = node.next;
    }
    var action: &PlannedAction = ctx.action_head;
    while action != null {
        if append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, action.label) != 0 ||
            append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, ":" as &byte) != 0 ||
            append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, action.action_key) != 0 ||
            append_buffer_text(&manifest[0] as &byte, &used, MAX_DIGEST_MANIFEST, "\n" as &byte) != 0 {
            return null;
        }
        action = action.next;
    }
    return blake2s_hex_bytes(ctx.phase1, &manifest[0] as &byte, used);
}

fn build_phase2_plan(ctx: &Phase2Context, matched: &StringNode) i32 {
    var node: &StringNode = matched;
    while node != null {
        if plan_target_recursive(ctx, node.text) != 0 {
            return -1;
        }
        node = node.next;
    }
    ctx.root_digest = compute_plan_root_digest(ctx, matched);
    if ctx.root_digest == null {
        return -1;
    }
    return 0;
}

fn extract_json_string_field(content: &byte, field_name: &byte, out: &byte, out_cap: usize) i32 {
    if content == null || field_name == null || out == null || out_cap == 0 {
        return -1;
    }
    var pattern: [byte: 128] = [];
    _ = snprintf(&pattern[0] as *byte, 128usize, "\"%s\":\"" as *byte, field_name as *byte);
    const pattern_len: usize = strlen(&pattern[0] as &byte);
    var pos: usize = 0usize;
    while content[pos] != 0 as byte {
        var matched: i32 = 1;
        var i: usize = 0usize;
        while i < pattern_len {
            if content[pos + i] == 0 as byte || content[pos + i] != pattern[i] {
                matched = 0;
                break;
            }
            i = i + 1usize;
        }
        if matched != 0 {
            var end: usize = pos + pattern_len;
            while content[end] != 0 as byte && content[end] != 34 as byte {
                end = end + 1usize;
            }
            const value_len: usize = end - (pos + pattern_len);
            if value_len + 1usize > out_cap {
                return -1;
            }
            memcpy(out, &content[pos + pattern_len] as &byte, value_len);
            out[value_len] = 0 as byte;
            return 0;
        }
        pos = pos + 1usize;
    }
    return -1;
}

fn extract_json_string_array_field(ctx: &Phase1Context,
                                   content: &byte,
                                   field_name: &byte,
                                   out: [&byte: MAX_ARGS],
                                   out_count: &i32) i32 {
    if ctx == null || content == null || field_name == null || out_count == null {
        return -1;
    }
    out_count[0] = 0;

    var pattern: [byte: 128] = [];
    _ = snprintf(&pattern[0] as *byte, 128usize, "\"%s\":[" as *byte, field_name as *byte);
    const pattern_len: usize = strlen(&pattern[0] as &byte);
    var pos: usize = 0usize;
    while content[pos] != 0 as byte {
        var matched: i32 = 1;
        var i: usize = 0usize;
        while i < pattern_len {
            if content[pos + i] == 0 as byte || content[pos + i] != pattern[i] {
                matched = 0;
                break;
            }
            i = i + 1usize;
        }
        if matched != 0 {
            pos = pos + pattern_len;
            while content[pos] != 0 as byte && content[pos] != 93 as byte {
                if content[pos] == 44 as byte {
                    pos = pos + 1usize;
                    continue;
                }
                if content[pos] != 34 as byte {
                    pos = pos + 1usize;
                    continue;
                }
                const start: usize = pos + 1usize;
                var end: usize = start;
                while content[end] != 0 as byte && content[end] != 34 as byte {
                    end = end + 1usize;
                }
                if content[end] != 34 as byte {
                    return -1;
                }
                if out_count[0] >= MAX_ARGS {
                    return -1;
                }
                const out_index: usize = i32_to_usize_checked(out_count[0]);
                if out_index >= MAX_ARGS as usize {
                    return -1;
                }
                out[out_index] = arena_copy_range(&ctx.arena, content, start, end - start);
                if out[out_index] == null {
                    return -1;
                }
                out_count[0] = out_count[0] + 1;
                pos = end + 1usize;
            }
            if content[pos] != 93 as byte {
                return -1;
            }
            return 0;
        }
        pos = pos + 1usize;
    }
    return -1;
}

fn is_reusable_action_status(status: &byte) i32 {
    if status == null {
        return 0;
    }
    if string_equals(status, "pending-execution" as &byte) != 0 ||
        string_equals(status, "execution-failed" as &byte) != 0 {
        return 0;
    }
    return 1;
}

fn build_index_entry_path(ctx: &Phase2Context, index_name: &byte, key: &byte, out: &byte, out_cap: usize) i32 {
    if ctx == null || index_name == null || key == null || out == null {
        return -1;
    }
    var dir_path: [byte: PATH_MAX] = [];
    if join_path(&ctx.state_layout.meta_indexes[0] as &byte, index_name, &dir_path[0] as &byte, PATH_MAX) != 0 {
        return -1;
    }
    if ensure_dir_recursive(&dir_path[0] as &byte) != 0 {
        return -1;
    }
    const key_digest: &byte = blake2s_hex_text(ctx.phase1, key);
    if key_digest == null {
        return -1;
    }
    return join_path(&dir_path[0] as &byte, key_digest, out, out_cap);
}

fn read_index_doc_ids(ctx: &Phase2Context,
                      index_name: &byte,
                      key: &byte,
                      out: [&byte: MAX_ARGS],
                      out_count: &i32) i32 {
    if ctx == null || out_count == null {
        return -1;
    }
    var path: [byte: PATH_MAX] = [];
    if build_index_entry_path(ctx, index_name, key, &path[0] as &byte, PATH_MAX) != 0 {
        return -1;
    }
    if path_is_file(&path[0] as &byte) == 0 {
        out_count[0] = 0;
        return -1;
    }
    var size_out: usize = 0usize;
    const content: &byte = read_file_into_arena(ctx.phase1, &path[0] as &byte, &size_out);
    _ = size_out;
    if content == null {
        return -1;
    }

    out_count[0] = 0;
    var pattern: [byte: 128] = [];
    _ = snprintf(&pattern[0] as *byte, 128usize, "\"%s\":[" as *byte, "doc_ids" as *byte);
    const pattern_len: usize = strlen(&pattern[0] as &byte);
    var pos: usize = 0usize;
    while content[pos] != 0 as byte {
        var matched: i32 = 1;
        var i: usize = 0usize;
        while i < pattern_len {
            if content[pos + i] == 0 as byte || content[pos + i] != pattern[i] {
                matched = 0;
                break;
            }
            i = i + 1usize;
        }
        if matched != 0 {
            pos = pos + pattern_len;
            while content[pos] != 0 as byte && content[pos] != 93 as byte {
                if content[pos] == 44 as byte {
                    pos = pos + 1usize;
                    continue;
                }
                if content[pos] != 34 as byte {
                    pos = pos + 1usize;
                    continue;
                }
                const start: usize = pos + 1usize;
                var end: usize = start;
                while content[end] != 0 as byte && content[end] != 34 as byte {
                    end = end + 1usize;
                }
                if content[end] != 34 as byte || out_count[0] >= MAX_ARGS {
                    return -1;
                }
                const out_index: usize = i32_to_usize_checked(out_count[0]);
                if out_index >= MAX_ARGS as usize {
                    return -1;
                }
                out[out_index] = arena_copy_range(&ctx.phase1.arena, content, start, end - start);
                if out[out_index] == null {
                    return -1;
                }
                out_count[0] = out_count[0] + 1;
                pos = end + 1usize;
            }
            if content[pos] != 93 as byte {
                return -1;
            }
            return 0;
        }
        pos = pos + 1usize;
    }
    return -1;
}

fn write_index_doc_ids(ctx: &Phase2Context,
                       index_name: &byte,
                       key: &byte,
                       doc_ids: [&byte: MAX_ARGS],
                       doc_count: i32) i32 {
    if ctx == null {
        return -1;
    }
    var path: [byte: PATH_MAX] = [];
    if build_index_entry_path(ctx, index_name, key, &path[0] as &byte, PATH_MAX) != 0 {
        return -1;
    }
    const file: &FILE = fopen(&path[0] as &const byte, "w" as &const byte);
    if file == null {
        return -1;
    }
    fputs("{\"index\":\"" as *byte, file);
    write_json_escape(file, index_name);
    fputs("\",\"key\":\"" as *byte, file);
    write_json_escape(file, key);
    fputs("\",\"doc_ids\":[" as *byte, file);
    var i: i32 = 0;
    while i < doc_count {
        if i > 0 {
            fputs("," as *byte, file);
        }
        fputc(34, file);
        write_json_escape(file, doc_ids[i as usize]);
        fputc(34, file);
        i = i + 1;
    }
    fputs("]}\n" as *byte, file);
    _ = fflush(file);
    if fclose(file) != 0 {
        return -1;
    }
    return 0;
}

fn append_index_doc_id(ctx: &Phase2Context, index_name: &byte, key: &byte, doc_id: &byte) i32 {
    if ctx == null || index_name == null || key == null || doc_id == null {
        return -1;
    }
    var path: [byte: PATH_MAX] = [];
    if build_index_entry_path(ctx, index_name, key, &path[0] as &byte, PATH_MAX) != 0 {
        return -1;
    }
    var doc_ids: [&byte: MAX_ARGS] = [];
    var doc_count: i32 = 0;
    if path_is_file(&path[0] as &byte) != 0 {
        var size_out: usize = 0usize;
        const content: &byte = read_file_into_arena(ctx.phase1, &path[0] as &byte, &size_out);
        _ = size_out;
        if content == null {
            return -1;
        }

        var pattern: [byte: 128] = [];
        _ = snprintf(&pattern[0] as *byte, 128usize, "\"%s\":[" as *byte, "doc_ids" as *byte);
        const pattern_len: usize = strlen(&pattern[0] as &byte);
        var pos: usize = 0usize;
        while content[pos] != 0 as byte {
            var matched: i32 = 1;
            var i: usize = 0usize;
            while i < pattern_len {
                if content[pos + i] == 0 as byte || content[pos + i] != pattern[i] {
                    matched = 0;
                    break;
                }
                i = i + 1usize;
            }
            if matched != 0 {
                pos = pos + pattern_len;
                while content[pos] != 0 as byte && content[pos] != 93 as byte {
                    if content[pos] == 44 as byte {
                        pos = pos + 1usize;
                        continue;
                    }
                    if content[pos] != 34 as byte {
                        pos = pos + 1usize;
                        continue;
                    }
                    const start: usize = pos + 1usize;
                    var end: usize = start;
                    while content[end] != 0 as byte && content[end] != 34 as byte {
                        end = end + 1usize;
                    }
                    if content[end] != 34 as byte || doc_count >= MAX_ARGS {
                        return -1;
                    }
                    const parsed_index: usize = i32_to_usize_checked(doc_count);
                    if parsed_index >= MAX_ARGS as usize {
                        return -1;
                    }
                    doc_ids[parsed_index] = arena_copy_range(&ctx.phase1.arena, content, start, end - start);
                    if doc_ids[parsed_index] == null {
                        return -1;
                    }
                    doc_count = doc_count + 1;
                    pos = end + 1usize;
                }
                break;
            }
            pos = pos + 1usize;
        }
    }

    var i: i32 = 0;
    while i < doc_count {
        if string_equals(doc_ids[i as usize], doc_id) != 0 {
            return 0;
        }
        i = i + 1;
    }
    if doc_count >= MAX_ARGS {
        return -1;
    }
    const next_index: usize = i32_to_usize_checked(doc_count);
    if next_index >= MAX_ARGS as usize {
        return -1;
    }
    doc_ids[next_index] = arena_copy_cstr(&ctx.phase1.arena, doc_id);
    if doc_ids[next_index] == null {
        return -1;
    }
    doc_count = doc_count + 1;
    return write_index_doc_ids(ctx, index_name, key, doc_ids, doc_count);
}

fn read_action_status_and_output_digest(ctx: &Phase2Context,
                                        action_doc_id: &byte,
                                        output_digest: &byte,
                                        output_digest_cap: usize,
                                        status_out: &byte,
                                        status_cap: usize) i32 {
    if ctx == null || action_doc_id == null || output_digest == null || status_out == null {
        return -1;
    }
    var path: [byte: PATH_MAX] = [];
    if join_path(&ctx.state_layout.meta_actions[0] as &byte, action_doc_id, &path[0] as &byte, PATH_MAX) != 0 {
        return -1;
    }
    if path_is_file(&path[0] as &byte) == 0 {
        return -1;
    }
    var size_out: usize = 0usize;
    const content: &byte = read_file_into_arena(ctx.phase1, &path[0] as &byte, &size_out);
    _ = size_out;
    if content == null {
        return -1;
    }
    if extract_json_string_field(content, "cache_status" as &byte, status_out, status_cap) != 0 {
        return -1;
    }
    if extract_json_string_field(content, "output_root_digest" as &byte, output_digest, output_digest_cap) != 0 {
        return -1;
    }
    return 0;
}

fn read_latest_owner_output_digest(ctx: &Phase2Context, owner: &byte, out: &byte, out_cap: usize) i32 {
    if ctx == null || owner == null || out == null {
        return -1;
    }
    var path: [byte: PATH_MAX] = [];
    if build_index_entry_path(ctx, "actions.by_owner" as &byte, owner, &path[0] as &byte, PATH_MAX) != 0 {
        return -1;
    }
    if path_is_file(&path[0] as &byte) == 0 {
        return -1;
    }
    var doc_ids: [&byte: MAX_ARGS] = [];
    var doc_count: i32 = 0;
    var size_out: usize = 0usize;
    const content: &byte = read_file_into_arena(ctx.phase1, &path[0] as &byte, &size_out);
    _ = size_out;
    if content == null {
        return -1;
    }

    var pattern: [byte: 128] = [];
    _ = snprintf(&pattern[0] as *byte, 128usize, "\"%s\":[" as *byte, "doc_ids" as *byte);
    const pattern_len: usize = strlen(&pattern[0] as &byte);
    var pos: usize = 0usize;
    while content[pos] != 0 as byte {
        var matched: i32 = 1;
        var i: usize = 0usize;
        while i < pattern_len {
            if content[pos + i] == 0 as byte || content[pos + i] != pattern[i] {
                matched = 0;
                break;
            }
            i = i + 1usize;
        }
        if matched != 0 {
            pos = pos + pattern_len;
            while content[pos] != 0 as byte && content[pos] != 93 as byte {
                if content[pos] == 44 as byte {
                    pos = pos + 1usize;
                    continue;
                }
                if content[pos] != 34 as byte {
                    pos = pos + 1usize;
                    continue;
                }
                const start: usize = pos + 1usize;
                var end: usize = start;
                while content[end] != 0 as byte && content[end] != 34 as byte {
                    end = end + 1usize;
                }
                if content[end] != 34 as byte || doc_count >= MAX_ARGS {
                    return -1;
                }
                const parsed_index: usize = i32_to_usize_checked(doc_count);
                if parsed_index >= MAX_ARGS as usize {
                    return -1;
                }
                doc_ids[parsed_index] = arena_copy_range(&ctx.phase1.arena, content, start, end - start);
                if doc_ids[parsed_index] == null {
                    return -1;
                }
                doc_count = doc_count + 1;
                pos = end + 1usize;
            }
            break;
        }
        pos = pos + 1usize;
    }
    if doc_count == 0 {
        return -1;
    }
    var index: i32 = doc_count - 1;
    while index >= 0 {
        var status_buf: [byte: 64] = [];
        const doc_index: usize = i32_to_usize_checked(index);
        if doc_index >= MAX_ARGS as usize {
            return -1;
        }
        if read_action_status_and_output_digest(ctx,
                                                doc_ids[doc_index],
                                                out,
                                                out_cap,
                                                &status_buf[0] as &byte,
                                                64usize) == 0 &&
            is_reusable_action_status(&status_buf[0] as &byte) != 0 {
            return 0;
        }
        index = index - 1;
    }
    return -1;
}

fn read_cache_output_digest(ctx: &Phase2Context, action_key: &byte, out: &byte, out_cap: usize) i32 {
    var cache_doc_id: &byte = action_key;
    var index_path: [byte: PATH_MAX] = [];
    if build_index_entry_path(ctx, "cache_entries.by_action_digest" as &byte, action_key, &index_path[0] as &byte, PATH_MAX) == 0 &&
        path_is_file(&index_path[0] as &byte) != 0 {
        var doc_ids: [&byte: MAX_ARGS] = [];
        var doc_count: i32 = 0;
        var size_out: usize = 0usize;
        const index_content: &byte = read_file_into_arena(ctx.phase1, &index_path[0] as &byte, &size_out);
        _ = size_out;
        if index_content != null {
            var pattern: [byte: 128] = [];
            _ = snprintf(&pattern[0] as *byte, 128usize, "\"%s\":[" as *byte, "doc_ids" as *byte);
            const pattern_len: usize = strlen(&pattern[0] as &byte);
            var pos: usize = 0usize;
            while index_content[pos] != 0 as byte {
                var matched: i32 = 1;
                var i: usize = 0usize;
                while i < pattern_len {
                    if index_content[pos + i] == 0 as byte || index_content[pos + i] != pattern[i] {
                        matched = 0;
                        break;
                    }
                    i = i + 1usize;
                }
                if matched != 0 {
                    pos = pos + pattern_len;
                    while index_content[pos] != 0 as byte && index_content[pos] != 93 as byte {
                        if index_content[pos] == 44 as byte {
                            pos = pos + 1usize;
                            continue;
                        }
                        if index_content[pos] != 34 as byte {
                            pos = pos + 1usize;
                            continue;
                        }
                        const start: usize = pos + 1usize;
                        var end: usize = start;
                        while index_content[end] != 0 as byte && index_content[end] != 34 as byte {
                            end = end + 1usize;
                        }
                        if index_content[end] != 34 as byte || doc_count >= MAX_ARGS {
                            return -1;
                        }
                        const parsed_index: usize = i32_to_usize_checked(doc_count);
                        if parsed_index >= MAX_ARGS as usize {
                            return -1;
                        }
                        doc_ids[parsed_index] = arena_copy_range(&ctx.phase1.arena, index_content, start, end - start);
                        if doc_ids[parsed_index] == null {
                            return -1;
                        }
                        doc_count = doc_count + 1;
                        pos = end + 1usize;
                    }
                    break;
                }
                pos = pos + 1usize;
            }
            if doc_count > 0 {
                const cache_index: usize = i32_to_usize_checked(doc_count - 1);
                if cache_index >= MAX_ARGS as usize {
                    return -1;
                }
                cache_doc_id = doc_ids[cache_index];
            }
        }
    }
    var path: [byte: PATH_MAX] = [];
    if join_path(&ctx.state_layout.meta_cache_entries[0] as &byte, cache_doc_id, &path[0] as &byte, PATH_MAX) != 0 {
        return -1;
    }
    if path_is_file(&path[0] as &byte) == 0 {
        return -1;
    }
    var size_out: usize = 0usize;
    const content: &byte = read_file_into_arena(ctx.phase1, &path[0] as &byte, &size_out);
    _ = size_out;
    if content == null {
        return -1;
    }
    return extract_json_string_field(content, "output_root_digest" as &byte, out, out_cap);
}

fn persist_phase2_metadata(ctx: &Phase2Context, subcommand: &byte, matched: &StringNode) i32 {
    var build_run_path: [byte: PATH_MAX] = [];
    if join_path(&ctx.state_layout.meta_build_runs[0] as &byte, &ctx.manifest.run_id[0] as &byte, &build_run_path[0] as &byte, PATH_MAX) != 0 {
        return -1;
    }
    const build_run_file: &FILE = fopen(&build_run_path[0] as &const byte, "w" as &const byte);
    if build_run_file == null {
        return -1;
    }
    fputs("{\"run_id\":\"" as *byte, build_run_file);
    write_json_escape(build_run_file, &ctx.manifest.run_id[0] as &byte);
    fputs("\",\"subcommand\":\"" as *byte, build_run_file);
    write_json_escape(build_run_file, subcommand);
    fputs("\",\"root_digest\":\"" as *byte, build_run_file);
    write_json_escape(build_run_file, ctx.root_digest);
    fputs("\",\"matched\":" as *byte, build_run_file);
    emit_string_node_array_json(build_run_file, matched);
    fputs(",\"actions\":" as *byte, build_run_file);
    fprintf(build_run_file, "%d" as *byte, ctx.action_count);
    fputs(",\"cache_hits\":" as *byte, build_run_file);
    fprintf(build_run_file, "%d" as *byte, ctx.cache_hit_count);
    fputs(",\"seeded\":" as *byte, build_run_file);
    fprintf(build_run_file, "%d" as *byte, ctx.seeded_count);
    fputs(",\"no_change\":" as *byte, build_run_file);
    fprintf(build_run_file, "%d" as *byte, ctx.no_change_count);
    fputs(",\"pending\":" as *byte, build_run_file);
    fprintf(build_run_file, "%d" as *byte, ctx.pending_count);
    fputs("}\n" as *byte, build_run_file);
    _ = fflush(build_run_file);
    if fclose(build_run_file) != 0 {
        return -1;
    }
    if append_index_doc_id(ctx,
                           "build_runs.by_run_id" as &byte,
                           &ctx.manifest.run_id[0] as &byte,
                           &ctx.manifest.run_id[0] as &byte) != 0 {
        return -1;
    }

    var events_path: [byte: PATH_MAX] = [];
    if join_path(&ctx.state_layout.meta_events[0] as &byte, &ctx.manifest.run_id[0] as &byte, &events_path[0] as &byte, PATH_MAX) != 0 {
        return -1;
    }
    const events_file: &FILE = fopen(&events_path[0] as &const byte, "w" as &const byte);
    if events_file == null {
        return -1;
    }
    fputs("{\"event\":\"BuildPlanned\",\"run_id\":\"" as *byte, events_file);
    write_json_escape(events_file, &ctx.manifest.run_id[0] as &byte);
    fputs("\",\"root_digest\":\"" as *byte, events_file);
    write_json_escape(events_file, ctx.root_digest);
    fputs("\",\"actions\":" as *byte, events_file);
    fprintf(events_file, "%d" as *byte, ctx.action_count);
    fputs("}\n" as *byte, events_file);

    var action: &PlannedAction = ctx.action_head;
    while action != null {
        var action_path: [byte: PATH_MAX] = [];
        if join_path(&ctx.state_layout.meta_actions[0] as &byte, action.action_key, &action_path[0] as &byte, PATH_MAX) != 0 {
            _ = fclose(events_file);
            return -1;
        }
        const action_file: &FILE = fopen(&action_path[0] as &const byte, "w" as &const byte);
        if action_file == null {
            _ = fclose(events_file);
            return -1;
        }
        fputs("{\"action_key\":\"" as *byte, action_file);
        write_json_escape(action_file, action.action_key);
        fputs("\",\"run_id\":\"" as *byte, action_file);
        write_json_escape(action_file, &ctx.manifest.run_id[0] as &byte);
        fputs("\",\"label\":\"" as *byte, action_file);
        write_json_escape(action_file, action.label);
        fputs("\",\"kind\":\"" as *byte, action_file);
        write_json_escape(action_file, action.kind);
        fputs("\",\"cache_status\":\"" as *byte, action_file);
        write_json_escape(action_file, action.cache_status);
        fputs("\",\"input_root_digest\":\"" as *byte, action_file);
        write_json_escape(action_file, action.input_root_digest);
        fputs("\",\"output_root_digest\":" as *byte, action_file);
        if action.output_root_digest != null {
            fputc(34, action_file);
            write_json_escape(action_file, action.output_root_digest);
            fputc(34, action_file);
        } else {
            fputs("null" as *byte, action_file);
        }
        fputs(",\"exit_code\":" as *byte, action_file);
        fprintf(action_file, "%d" as *byte, action.exit_code);
        fputs(",\"pending_execution\":" as *byte, action_file);
        if action.pending_execution != 0 {
            fputs("true" as *byte, action_file);
        } else {
            fputs("false" as *byte, action_file);
        }
        fputs(",\"stdout_log\":" as *byte, action_file);
        if action.stdout_path != null {
            fputc(34, action_file);
            write_json_escape(action_file, action.stdout_path);
            fputc(34, action_file);
        } else {
            fputs("null" as *byte, action_file);
        }
        fputs(",\"stderr_log\":" as *byte, action_file);
        if action.stderr_path != null {
            fputc(34, action_file);
            write_json_escape(action_file, action.stderr_path);
            fputc(34, action_file);
        } else {
            fputs("null" as *byte, action_file);
        }
        fputs("}\n" as *byte, action_file);
        _ = fflush(action_file);
        if fclose(action_file) != 0 {
            _ = fclose(events_file);
            return -1;
        }
        if append_index_doc_id(ctx, "actions.by_digest" as &byte, action.action_key, action.action_key) != 0 ||
            append_index_doc_id(ctx, "actions.by_owner" as &byte, action.label, action.action_key) != 0 ||
            append_index_doc_id(ctx, "actions.by_status" as &byte, action.cache_status, action.action_key) != 0 {
            _ = fclose(events_file);
            return -1;
        }

        fputs("{\"event\":\"ActionPlanned\",\"run_id\":\"" as *byte, events_file);
        write_json_escape(events_file, &ctx.manifest.run_id[0] as &byte);
        fputs("\",\"action_key\":\"" as *byte, events_file);
        write_json_escape(events_file, action.action_key);
        fputs("\",\"label\":\"" as *byte, events_file);
        write_json_escape(events_file, action.label);
        fputs("\",\"status\":\"" as *byte, events_file);
        write_json_escape(events_file, action.cache_status);
        fputs("\"}\n" as *byte, events_file);

        var cache_path: [byte: PATH_MAX] = [];
        if join_path(&ctx.state_layout.meta_cache_entries[0] as &byte, action.action_key, &cache_path[0] as &byte, PATH_MAX) != 0 {
            _ = fclose(events_file);
            return -1;
        }
        const cache_file: &FILE = fopen(&cache_path[0] as &const byte, "w" as &const byte);
        if cache_file == null {
            _ = fclose(events_file);
            return -1;
        }
        fputs("{\"action_key\":\"" as *byte, cache_file);
        write_json_escape(cache_file, action.action_key);
        fputs("\",\"owner\":\"" as *byte, cache_file);
        write_json_escape(cache_file, action.label);
        fputs("\",\"output_root_digest\":" as *byte, cache_file);
        if action.output_root_digest != null {
            fputc(34, cache_file);
            write_json_escape(cache_file, action.output_root_digest);
            fputc(34, cache_file);
        } else {
            fputs("null" as *byte, cache_file);
        }
        fputs(",\"status\":\"" as *byte, cache_file);
        write_json_escape(cache_file, action.cache_status);
        fputs("\"}\n" as *byte, cache_file);
        _ = fflush(cache_file);
        if fclose(cache_file) != 0 {
            _ = fclose(events_file);
            return -1;
        }
        if append_index_doc_id(ctx,
                               "cache_entries.by_action_digest" as &byte,
                               action.action_key,
                               action.action_key) != 0 {
            _ = fclose(events_file);
            return -1;
        }

        var output: &StringNode = action.output_head;
        while output != null {
            const artifact_id: &byte = blake2s_hex_text(ctx.phase1, output.text);
            var artifact_path: [byte: PATH_MAX] = [];
            if artifact_id == null ||
                join_path(&ctx.state_layout.meta_artifacts[0] as &byte, artifact_id, &artifact_path[0] as &byte, PATH_MAX) != 0 {
                _ = fclose(events_file);
                return -1;
            }
            const artifact_file: &FILE = fopen(&artifact_path[0] as &const byte, "w" as &const byte);
            if artifact_file == null {
                _ = fclose(events_file);
                return -1;
            }
            const snapshot: &SnapshotEntry = snapshot_workspace_path(ctx, output.text, 0);
            fputs("{\"artifact_id\":\"" as *byte, artifact_file);
            write_json_escape(artifact_file, artifact_id);
            fputs("\",\"path\":\"" as *byte, artifact_file);
            write_json_escape(artifact_file, output.text);
            fputs("\",\"producer\":\"" as *byte, artifact_file);
            write_json_escape(artifact_file, action.action_key);
            fputs("\",\"digest\":" as *byte, artifact_file);
            if snapshot != null {
                fputc(34, artifact_file);
                write_json_escape(artifact_file, snapshot.digest_hex);
                fputc(34, artifact_file);
            } else {
                fputs("null" as *byte, artifact_file);
            }
            fputs("}\n" as *byte, artifact_file);
            _ = fflush(artifact_file);
            if fclose(artifact_file) != 0 {
                _ = fclose(events_file);
                return -1;
            }
            if append_index_doc_id(ctx, "artifacts.by_path" as &byte, output.text, artifact_id) != 0 {
                _ = fclose(events_file);
                return -1;
            }
            output = output.next;
        }

        action = action.next;
    }

    _ = fflush(events_file);
    if fclose(events_file) != 0 {
        return -1;
    }
    if append_index_doc_id(ctx,
                           "events.by_run_id" as &byte,
                           &ctx.manifest.run_id[0] as &byte,
                           &ctx.manifest.run_id[0] as &byte) != 0 {
        return -1;
    }
    return 0;
}

fn emit_string_node_array_json(stream: &FILE, head: &StringNode) void {
    fputs("[" as *byte, stream);
    var first: i32 = 1;
    var node: &StringNode = head;
    while node != null {
        if first == 0 {
            fputs("," as *byte, stream);
        }
        fputc(34, stream);
        write_json_escape(stream, node.text);
        fputc(34, stream);
        first = 0;
        node = node.next;
    }
    fputs("]" as *byte, stream);
}

fn emit_action_json(stream: &FILE, action: &PlannedAction) void {
    fputs("{\"label\":\"" as *byte, stream);
    write_json_escape(stream, action.label);
    fputs("\",\"kind\":\"" as *byte, stream);
    write_json_escape(stream, action.kind);
    fputs("\",\"order\":" as *byte, stream);
    fprintf(stream, "%d" as *byte, action.order_index);
    fputs(",\"action_key\":\"" as *byte, stream);
    write_json_escape(stream, action.action_key);
    fputs("\",\"input_root_digest\":\"" as *byte, stream);
    write_json_escape(stream, action.input_root_digest);
    fputs("\",\"output_root_digest\":" as *byte, stream);
    if action.output_root_digest != null {
        fputc(34, stream);
        write_json_escape(stream, action.output_root_digest);
        fputc(34, stream);
    } else {
        fputs("null" as *byte, stream);
    }
    fputs(",\"cache_status\":\"" as *byte, stream);
    write_json_escape(stream, action.cache_status);
    fputs("\",\"exit_code\":" as *byte, stream);
    fprintf(stream, "%d" as *byte, action.exit_code);
    fputs(",\"pending_execution\":" as *byte, stream);
    if action.pending_execution != 0 {
        fputs("true" as *byte, stream);
    } else {
        fputs("false" as *byte, stream);
    }
    fputs(",\"stdout_log\":" as *byte, stream);
    if action.stdout_path != null {
        fputc(34, stream);
        write_json_escape(stream, action.stdout_path);
        fputc(34, stream);
    } else {
        fputs("null" as *byte, stream);
    }
    fputs(",\"stderr_log\":" as *byte, stream);
    if action.stderr_path != null {
        fputc(34, stream);
        write_json_escape(stream, action.stderr_path);
        fputc(34, stream);
    } else {
        fputs("null" as *byte, stream);
    }
    fputs(",\"deps\":" as *byte, stream);
    emit_string_node_array_json(stream, action.dep_head);
    fputs(",\"command\":" as *byte, stream);
    emit_string_node_array_json(stream, action.command_head);
    fputs(",\"inputs\":" as *byte, stream);
    emit_string_node_array_json(stream, action.input_head);
    fputs(",\"outputs\":" as *byte, stream);
    emit_string_node_array_json(stream, action.output_head);
    fputs("}" as *byte, stream);
}

fn emit_phase2_summary_json(stream: &FILE, ctx: &Phase2Context) void {
    fputs("{\"root_digest\":\"" as *byte, stream);
    write_json_escape(stream, ctx.root_digest);
    fputs("\",\"snapshots\":" as *byte, stream);
    fprintf(stream, "%d" as *byte, ctx.snapshot_count);
    fputs(",\"actions\":" as *byte, stream);
    fprintf(stream, "%d" as *byte, ctx.action_count);
    fputs(",\"cache_hits\":" as *byte, stream);
    fprintf(stream, "%d" as *byte, ctx.cache_hit_count);
    fputs(",\"seeded\":" as *byte, stream);
    fprintf(stream, "%d" as *byte, ctx.seeded_count);
    fputs(",\"no_change\":" as *byte, stream);
    fprintf(stream, "%d" as *byte, ctx.no_change_count);
    fputs(",\"pending\":" as *byte, stream);
    fprintf(stream, "%d" as *byte, ctx.pending_count);
    fputs("}" as *byte, stream);
}

fn emit_plan_json(ctx: &Phase1Context,
                  phase2: &Phase2Context,
                  requested: [&byte: MAX_ARGS],
                  requested_count: i32,
                  matched: &StringNode) void {
    fputs("{\"ok\":true,\"phase\":2," as *byte, libc.stdout);
    fputs("\"workspace\":{" as *byte, libc.stdout);
    fputs("\"name\":\"" as *byte, libc.stdout);
    write_json_escape(libc.stdout, ctx.workspace_ir.name);
    fputs("\",\"root\":\"" as *byte, libc.stdout);
    write_json_escape(libc.stdout, "." as &byte);
    fputs("\",\"entrypoint\":\"" as *byte, libc.stdout);
    if ctx.workspace_ir.source_file != null {
        write_json_escape(libc.stdout, ctx.workspace_ir.source_file.rel_path);
    } else {
        write_json_escape(libc.stdout, "uya.build" as &byte);
    }
    fputs("\",\"strict\":" as *byte, libc.stdout);
    if ctx.workspace_ir.strict != 0 {
        fputs("true" as *byte, libc.stdout);
    } else {
        fputs("false" as *byte, libc.stdout);
    }
    fputs(",\"default\":" as *byte, libc.stdout);
    emit_typed_value_json(libc.stdout, ctx.workspace_ir.defaults);
    fputs("}," as *byte, libc.stdout);

    fputs("\"files\":[" as *byte, libc.stdout);
    var first_file: i32 = 1;
    var file: &SourceFile = ctx.files_head;
    while file != null {
        if first_file == 0 {
            fputs("," as *byte, libc.stdout);
        }
        fputc(34, libc.stdout);
        write_json_escape(libc.stdout, file.rel_path);
        fputc(34, libc.stdout);
        first_file = 0;
        file = file.next;
    }
    fputs("]," as *byte, libc.stdout);

    fputs("\"uses\":[" as *byte, libc.stdout);
    var first_use: i32 = 1;
    var use_item: &RuleUse = ctx.uses_head;
    while use_item != null {
        if first_use == 0 {
            fputs("," as *byte, libc.stdout);
        }
        fputc(34, libc.stdout);
        write_json_escape(libc.stdout, use_item.name);
        fputc(34, libc.stdout);
        first_use = 0;
        use_item = use_item.next;
    }
    fputs("]," as *byte, libc.stdout);

    fputs("\"configs\":[" as *byte, libc.stdout);
    var first_config: i32 = 1;
    var config: &IRConfig = ctx.configs_head;
    while config != null {
        if first_config == 0 {
            fputs("," as *byte, libc.stdout);
        }
        fputs("{\"name\":\"" as *byte, libc.stdout);
        write_json_escape(libc.stdout, config.name);
        fputs("\",\"file\":\"" as *byte, libc.stdout);
        write_json_escape(libc.stdout, config.file.rel_path);
        fputs("\",\"line\":" as *byte, libc.stdout);
        fprintf(libc.stdout, "%d" as *byte, config.span.start.line);
        fputs(",\"attrs\":" as *byte, libc.stdout);
        emit_ir_fields_json(libc.stdout, config.attrs);
        fputs("}" as *byte, libc.stdout);
        first_config = 0;
        config = config.next;
    }
    fputs("]," as *byte, libc.stdout);

    fputs("\"targets\":[" as *byte, libc.stdout);
    var first_target: i32 = 1;
    var target: &IRTarget = ctx.targets_head;
    while target != null {
        if first_target == 0 {
            fputs("," as *byte, libc.stdout);
        }
        fputs("{\"label\":\"" as *byte, libc.stdout);
        write_json_escape(libc.stdout, target.label);
        fputs("\",\"kind\":\"" as *byte, libc.stdout);
        write_json_escape(libc.stdout, target.kind);
        fputs("\",\"package\":\"" as *byte, libc.stdout);
        write_json_escape(libc.stdout, target.package_path);
        fputs("\",\"file\":\"" as *byte, libc.stdout);
        write_json_escape(libc.stdout, target.file.rel_path);
        fputs("\",\"line\":" as *byte, libc.stdout);
        fprintf(libc.stdout, "%d" as *byte, target.span.start.line);
        fputs(",\"providers\":" as *byte, libc.stdout);
        emit_provider_mask_json(libc.stdout, target.provider_mask);
        fputs(",\"attrs\":" as *byte, libc.stdout);
        emit_ir_fields_json(libc.stdout, target.attrs);
        fputs("}" as *byte, libc.stdout);
        first_target = 0;
        target = target.next;
    }
    fputs("]," as *byte, libc.stdout);

    fputs("\"requested\":[" as *byte, libc.stdout);
    var first_req: i32 = 1;
    var i: i32 = 0;
    while i < requested_count {
        if first_req == 0 {
            fputs("," as *byte, libc.stdout);
        }
        fputc(34, libc.stdout);
        write_json_escape(libc.stdout, requested[i as usize]);
        fputc(34, libc.stdout);
        first_req = 0;
        i = i + 1;
    }
    fputs("],\"matched\":" as *byte, libc.stdout);
    emit_string_node_array_json(libc.stdout, matched);
    fputs(",\"planning\":" as *byte, libc.stdout);
    emit_phase2_summary_json(libc.stdout, phase2);
    fputs(",\"action_graph\":[" as *byte, libc.stdout);
    var first_action: i32 = 1;
    var action: &PlannedAction = phase2.action_head;
    while action != null {
        if first_action == 0 {
            fputs("," as *byte, libc.stdout);
        }
        emit_action_json(libc.stdout, action);
        first_action = 0;
        action = action.next;
    }
    fputs("]" as *byte, libc.stdout);
    fputs("}\n" as *byte, libc.stdout);
    _ = fflush(libc.stdout);
}

fn emit_query_json(ctx: &Phase1Context, expression: &byte, matches: &StringNode) void {
    fputs("{\"ok\":true,\"phase\":1,\"workspace\":\"" as *byte, libc.stdout);
    write_json_escape(libc.stdout, ctx.workspace_ir.name);
    fputs("\",\"expression\":\"" as *byte, libc.stdout);
    write_json_escape(libc.stdout, expression);
    fputs("\",\"targets\":" as *byte, libc.stdout);
    emit_string_node_array_json(libc.stdout, matches);
    fputs("}\n" as *byte, libc.stdout);
    _ = fflush(libc.stdout);
}

fn emit_query_text(matches: &StringNode) void {
    var node: &StringNode = matches;
    while node != null {
        fprintf(libc.stdout, "%s\n" as *byte, node.text as *byte);
        node = node.next;
    }
    _ = fflush(libc.stdout);
}

fn emit_plan_text(ctx: &Phase1Context, phase2: &Phase2Context, matched: &StringNode) void {
    fprintf(libc.stdout, "workspace: %s\n" as *byte, ctx.workspace_ir.name as *byte);
    fprintf(libc.stdout, "phase: %d\n" as *byte, PLAN_PHASE_NUMBER);
    fprintf(libc.stdout, "files: %d\n" as *byte, ctx.file_count);
    fprintf(libc.stdout, "rule_packs: %d\n" as *byte, ctx.use_count);
    fprintf(libc.stdout, "configs: %d\n" as *byte, ctx.config_count);
    fprintf(libc.stdout, "targets: %d\n" as *byte, ctx.target_count);
    fprintf(libc.stdout, "snapshots: %d\n" as *byte, phase2.snapshot_count);
    fprintf(libc.stdout, "actions: %d\n" as *byte, phase2.action_count);
    fprintf(libc.stdout, "cache_hits: %d\n" as *byte, phase2.cache_hit_count);
    fprintf(libc.stdout, "seeded_outputs: %d\n" as *byte, phase2.seeded_count);
    fprintf(libc.stdout, "success_no_change: %d\n" as *byte, phase2.no_change_count);
    fprintf(libc.stdout, "pending_execution: %d\n" as *byte, phase2.pending_count);
    fprintf(libc.stdout, "root_digest: %s\n" as *byte, phase2.root_digest as *byte);
    fputs("matched:\n" as *byte, libc.stdout);
    var node: &StringNode = matched;
    while node != null {
        fprintf(libc.stdout, "  %s\n" as *byte, node.text as *byte);
        node = node.next;
    }
    fputs("actions:\n" as *byte, libc.stdout);
    var action: &PlannedAction = phase2.action_head;
    while action != null {
        fprintf(libc.stdout,
                "  %s %s [%s]\n" as *byte,
                action.label as *byte,
                action.kind as *byte,
                action.cache_status as *byte);
        action = action.next;
    }
    _ = fflush(libc.stdout);
}

fn emit_build_json(ctx: &Phase1Context, phase2: &Phase2Context, matched: &StringNode) void {
    fputs("{\"ok\":true,\"phase\":3,\"mode\":\"local-executor\",\"workspace\":\"" as *byte, libc.stdout);
    write_json_escape(libc.stdout, ctx.workspace_ir.name);
    fputs("\",\"matched\":" as *byte, libc.stdout);
    emit_string_node_array_json(libc.stdout, matched);
    fputs(",\"planning\":" as *byte, libc.stdout);
    emit_phase2_summary_json(libc.stdout, phase2);
    fputs(",\"action_graph\":[" as *byte, libc.stdout);
    var first_action: i32 = 1;
    var action: &PlannedAction = phase2.action_head;
    while action != null {
        if first_action == 0 {
            fputs("," as *byte, libc.stdout);
        }
        emit_action_json(libc.stdout, action);
        first_action = 0;
        action = action.next;
    }
    fputs("]}\n" as *byte, libc.stdout);
    _ = fflush(libc.stdout);
}

fn emit_build_text(ctx: &Phase1Context, phase2: &Phase2Context, matched: &StringNode) void {
    fprintf(libc.stdout, "workspace: %s\n" as *byte, ctx.workspace_ir.name as *byte);
    fprintf(libc.stdout, "phase: %d\n" as *byte, BUILD_PHASE_NUMBER);
    fprintf(libc.stdout, "matched_targets: %d\n" as *byte, phase2.matched_count);
    fprintf(libc.stdout, "planned_actions: %d\n" as *byte, phase2.action_count);
    fprintf(libc.stdout, "cache_hits: %d\n" as *byte, phase2.cache_hit_count);
    fprintf(libc.stdout, "seeded_outputs: %d\n" as *byte, phase2.seeded_count);
    fprintf(libc.stdout, "success_no_change: %d\n" as *byte, phase2.no_change_count);
    fprintf(libc.stdout, "pending_execution: %d\n" as *byte, phase2.pending_count);
    fprintf(libc.stdout, "root_digest: %s\n" as *byte, phase2.root_digest as *byte);
    fputs("matched:\n" as *byte, libc.stdout);
    var node: &StringNode = matched;
    while node != null {
        fprintf(libc.stdout, "  %s\n" as *byte, node.text as *byte);
        node = node.next;
    }
    _ = fflush(libc.stdout);
}

fn load_phase1_model(options: &Options, workspace: &Workspace, ctx: &Phase1Context) i32 {
    phase1_ctx_init(ctx, &workspace.root[0] as &byte, &workspace.entrypoint[0] as &byte);
    if load_workspace_files(ctx) != 0 {
        return emit_diagnostic(options.output_mode, &ctx.diagnostic);
    }
    if analyze_workspace(ctx) != 0 {
        return emit_diagnostic(options.output_mode, &ctx.diagnostic);
    }
    return 0;
}

fn print_root_help() void {
    fprintf(libc.stdout, "uyabuild %s\n" as *byte, VERSION as *byte);
    fputs("\n" as *byte, libc.stdout);
    fputs("Usage:\n" as *byte, libc.stdout);
    fputs("  uyabuild [global-options] <command> [command-options]\n" as *byte, libc.stdout);
    fputs("\n" as *byte, libc.stdout);
    fputs("Bootstrap:\n" as *byte, libc.stdout);
    fputs("  make bootstrap        build the pure Uya bootstrap binary into bin/uyabuild\n" as *byte, libc.stdout);
    fputs("\n" as *byte, libc.stdout);
    fputs("Commands:\n" as *byte, libc.stdout);
    fputs("  build                 analyze, snapshot, and execute supported local actions\n" as *byte, libc.stdout);
    fputs("  query                 inspect the typed target graph\n" as *byte, libc.stdout);
    fputs("  plan                  emit the typed IR plus Phase 2 action graph\n" as *byte, libc.stdout);
    fputs("  version               print the bootstrap version\n" as *byte, libc.stdout);
    fputs("  help                  show command help\n" as *byte, libc.stdout);
    fputs("\n" as *byte, libc.stdout);
    fputs("Global options:\n" as *byte, libc.stdout);
    fputs("  --workspace <path>    override workspace root discovery\n" as *byte, libc.stdout);
    fputs("  --state-dir <path>    override state directory (default: <workspace>/.uya-build)\n" as *byte, libc.stdout);
    fputs("  --json                emit diagnostics as JSON\n" as *byte, libc.stdout);
    fputs("  -h, --help            show help\n" as *byte, libc.stdout);
    fputs("  --version             print version\n" as *byte, libc.stdout);
    fputs("\n" as *byte, libc.stdout);
    fputs("Examples:\n" as *byte, libc.stdout);
    fputs("  uyabuild build //bootstrap:uyabuild\n" as *byte, libc.stdout);
    fputs("  uyabuild query //...\n" as *byte, libc.stdout);
    fputs("  uyabuild plan //app:hello --json\n" as *byte, libc.stdout);
    _ = fflush(libc.stdout);
}

fn print_build_help() void {
    fputs("Usage:\n" as *byte, libc.stdout);
    fputs("  uyabuild build [options] <target> [<target> ...]\n" as *byte, libc.stdout);
    fputs("\n" as *byte, libc.stdout);
    fputs("Options:\n" as *byte, libc.stdout);
    fputs("  --workspace <path>    override workspace root discovery\n" as *byte, libc.stdout);
    fputs("  --state-dir <path>    override state directory\n" as *byte, libc.stdout);
    fputs("  --json                emit diagnostics as JSON\n" as *byte, libc.stdout);
    fputs("  -h, --help            show build help\n" as *byte, libc.stdout);
    fputs("\n" as *byte, libc.stdout);
    fputs("Notes:\n" as *byte, libc.stdout);
    fputs("  Build runs Phase 2 analysis/planning first, then executes pending\n" as *byte, libc.stdout);
    fputs("  legacy.shell and task actions through the local executor.\n" as *byte, libc.stdout);
    fputs("  Existing outputs may still resolve as local-hit, seeded-output, or\n" as *byte, libc.stdout);
    fputs("  success-no-change without launching a child action.\n" as *byte, libc.stdout);
    _ = fflush(libc.stdout);
}

