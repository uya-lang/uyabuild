workspace {
  name = "cxx-header-scan"
  default = ["//app:hello"]
  strict = true
}

use cxx

cxx.library "//lib:hello" {
  srcs = ["src/lib.cc"]
  hdrs = ["src/lib.h"]
  discover = cpp.headers()
}

cxx.binary "//app:hello" {
  srcs = ["src/main.cc"]
  deps = ["//lib:hello"]
  discover = cpp.headers()
  out = "out/bin/hello"
}
